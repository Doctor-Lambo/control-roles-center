
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	ЗаполнитьДеревоОбъектов();

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыОбъектыМетаданных

&НаКлиенте
Процедура ОбъектыМетаданныхВыборОбъектаПриИзменении(Элемент)

	ТекущиеДанные = Элементы.ОбъектыМетаданных.ТекущиеДанные;

	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;

	// Третье состояние вручную не устанавливаем — сбрасываем в 0
	Если ТекущиеДанные.ВыборОбъекта = 2 Тогда
		ТекущиеДанные.ВыборОбъекта = 0;
	КонецЕсли;

	Если ТекущиеДанные.ЭтоГруппа Тогда
		УстановитьВыборДочерним(ТекущиеДанные, ТекущиеДанные.ВыборОбъекта);
	КонецЕсли;

	ПересчитатьВыборРодителя(ТекущиеДанные);

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Выбрать(Команда)

	РезультатВыбора = СобратьВыбранныеОбъекты();
	Закрыть(РезультатВыбора);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗаполнитьДеревоОбъектов()

	// Разбираем JSON со списком уже добавленных объектов
	УжеДобавленные = Новый Соответствие;
	Если ЗначениеЗаполнено(УжеВыбранныеОбъекты) Тогда

		МассивОбъектов = ПолучитьМассивИзJSON(УжеВыбранныеОбъекты);
		Если ТипЗнч(МассивОбъектов) = Тип("Массив") Тогда
			Для Каждого Элемент Из МассивОбъектов Цикл
				Ключ = Элемент["ВидОбъекта"] + "|" + Элемент["ИмяОбъекта"];
				УжеДобавленные.Вставить(Ключ, Истина);
			КонецЦикла;
		КонецЕсли;

	КонецЕсли;

	// Виды метаданных, которые не показываем в форме выбора
	ВидыИсключения = Новый Соответствие;
	ВидыИсключения.Вставить("Configuration", Истина);
	ВидыИсключения.Вставить("HTTPService", Истина);
	ВидыИсключения.Вставить("WebService", Истина);
	ВидыИсключения.Вставить("Subsystem", Истина);
	ВидыИсключения.Вставить("ExchangePlan", Истина);

	ВсеВиды = цур_РеестрМетаданныхСерверПовтИсп.ВсеВидыМетаданных();

	Для Каждого ОписаниеВида Из ВсеВиды Цикл

		Если ВидыИсключения.Получить(ОписаниеВида.ВидМетаданных) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;

		ИмяКоллекции = ОписаниеВида.ИмяКоллекцииМетаданных;
		Если НЕ ЗначениеЗаполнено(ИмяКоллекции) Тогда
			Продолжить;
		КонецЕсли;

		СписокОбъектов = цур_ПровайдерМетаданныхСервер.СписокОбъектовМетаданных(
			ИнформационнаяБаза, ОписаниеВида.ВидМетаданных);

		Если СписокОбъектов.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;

		СтрокаГруппы = ОбъектыМетаданных.ПолучитьЭлементы().Добавить();
		СтрокаГруппы.ПредставлениеОбъекта = ОписаниеВида.СинонимМн;
		СтрокаГруппы.ВидОбъекта           = ОписаниеВида.ВидМетаданных;
		СтрокаГруппы.ЭтоГруппа            = Истина;
		СтрокаГруппы.КартинкаОбъекта      = КартинкаВидаМетаданных(ОписаниеВида.ВидМетаданных);

		КоличествоВыбранных = 0;

		Для Каждого ОбъектМД Из СписокОбъектов Цикл

			СтрокаОбъекта = СтрокаГруппы.ПолучитьЭлементы().Добавить();
			СтрокаОбъекта.ВидОбъекта           = ОписаниеВида.ВидМетаданных;
			СтрокаОбъекта.ИмяОбъекта           = ОбъектМД.ИмяОбъекта;
			СтрокаОбъекта.ПредставлениеОбъекта = ?(ЗначениеЗаполнено(ОбъектМД.Синоним), ОбъектМД.Синоним, ОбъектМД.ИмяОбъекта);
			СтрокаОбъекта.ЭтоГруппа            = Ложь;

			Ключ = ОписаниеВида.ВидМетаданных + "|" + ОбъектМД.ИмяОбъекта;
			Если УжеДобавленные.Получить(Ключ) <> Неопределено Тогда
				СтрокаОбъекта.ВыборОбъекта = 1;
				КоличествоВыбранных        = КоличествоВыбранных + 1;
			КонецЕсли;

		КонецЦикла;

		Если КоличествоВыбранных = 0 Тогда
			СтрокаГруппы.ВыборОбъекта = 0;
		ИначеЕсли КоличествоВыбранных = СписокОбъектов.Количество() Тогда
			СтрокаГруппы.ВыборОбъекта = 1;
		Иначе
			СтрокаГруппы.ВыборОбъекта = 2;
		КонецЕсли;

	КонецЦикла;

КонецПроцедуры

// Возвращает картинку для вида метаданных из библиотеки картинок конфигурации.
//
// Параметры:
//  ВидМетаданных - Строка
//
// Возвращает:
//  Картинка
//
&НаСервере
Функция КартинкаВидаМетаданных(ВидМетаданных)

	Попытка
		Возврат БиблиотекаКартинок["гпр_" + ВидМетаданных];
	Исключение
		Возврат Неопределено;
	КонецПопытки;

КонецФункции

// Собирает только НОВЫЕ выбранные объекты (не входящие в список уже добавленных).
//
// Возвращает:
//  Массив из Структура - каждый элемент содержит поля ВидОбъекта и ИмяОбъекта
//
&НаКлиенте
Функция СобратьВыбранныеОбъекты()

	Результат = Новый Массив;

	УжеДобавленные = РазобратьСписокУжеДобавленных();

	Для Каждого СтрокаГруппы Из ОбъектыМетаданных.ПолучитьЭлементы() Цикл
		Для Каждого СтрокаОбъекта Из СтрокаГруппы.ПолучитьЭлементы() Цикл

			Если СтрокаОбъекта.ВыборОбъекта <> 1 Тогда
				Продолжить;
			КонецЕсли;

			Ключ = СтрокаОбъекта.ВидОбъекта + "|" + СтрокаОбъекта.ИмяОбъекта;
			Если УжеДобавленные.Получить(Ключ) <> Неопределено Тогда
				Продолжить;
			КонецЕсли;

			Результат.Добавить(Новый Структура("ВидОбъекта, ИмяОбъекта",
				СтрокаОбъекта.ВидОбъекта, СтрокаОбъекта.ИмяОбъекта));

		КонецЦикла;
	КонецЦикла;

	Возврат Результат;

КонецФункции

// Разбирает строку JSON с уже добавленными объектами в соответствие Ключ -> Истина.
// Ключ формируется как "ВидОбъекта|ИмяОбъекта".
//
// Возвращает:
//  Соответствие
//
&НаКлиенте
Функция РазобратьСписокУжеДобавленных()

	Результат = Новый Соответствие;

	Если НЕ ЗначениеЗаполнено(УжеВыбранныеОбъекты) Тогда
		Возврат Результат;
	КонецЕсли;

	МассивОбъектов = ПолучитьМассивИзJSON(УжеВыбранныеОбъекты);
	Если ТипЗнч(МассивОбъектов) <> Тип("Массив") Тогда
		Возврат Результат;
	КонецЕсли;

	Для Каждого Элемент Из МассивОбъектов Цикл
		Ключ = Элемент["ВидОбъекта"] + "|" + Элемент["ИмяОбъекта"];
		Результат.Вставить(Ключ, Истина);
	КонецЦикла;

	Возврат Результат;

КонецФункции

// Разбирает JSON-строку в объект средствами платформы.
//
// Параметры:
//  СтрокаJSON - Строка
//
// Возвращает:
//  Произвольный - тип зависит от содержимого JSON
//
&НаКлиентеНаСервереБезКонтекста
Функция ПолучитьМассивИзJSON(СтрокаJSON)

	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(СтрокаJSON);
	Возврат ПрочитатьJSON(ЧтениеJSON);

КонецФункции

&НаКлиенте
Процедура УстановитьВыборДочерним(Данные, Значение)

	Для Каждого Дочерняя Из Данные.ПолучитьЭлементы() Цикл
		Дочерняя.ВыборОбъекта = Значение;
		УстановитьВыборДочерним(Дочерняя, Значение);
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьВыборРодителя(Данные)

	Родитель = Данные.ПолучитьРодителя();
	Если Родитель = Неопределено Тогда
		Возврат;
	КонецЕсли;

	КоличествоВсего      = 0;
	КоличествоВыбранных  = 0;

	Для Каждого Дочерняя Из Родитель.ПолучитьЭлементы() Цикл

		КоличествоВсего = КоличествоВсего + 1;

		Если Дочерняя.ВыборОбъекта = 1 Тогда
			КоличествоВыбранных = КоличествоВыбранных + 1;
		ИначеЕсли Дочерняя.ВыборОбъекта = 2 Тогда
			КоличествоВыбранных = КоличествоВыбранных + 0.5; // частично выбрано
		КонецЕсли;

	КонецЦикла;

	Если КоличествоВыбранных = 0 Тогда
		Родитель.ВыборОбъекта = 0;
	ИначеЕсли КоличествоВыбранных = КоличествоВсего Тогда
		Родитель.ВыборОбъекта = 1;
	Иначе
		Родитель.ВыборОбъекта = 2;
	КонецЕсли;

КонецПроцедуры

#КонецОбласти
