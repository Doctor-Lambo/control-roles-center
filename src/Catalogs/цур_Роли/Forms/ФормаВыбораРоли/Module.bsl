#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	ЗаполнитьРолиКонфигурации();

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыРолиКонфигурации

&НаКлиенте
Процедура РолиКонфигурацииВыборЗначения(Элемент, Значение, СтандартнаяОбработка)

	ТекущиеДанные = Элементы.РолиКонфигурации.ТекущиеДанные;

	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Закрыть(ТекущиеДанные.Значение);

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗаполнитьРолиКонфигурации()

	Если ЗначениеЗаполнено(ИнформационнаяБаза) Тогда
		ЗаполнитьРолиКонфигурацииПоИнформационнойБазе();
	Иначе
		ЗаполнитьВсеРолиКонфигурации();
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьВсеРолиКонфигурации()

	Для Каждого ТекущаяРоль Из Метаданные.Роли Цикл

		Представление = ?(ПустаяСтрока(ТекущаяРоль.Синоним),
			ТекущаяРоль.Имя,
			СтрШаблон("%1 (%2)", ТекущаяРоль.Синоним, ТекущаяРоль.Имя));

		РолиКонфигурации.Добавить(ТекущаяРоль.Имя, Представление);

	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьРолиКонфигурацииПоИнформационнойБазе()

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ИнформационнаяБаза", ИнформационнаяБаза);

	Запрос.Текст =
	"ВЫБРАТЬ
	|	РС.ИмяРоли КАК ИмяРоли
	|ИЗ
	|	РегистрСведений.цур_XMLРолейКонфигурации КАК РС
	|ГДЕ
	|	РС.ИнформационнаяБаза = &ИнформационнаяБаза
	|УПОРЯДОЧИТЬ ПО
	|	РС.ИмяРоли";

	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();

	Пока Выборка.Следующий() Цикл

		ИмяРоли     = Выборка.ИмяРоли;
		РольМД      = Метаданные.Роли.Найти(ИмяРоли);
		Представление = ИмяРоли;

		Если РольМД <> Неопределено И НЕ ПустаяСтрока(РольМД.Синоним) Тогда
			Представление = СтрШаблон("%1 (%2)", РольМД.Синоним, ИмяРоли);
		КонецЕсли;

		РолиКонфигурации.Добавить(ИмяРоли, Представление);

	КонецЦикла;

КонецПроцедуры

#КонецОбласти
