
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	ВидОбъекта = Параметры.ВидОбъекта;
	ИмяОбъекта = Параметры.ИмяОбъекта;

	Если ЗначениеЗаполнено(Параметры.ПредставлениеОбъекта) Тогда
		Заголовок = СтрШаблон(НСтр("ru = 'Ограничения доступа: %1'"), Параметры.ПредставлениеОбъекта);
	КонецЕсли;

	ЗаполнитьПраваДоступаПоВидуОбъекта(ВидОбъекта);
	ЗагрузитьДанныеИзХранилища(Параметры.АдресОграниченийПрав);

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТабличнойЧастиПраваДоступа

&НаКлиенте
Процедура ПраваДоступаПриАктивизацииСтроки(Элемент)

	ОбновитьФильтрОграниченийПоВыбранномуПраву();

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТабличнойЧастиОграниченияПравДоступа

&НаКлиенте
Процедура ОграниченияПравДоступаПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)

	Если НоваяСтрока Тогда

		ТекущиеДанные = Элементы.ОграниченияПравДоступа.ТекущиеДанные;
		ТекущаяСтрокаПрава = Элементы.ПраваДоступа.ТекущиеДанные;

		Если ТекущаяСтрокаПрава <> Неопределено Тогда
			ТекущиеДанные.ИмяПрава = ТекущаяСтрокаПрава.ИмяПрава;
		КонецЕсли;

		ТекущиеДанные.Поля = НСтр("ru = '<Прочие поля>'");

	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОграниченияПравДоступаОграничениеДоступаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)

	СтандартнаяОбработка = Ложь;

	ТекущийТекст = Элемент.ТекстРедактирования;

	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ТекущийТекстОграничения", ТекущийТекст);

	ОписаниеОповещения = Новый ОписаниеОповещения(
		"ОбработатьВыборТекстаОграничения", ЭтотОбъект,
		Элементы.ОграниченияПравДоступа.ТекущиеДанные);

	ОткрытьФорму(
		"Справочник.цур_Роли.Форма.РедакторТекстаОграниченияДоступа",
		ПараметрыФормы,
		ЭтотОбъект,
		,
		,
		,
		ОписаниеОповещения,
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);

КонецПроцедуры

&НаКлиенте
Процедура ОбработатьВыборТекстаОграничения(РезультатЗакрытия, ДополнительныеПараметры) Экспорт

	Если РезультатЗакрытия = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Если ДополнительныеПараметры <> Неопределено Тогда
		ДополнительныеПараметры.ОграничениеДоступа = РезультатЗакрытия;
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ЗавершитьРедактирование(Команда)

	АдресРезультата = СохранитьРезультатВХранилищеНаСервере();
	Закрыть(АдресРезультата);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Заполняет таблицу прав доступа в зависимости от вида объекта метаданных.
//
// Параметры:
//  ВидОбъектаМД - Строка - вид метаданных ("Catalog", "Document" и т.д.)
//
&НаСервере
Процедура ЗаполнитьПраваДоступаПоВидуОбъекта(ВидОбъектаМД)

	ПраваДоступа.Очистить();

	ДоступныеПрава = ОпределитьДоступныеПрава(ВидОбъектаМД);

	ПредставленияПрав = Новый Соответствие;
	ПредставленияПрав.Вставить("Read",   НСтр("ru = 'Чтение'"));
	ПредставленияПрав.Вставить("Insert", НСтр("ru = 'Добавление'"));
	ПредставленияПрав.Вставить("Update", НСтр("ru = 'Изменение'"));
	ПредставленияПрав.Вставить("Delete", НСтр("ru = 'Удаление'"));

	Для Каждого ИмяПрава Из ДоступныеПрава Цикл
		НоваяСтрока = ПраваДоступа.Добавить();
		НоваяСтрока.ИмяПрава      = ИмяПрава;
		НоваяСтрока.Представление = ПредставленияПрав.Получить(ИмяПрава);
	КонецЦикла;

КонецПроцедуры

// Возвращает список прав, доступных для RLS по виду объекта.
//
// Параметры:
//  ВидОбъектаМД - Строка - вид метаданных
//
// Возвращает:
//  Массив из Строка - имена прав
//
&НаСервере
Функция ОпределитьДоступныеПрава(ВидОбъектаМД)

	// Объекты с полным набором прав RLS
	ОбъектыПолныеПрава = "Catalog,Document,ExchangePlan,ChartOfCharacteristicTypes,ChartOfAccounts,BusinessProcess,Task";

	// Регистры - только Read и Update
	ОбъектыРегистры = "InformationRegister,AccumulationRegister,AccountingRegister,CalculationRegister";

	// Журналы документов - только Read
	ОбъектыТолькоЧтение = "DocumentJournal";

	СтрокаПрав = "Read,Insert,Update,Delete"; // По умолчанию - полный набор

	Если СтрНайти(ОбъектыРегистры, ВидОбъектаМД) > 0 Тогда
		СтрокаПрав = "Read,Update";
	ИначеЕсли СтрНайти(ОбъектыТолькоЧтение, ВидОбъектаМД) > 0 Тогда
		СтрокаПрав = "Read";
	КонецЕсли;

	Возврат СтрРазделить(СтрокаПрав, ",");

КонецФункции

// Загружает текущие ограничения и шаблоны из временного хранилища.
//
// Параметры:
//  Адрес - Строка - адрес во временном хранилище
//
&НаСервере
Процедура ЗагрузитьДанныеИзХранилища(Адрес)

	Если НЕ ЗначениеЗаполнено(Адрес) Тогда
		Возврат;
	КонецЕсли;

	ДанныеХранилища = ПолучитьИзВременногоХранилища(Адрес);

	Если ДанныеХранилища = Неопределено Тогда
		Возврат;
	КонецЕсли;

	// Загружаем ограничения только для текущего объекта
	Если ДанныеХранилища.Свойство("ТекущиеОграничения")
		И ДанныеХранилища.ТекущиеОграничения <> Неопределено Тогда

		Для Каждого Строка Из ДанныеХранилища.ТекущиеОграничения Цикл
			НоваяСтрока = ОграниченияПравДоступа.Добавить();
			НоваяСтрока.ИмяПрава           = Строка.ИмяПрава;
			НоваяСтрока.ОграничениеДоступа = Строка.УсловиеОграничения;
		КонецЦикла;

	КонецЕсли;

	// Загружаем шаблоны
	Если ДанныеХранилища.Свойство("Шаблоны") И ДанныеХранилища.Шаблоны <> Неопределено Тогда

		Для Каждого Строка Из ДанныеХранилища.Шаблоны Цикл
			НоваяСтрока = ШаблоныОграничений.Добавить();
			НоваяСтрока.ИмяШаблона   = Строка.ИмяШаблона;
			НоваяСтрока.ТекстШаблона = Строка.ТекстШаблона;
		КонецЦикла;

	КонецЕсли;

КонецПроцедуры

// Обновляет фильтр таблицы ограничений по текущему выбранному праву.
//
&НаКлиенте
Процедура ОбновитьФильтрОграниченийПоВыбранномуПраву()

	ТекущаяСтрокаПрава = Элементы.ПраваДоступа.ТекущиеДанные;

	Если ТекущаяСтрокаПрава = Неопределено Тогда
		Элементы.ОграниченияПравДоступа.ОтборСтрок = Неопределено;
		Возврат;
	КонецЕсли;

	Элементы.ОграниченияПравДоступа.ОтборСтрок =
		Новый ФиксированнаяСтруктура("ИмяПрава", ТекущаяСтрокаПрава.ИмяПрава);

КонецПроцедуры

// Сохраняет результат редактирования во временное хранилище.
//
// Возвращает:
//  Строка - адрес во временном хранилище с результатом
//
&НаСервере
Функция СохранитьРезультатВХранилищеНаСервере()

	Результат = Новый Структура;
	Результат.Вставить("ОграниченияПравДоступа", ОграниченияПравДоступа.Выгрузить());
	Результат.Вставить("ШаблоныОграничений",     ШаблоныОграничений.Выгрузить());

	Возврат ПоместитьВоВременноеХранилище(Результат, УникальныйИдентификатор);

КонецФункции

#КонецОбласти
