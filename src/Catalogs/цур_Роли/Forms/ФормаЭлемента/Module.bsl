Процедура ДляКаждогоУзлаДерева(Дерево, Развернуть)

	Для Каждого СтрокаДерева Из Дерево.ПолучитьЭлементы() Цикл

		Если Развернуть Тогда
			Элементы.ОбъектыКонфигурации.Развернуть(СтрокаДерева.ПолучитьИдентификатор(), Истина);
		Иначе
			Элементы.ОбъектыКонфигурации.Свернуть(СтрокаДерева.ПолучитьИдентификатор());
		КонецЕсли;

	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Функция РазбитьCamelCase(Знач Строка)

	Если ПустаяСтрока(Строка) Тогда
		Возврат Строка;
	КонецЕсли;

	Результат = "";

	Пока НЕ ПустаяСтрока(Строка) Цикл

		Буква = Лев(Строка, 1);

		Если ПустаяСтрока(Результат) Тогда
			Результат = Буква;

		ИначеЕсли Буква <> НРег(Буква) Тогда
			Результат = Результат + " " + НРег(Буква);

		Иначе
			Результат = Результат + Буква;

		КонецЕсли;

		Строка = Сред(Строка, 2);

	КонецЦикла;

	Возврат Результат;

КонецФункции

