КонецПроцедуры

&НаКлиенте
Процедура ИзменитьОграниченияДоступаОбъекта(Команда)

	ТекущиеДанные = Элементы.ОбъектыКонфигурации.ТекущиеДанные;

	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;

	// Поднимаемся до корневого объекта (мимо групп реквизитов)
	Данные = ТекущиеДанные;
	Пока Данные.ПолучитьРодителя() <> Неопределено
		И ПустаяСтрока(Данные.ИмяОбъекта) Цикл
		Данные = Данные.ПолучитьРодителя();
	КонецЦикла;

	Если ПустаяСтрока(Данные.ВидОбъекта) Или ПустаяСтрока(Данные.ИмяОбъекта) Тогда
		Возврат;
	КонецЕсли;

	АдресОграничений = ПодготовитьДанныеДляФормыОграниченийНаСервере(
		Данные.ВидОбъекта, Данные.ИмяОбъекта);

	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ВидОбъекта",  Данные.ВидОбъекта);
	ДополнительныеПараметры.Вставить("ИмяОбъекта",  Данные.ИмяОбъекта);
	ДополнительныеПараметры.Вставить("СтрокаДерева", Данные);

	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ВидОбъекта",           Данные.ВидОбъекта);
	ПараметрыФормы.Вставить("ИмяОбъекта",           Данные.ИмяОбъекта);
	ПараметрыФормы.Вставить("ПредставлениеОбъекта", Данные.Синоним);
	ПараметрыФормы.Вставить("АдресОграниченийПрав",  АдресОграничений);

	ОписаниеОповещения = Новый ОписаниеОповещения(
		"ОбработатьВозвратФормыОграничений", ЭтотОбъект, ДополнительныеПараметры);

	ОткрытьФорму(
		"Справочник.цур_Роли.Форма.ФормаРедактированияОграниченияДоступаОбъекта",
		ПараметрыФормы,
		ЭтотОбъект,
		,
		,
		,
		ОписаниеОповещения,
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);

КонецПроцедуры

// Обрабатывает возврат из формы редактирования ограничений доступа.
//
// Параметры:
//  РезультатЗакрытия      - Строка - адрес во временном хранилище с результатом, либо Неопределено
//  ДополнительныеПараметры - Структура - содержит ВидОбъекта, ИмяОбъекта, СтрокаДерева
//
&НаКлиенте
Процедура ОбработатьВозвратФормыОграничений(РезультатЗакрытия, ДополнительныеПараметры) Экспорт

	Если РезультатЗакрытия = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ПрименитьРезультатОграниченийНаСервере(
		РезультатЗакрытия,
		ДополнительныеПараметры.ВидОбъекта,
		ДополнительныеПараметры.ИмяОбъекта);

	// Обновить иконку ограничений в строке дерева
	СтрокаДерева = ДополнительныеПараметры.СтрокаДерева;
	Если СтрокаДерева <> Неопределено Тогда
		ОбновитьИконкуОграниченийСтроки(СтрокаДерева, ДополнительныеПараметры.ВидОбъекта, ДополнительныеПараметры.ИмяОбъекта);
	КонецЕсли;

КонецПроцедуры

// Обновляет иконку ограничений доступа для строки дерева.
//
// Параметры:
//  СтрокаДерева - ДанныеФормыЭлементДерева
//  ВидОбъекта   - Строка
//  ИмяОбъекта   - Строка
//
&НаКлиенте
Процедура ОбновитьИконкуОграниченийСтроки(СтрокаДерева, ВидОбъекта, ИмяОбъекта)

	ЕстьОграничения = ОбъектИмеетОграниченияВХранилище(ВидОбъекта, ИмяОбъекта);

	Если ЕстьОграничения Тогда
		СтрокаДерева.ОграничениеДоступаКДанным = БиблиотекаКартинок.гпр_RLS;
	Иначе
		СтрокаДерева.ОграничениеДоступаКДанным = Новый Картинка;
	КонецЕсли;

КонецПроцедуры

// Проверяет наличие ограничений для объекта в хранилище формы.
//
// Параметры:
//  ВидОбъекта - Строка
//  ИмяОбъекта - Строка
//
// Возвращает:
//  Булево
//
&НаСервере
Функция ОбъектИмеетОграниченияВХранилище(Знач ВидОбъекта, Знач ИмяОбъекта)

	Результат = ХранилищеОграничений.НайтиСтроки(
		Новый Структура("ВидОбъекта, ИмяОбъекта", ВидОбъекта, ИмяОбъекта));

	Возврат Результат.Количество() > 0;

КонецФункции

// Подготавливает данные текущих ограничений объекта и всех шаблонов для передачи в форму.
//
// Параметры:
//  ВидОбъекта - Строка - вид метаданных
//  ИмяОбъекта - Строка - имя объекта метаданных
//
// Возвращает:
//  Строка - адрес во временном хранилище со структурой {ТекущиеОграничения, Шаблоны}
//
&НаСервере
Функция ПодготовитьДанныеДляФормыОграниченийНаСервере(Знач ВидОбъекта, Знач ИмяОбъекта)

	ТаблицаВсехОграничений = РеквизитФормыВЗначение("ХранилищеОграничений");
	ТаблицаШаблонов       = РеквизитФормыВЗначение("ХранилищеШаблонов");

	ТаблицаОграничений = ТаблицаВсехОграничений.Скопировать(
		Новый Структура("ВидОбъекта, ИмяОбъекта", ВидОбъекта, ИмяОбъекта));

	ДанныеФормы = Новый Структура;
	ДанныеФормы.Вставить("ТекущиеОграничения", ТаблицаОграничений);
	ДанныеФормы.Вставить("Шаблоны",           ТаблицаШаблонов);

	Возврат ПоместитьВоВременноеХранилище(ДанныеФормы, УникальныйИдентификатор);

КонецФункции

// Применяет результат редактирования ограничений к хранилищам формы.
//
// Параметры:
//  АдресРезультата - Строка - адрес во временном хранилище с результатом редактирования
//  ВидОбъекта      - Строка
//  ИмяОбъекта      - Строка
//
&НаСервере
Процедура ПрименитьРезультатОграниченийНаСервере(Знач АдресРезультата, Знач ВидОбъекта, Знач ИмяОбъекта)

	РезультатРедактирования = ПолучитьИзВременногоХранилища(АдресРезультата);

	Если РезультатРедактирования = Неопределено Тогда
		Возврат;
	КонецЕсли;

	// Удаляем старые ограничения для этого объекта
	СтарыеСтроки = ХранилищеОграничений.НайтиСтроки(
		Новый Структура("ВидОбъекта, ИмяОбъекта", ВидОбъекта, ИмяОбъекта));

	Для Каждого СтараяСтрока Из СтарыеСтроки Цикл
		ХранилищеОграничений.Удалить(СтараяСтрока);
	КонецЦикла;

	// Добавляем новые ограничения
	Если РезультатРедактирования.Свойство("ОграниченияПравДоступа") Тогда
		Для Каждого Строка Из РезультатРедактирования.ОграниченияПравДоступа Цикл

			Если ПустаяСтрока(СокрЛП(Строка.ОграничениеДоступа)) Тогда
				Продолжить;
			КонецЕсли;

			НоваяСтрока = ХранилищеОграничений.Добавить();
			НоваяСтрока.ВидОбъекта         = ВидОбъекта;
			НоваяСтрока.ИмяОбъекта         = ИмяОбъекта;
			НоваяСтрока.ИмяПрава           = Строка.ИмяПрава;
			НоваяСтрока.УсловиеОграничения = Строка.ОграничениеДоступа;

		КонецЦикла;
	КонецЕсли;

	// Обновляем шаблоны (общие для всей роли)
	Если РезультатРедактирования.Свойство("ШаблоныОграничений") Тогда
		ХранилищеШаблонов.Очистить();
		Для Каждого Строка Из РезультатРедактирования.ШаблоныОграничений Цикл
			НоваяСтрока = ХранилищеШаблонов.Добавить();
			НоваяСтрока.ИмяШаблона   = Строка.ИмяШаблона;
			НоваяСтрока.ТекстШаблона = Строка.ТекстШаблона;
		КонецЦикла;
	КонецЕсли;

КонецПроцедуры

// TODO NEWGPR-backlog: реализовать получение связанных объектов метаданных
//   (табличные части, подчинённые справочники) через API платформы
&НаКлиенте
Асинх Процедура ДобавитьСвязанныеОбъекты(Команда)

	ТекущиеДанные = Элементы.ОбъектыКонфигурации.ТекущиеДанные;

	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Если ПустаяСтрока(ТекущиеДанные.ВидОбъекта) Или ПустаяСтрока(ТекущиеДанные.ИмяОбъекта) Тогда
		Возврат;
	КонецЕсли;

	Ждать ПредупреждениеАсинх(НСтр("ru = 'Функция в разработке.'"));

КонецПроцедуры

&НаКлиенте
Процедура РазвернутьВсе(Команда)

	ДляКаждогоУзлаДерева(ОбъектыКонфигурации, Истина);

КонецПроцедуры

&НаКлиенте
Процедура СвернутьВсе(Команда)

	ДляКаждогоУзлаДерева(ОбъектыКонфигурации, Ложь);

КонецПроцедуры

&НаКлиенте
Асинх Процедура Валидация(Команда)

	Если Объект.Ссылка.Пустая() Тогда

		Ждать ПредупреждениеАсинх(НСтр("ru = 'Сначала запишите роль.'"));
		Возврат;

	КонецЕсли;

	Результат = цур_ВызовСервера.ВалидироватьРоль(Объект.Ссылка);

	Если Результат.Успешно Тогда

		Ждать ПредупреждениеАсинх(НСтр("ru = 'Валидация пройдена успешно.'"));

	Иначе

		ТекстОшибок = СтрСоединить(Результат.Ошибки, Символы.ПС);
		Ждать ПредупреждениеАсинх(ТекстОшибок);

	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область Инициализация

&НаСервере
Процедура ИнициализироватьВидыМетаданных()

	КэшВидов = Новый Соответствие;
	МассивВидов = цур_РеестрМетаданныхСерверПовтИсп.ВсеВидыМетаданных();

	Для Каждого ОписаниеВида Из МассивВидов Цикл

		НоваяСтрока = ВидыОбъектовВДереве.Добавить();
		НоваяСтрока.ВидОбъекта       = ОписаниеВида.ВидМетаданных;
		НоваяСтрока.Представление     = ОписаниеВида.СинонимМн;
		НоваяСтрока.ИмяКоллекции      = ОписаниеВида.ИмяКоллекцииМетаданных;
		НоваяСтрока.Порядок           = ОписаниеВида.Порядок;
		НоваяСтрока.ИндексВДереве     = -1;

		КэшВидов.Вставить(ОписаниеВида.ВидМетаданных, ОписаниеВида);

	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДеревоВидов()

	// Не очищать если дерево уже заполнено при чтении (ПриЧтенииНаСервере)
	Если ОбъектыКонфигурации.ПолучитьЭлементы().Количество() > 0 Тогда
		Возврат;
	КонецЕсли;

	ОбъектыКонфигурации.ПолучитьЭлементы().Очистить();

КонецПроцедуры

#КонецОбласти

#Область Подсистемы

&НаСервере
Процедура ЗаполнитьДеревоПодсистем()

	ДеревоПодсистем.ПолучитьЭлементы().Очистить();
	ДеревоПодсистемСервер = цур_ВызовСервера.ПолучитьПодсистемыКонфигурации();

	ДобавитьПодсистемыВДерево(ДеревоПодсистемСервер.Строки, ДеревоПодсистем.ПолучитьЭлементы());

КонецПроцедуры

&НаСервере
Процедура ДобавитьПодсистемыВДерево(СтрокиИсточника, ЭлементыПриемника)

	Для Каждого СтрокаИсточника Из СтрокиИсточника Цикл

		НоваяСтрока = ЭлементыПриемника.Добавить();
		НоваяСтрока.Имя                = СтрокаИсточника.Имя;
		НоваяСтрока.ПолноеИмя          = СтрокаИсточника.ПолноеИмя;
		НоваяСтрока.Представление      = СтрокаИсточника.Представление;
		НоваяСтрока.КартинкаПодсистемы = СтрокаИсточника.КартинкаПодсистемы;
		НоваяСтрока.Использование      = Ложь;

		Если СтрокаИсточника.Строки.Количество() > 0 Тогда
			ДобавитьПодсистемыВДерево(СтрокаИсточника.Строки, НоваяСтрока.ПолучитьЭлементы());
		КонецЕсли;

	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура ЗагрузитьПодсистемыИзРегистра()

	Если Объект.Ссылка.Пустая() Тогда
		Возврат;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	РС.ПолноеИмяПодсистемы КАК ПолноеИмяПодсистемы
	|ИЗ
	|	РегистрСведений.цур_ПодсистемыРолей КАК РС
	|ГДЕ
	|	РС.Роль = &Роль";
	Запрос.УстановитьПараметр("Роль", Объект.Ссылка);

	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();

	ИменаПодсистем = Новый Соответствие;

	Пока Выборка.Следующий() Цикл
		ИменаПодсистем.Вставить(Выборка.ПолноеИмяПодсистемы, Истина);
	КонецЦикла;

	УстановитьОтметкиПодсистем(ДеревоПодсистем.ПолучитьЭлементы(), ИменаПодсистем);

КонецПроцедуры

&НаСервере
Процедура УстановитьОтметкиПодсистем(ЭлементыДерева, ИменаПодсистем)

	Для Каждого СтрокаДерева Из ЭлементыДерева Цикл

		СтрокаДерева.Использование = ИменаПодсистем.Получить(СтрокаДерева.ПолноеИмя) <> Неопределено;
		УстановитьОтметкиПодсистем(СтрокаДерева.ПолучитьЭлементы(), ИменаПодсистем);

	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура УпаковатьПодсистемыВРегистр(СсылкаРоли)

	Если НЕ ЗначениеЗаполнено(СсылкаРоли) Тогда
		Возврат;
	КонецЕсли;

	НаборЗаписей = РегистрыСведений.цур_ПодсистемыРолей.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Роль.Установить(СсылкаРоли);

	СобратьОтмеченныеПодсистемы(ДеревоПодсистем.ПолучитьЭлементы(), НаборЗаписей, СсылкаРоли);

	НаборЗаписей.Записать();

КонецПроцедуры

&НаСервере
Процедура СобратьОтмеченныеПодсистемы(ЭлементыДерева, НаборЗаписей, СсылкаРоли)

	Для Каждого СтрокаДерева Из ЭлементыДерева Цикл

		Если СтрокаДерева.Использование Тогда

			НоваяЗапись = НаборЗаписей.Добавить();
			НоваяЗапись.Роль                = СсылкаРоли;
			НоваяЗапись.ПолноеИмяПодсистемы = СтрокаДерева.ПолноеИмя;

		КонецЕсли;

		СобратьОтмеченныеПодсистемы(СтрокаДерева.ПолучитьЭлементы(), НаборЗаписей, СсылкаРоли);

	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура УстановитьИспользованиеПодчиненным(Родитель, Значение)

	Для Каждого Дочерняя Из Родитель.ПолучитьЭлементы() Цикл

		Дочерняя.Использование = Значение;
		УстановитьИспользованиеПодчиненным(Дочерняя, Значение);

	КонецЦикла;

КонецПроцедуры

#КонецОбласти

#Область ДобавлениеУдалениеОбъектовВДереве

&НаСервере
Функция ДобавитьОбъектВДеревоНаСервере(ВидОбъекта, ИмяОбъекта)

	Результат = Новый Структура("Успешно, ОписаниеОшибки", Ложь, "");

	ОписаниеВида = цур_РеестрМетаданныхСерверПовтИсп.ОписаниеВида(ВидОбъекта);

	Если ОписаниеВида = Неопределено Тогда

		Результат.ОписаниеОшибки = СтрШаблон(
			НСтр("ru = 'Вид метаданных ""%1"" не найден в реестре.'"), ВидОбъекта);
		Возврат Результат;

	КонецЕсли;

	ОбъектМетаданных = НайтиОбъектМетаданных(ОписаниеВида.ИмяКоллекцииМетаданных, ИмяОбъекта);

	Если ОбъектМетаданных = Неопределено Тогда

		Результат.ОписаниеОшибки = СтрШаблон(
			НСтр("ru = 'Объект ""%1.%2"" не найден в метаданных конфигурации.'"), ВидОбъекта, ИмяОбъекта);
		Возврат Результат;

	КонецЕсли;

	Если ОбъектУжеДобавлен(ВидОбъекта, ИмяОбъекта) Тогда

		Результат.ОписаниеОшибки = СтрШаблон(
			НСтр("ru = 'Объект ""%1.%2"" уже добавлен в дерево.'"), ВидОбъекта, ИмяОбъекта);
		Возврат Результат;

	КонецЕсли;

	ДобавитьОбъектСПодчиненными(ВидОбъекта, ИмяОбъекта, ОбъектМетаданных, ОписаниеВида);
	СортироватьОбъектыВДереве();

	Результат.Успешно = Истина;
	Возврат Результат;

КонецФункции

&НаСервере
Функция НайтиОбъектМетаданных(ИмяКоллекции, ИмяОбъекта)

	Попытка
		КоллекцияМД = Метаданные[ИмяКоллекции];
	Исключение
		Возврат Неопределено;
	КонецПопытки;

	Если КоллекцияМД = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	Возврат КоллекцияМД.Найти(ИмяОбъекта);

КонецФункции

&НаСервере
Функция ОбъектУжеДобавлен(ВидОбъекта, ИмяОбъекта)

	Возврат ОбъектыВДереве.НайтиСтроки(
		Новый Структура("ВидОбъекта, ИмяОбъекта", ВидОбъекта, ИмяОбъекта)).Количество() > 0;

КонецФункции

&НаСервере
Процедура ДобавитьОбъектСПодчиненными(ВидОбъекта, ИмяОбъекта, ОбъектМетаданных, ОписаниеВида)

	ГруппаВида = ПолучитьИлиСоздатьГруппуВида(ВидОбъекта, ОписаниеВида);

	СтрокаОбъекта = ГруппаВида.ПолучитьЭлементы().Добавить();
	СтрокаОбъекта.Представление  = ИмяОбъекта;
	СтрокаОбъекта.Синоним        = ?(ПустаяСтрока(ОбъектМетаданных.Синоним), ИмяОбъекта, ОбъектМетаданных.Синоним);
	СтрокаОбъекта.ВидОбъекта     = ВидОбъекта;
	СтрокаОбъекта.ИмяОбъекта     = ИмяОбъекта;
	СтрокаОбъекта.ЭтоГруппа      = Ложь;
	СтрокаОбъекта.ТипРеквизита   = "";
	СтрокаОбъекта.ИмяРеквизита   = "";
	СтрокаОбъекта.ИмяРеквизитаТЧ = "";
	СтрокаОбъекта.КартинкаОбъекта = КартинкаВидаМетаданных(ВидОбъекта);

	НоваяСтрокаИндекса = ОбъектыВДереве.Добавить();
	НоваяСтрокаИндекса.ВидОбъекта = ВидОбъекта;
	НоваяСтрокаИндекса.ИмяОбъекта = ИмяОбъекта;

	ДобавитьПодчиненныеЭлементы(СтрокаОбъекта, ОбъектМетаданных, ОписаниеВида);

КонецПроцедуры

&НаСервере
Процедура ДобавитьПодчиненныеЭлементы(СтрокаОбъекта, ОбъектМетаданных, ОписаниеВида)

	ГруппыВложенных = ОписаниеВида.ГруппыВложенных;

	Если ГруппыВложенных.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;

	СоответствиеГрупп = СоответствиеГруппВложенных();

	Для Каждого ИмяГруппы Из ГруппыВложенных Цикл

		ОписаниеГруппы = СоответствиеГрупп.Получить(ИмяГруппы);

		Если ОписаниеГруппы = Неопределено Тогда
			Продолжить;
		КонецЕсли;

		КоллекцияРеквизитов = Неопределено;

		Попытка
			КоллекцияРеквизитов = ОбъектМетаданных[ОписаниеГруппы.ИмяСвойстваМД];
		Исключение
			Продолжить;
		КонецПопытки;

		Если КоллекцияРеквизитов = Неопределено Тогда
			Продолжить;
		КонецЕсли;

		КоличествоРеквизитов = 0;

		Попытка
			КоличествоРеквизитов = КоллекцияРеквизитов.Количество();
		Исключение
			Продолжить;
		КонецПопытки;

		Если КоличествоРеквизитов = 0 Тогда
			Продолжить;
		КонецЕсли;

		ГруппаРеквизитов = СтрокаОбъекта.ПолучитьЭлементы().Добавить();
		ГруппаРеквизитов.Представление  = ОписаниеГруппы.Представление;
		ГруппаРеквизитов.Синоним        = ОписаниеГруппы.Представление;
		ГруппаРеквизитов.ВидОбъекта     = СтрокаОбъекта.ВидОбъекта;
		ГруппаРеквизитов.ИмяОбъекта     = СтрокаОбъекта.ИмяОбъекта;
		ГруппаРеквизитов.ЭтоГруппа      = Ложь;
		ГруппаРеквизитов.ТипРеквизита   = ИмяГруппы;
		ГруппаРеквизитов.ИмяРеквизита   = "";
		ГруппаРеквизитов.ИмяРеквизитаТЧ = "";
		ГруппаРеквизитов.КартинкаОбъекта = ОписаниеГруппы.Картинка;

		Для Каждого ЭлементМД Из КоллекцияРеквизитов Цикл

			СтрокаЭлемента = ГруппаРеквизитов.ПолучитьЭлементы().Добавить();
			СтрокаЭлемента.Представление = ЭлементМД.Имя;
			СтрокаЭлемента.Синоним       = ?(ПустаяСтрока(ЭлементМД.Синоним), ЭлементМД.Имя, ЭлементМД.Синоним);
			СтрокаЭлемента.ВидОбъекта    = СтрокаОбъекта.ВидОбъекта;
			СтрокаЭлемента.ИмяОбъекта    = СтрокаОбъекта.ИмяОбъекта;
			СтрокаЭлемента.ЭтоГруппа     = Ложь;
			СтрокаЭлемента.ТипРеквизита  = ИмяГруппы;
			СтрокаЭлемента.ИмяРеквизита  = ЭлементМД.Имя;
			СтрокаЭлемента.ИмяРеквизитаТЧ = "";

			Если ОписаниеГруппы.ЕстьПодчиненные Тогда
				ДобавитьРеквизитыТабличнойЧасти(СтрокаЭлемента, ОбъектМетаданных, ЭлементМД.Имя);
			КонецЕсли;

			Если Объект.УстанавливатьДляРеквизитовПоУмолчанию Тогда
				УстановитьПраваПоУмолчаниюДляРеквизита(СтрокаЭлемента, ИмяГруппы);
			КонецЕсли;

		КонецЦикла;

	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура ДобавитьРеквизитыТабличнойЧасти(СтрокаТЧ, ОбъектМетаданных, ИмяТЧ)

	ТабличнаяЧастьМД = Неопределено;

	Попытка
		ТабличнаяЧастьМД = ОбъектМетаданных.ТабличныеЧасти.Найти(ИмяТЧ);
	Исключение
		Возврат;
	КонецПопытки;

	Если ТабличнаяЧастьМД = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Для Каждого РеквизитТЧ Из ТабличнаяЧастьМД.Реквизиты Цикл

		НоваяСтрока = СтрокаТЧ.ПолучитьЭлементы().Добавить();
		НоваяСтрока.Представление = РеквизитТЧ.Имя;
		НоваяСтрока.Синоним       = ?(ПустаяСтрока(РеквизитТЧ.Синоним), РеквизитТЧ.Имя, РеквизитТЧ.Синоним);
		НоваяСтрока.ВидОбъекта    = СтрокаТЧ.ВидОбъекта;
		НоваяСтрока.ИмяОбъекта    = СтрокаТЧ.ИмяОбъекта;
		НоваяСтрока.ЭтоГруппа     = Ложь;
		НоваяСтрока.ТипРеквизита  = "Attribute";
		НоваяСтрока.ИмяРеквизита  = ИмяТЧ;
		НоваяСтрока.ИмяРеквизитаТЧ = РеквизитТЧ.Имя;

		Если Объект.УстанавливатьДляРеквизитовПоУмолчанию Тогда
			УстановитьПраваПоУмолчаниюДляРеквизита(НоваяСтрока, "Attribute");
		КонецЕсли;

	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура УстановитьПраваПоУмолчаниюДляРеквизита(СтрокаДерева, ТипРеквизита)

	ПраваРеквизитов = ПраваДоступаДляРеквизитов();
	ДоступныеПрава = ПраваРеквизитов.Получить(ТипРеквизита);

	Если ДоступныеПрава = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Для Каждого ИмяПрава Из ДоступныеПрава Цикл

		Попытка
			СтрокаДерева[ИмяПрава] = Истина;
		Исключение
			Продолжить;
		КонецПопытки;

	КонецЦикла;

КонецПроцедуры

&НаСервереБезКонтекста
Функция ПраваДоступаДляРеквизитов()

	Результат = Новый Соответствие;

	ПраваРеквизита = Новый Массив;
	ПраваРеквизита.Добавить("Просмотр");
	ПраваРеквизита.Добавить("Редактирование");
	Результат.Вставить("Attribute", ПраваРеквизита);
	Результат.Вставить("StandardAttribute", ПраваРеквизита);

	ПраваТЧ = Новый Массив;
	ПраваТЧ.Добавить("Просмотр");
	ПраваТЧ.Добавить("Редактирование");
	Результат.Вставить("TabularSection", ПраваТЧ);

	ПраваКоманды = Новый Массив;
	ПраваКоманды.Добавить("Просмотр");
	Результат.Вставить("Command", ПраваКоманды);

	ПраваИзмерения = Новый Массив;
	ПраваИзмерения.Добавить("Просмотр");
	ПраваИзмерения.Добавить("Редактирование");
	Результат.Вставить("Dimension", ПраваИзмерения);

	ПраваРесурса = Новый Массив;
	ПраваРесурса.Добавить("Просмотр");
	ПраваРесурса.Добавить("Редактирование");
	Результат.Вставить("Resource", ПраваРесурса);

	Возврат Результат;

КонецФункции

&НаСервереБезКонтекста
Функция СоответствиеГруппВложенных()

	Результат = Новый Соответствие;

	Результат.Вставить("Attribute", Новый Структура(
		"ИмяСвойстваМД, Представление, ЕстьПодчиненные, Картинка",
		"Реквизиты", НСтр("ru = 'Реквизиты'"), Ложь, ПолучитьКартинкуБезопасно("Реквизит")));

	Результат.Вставить("StandardAttribute", Новый Структура(
		"ИмяСвойстваМД, Представление, ЕстьПодчиненные, Картинка",
		"СтандартныеРеквизиты", НСтр("ru = 'Стандартные реквизиты'"), Ложь, ПолучитьКартинкуБезопасно("цур_СтандартныйРеквизит")));

	Результат.Вставить("TabularSection", Новый Структура(
		"ИмяСвойстваМД, Представление, ЕстьПодчиненные, Картинка",
		"ТабличныеЧасти", НСтр("ru = 'Табличные части'"), Истина, ПолучитьКартинкуБезопасно("ТабличнаяЧасть")));

	Результат.Вставить("Command", Новый Структура(
		"ИмяСвойстваМД, Представление, ЕстьПодчиненные, Картинка",
		"Команды", НСтр("ru = 'Команды'"), Ложь, ПолучитьКартинкуБезопасно("Команда")));

	Результат.Вставить("Dimension", Новый Структура(
		"ИмяСвойстваМД, Представление, ЕстьПодчиненные, Картинка",
		"Измерения", НСтр("ru = 'Измерения'"), Ложь, ПолучитьКартинкуБезопасно("Измерение")));

	Результат.Вставить("Resource", Новый Структура(
		"ИмяСвойстваМД, Представление, ЕстьПодчиненные, Картинка",
		"Ресурсы", НСтр("ru = 'Ресурсы'"), Ложь, ПолучитьКартинкуБезопасно("Ресурс")));

	Возврат Результат;

КонецФункции

&НаСервере
Функция ПолучитьИлиСоздатьГруппуВида(ВидОбъекта, ОписаниеВида)

	НайденныеСтроки = ВидыОбъектовВДереве.НайтиСтроки(Новый Структура("ВидОбъекта", ВидОбъекта));

	Если НайденныеСтроки.Количество() = 0 Тогда
		ВызватьИсключение СтрШаблон(
			НСтр("ru = 'Вид метаданных ""%1"" не найден в реестре видов.'"), ВидОбъекта);
	КонецЕсли;

	СтрокаВида = НайденныеСтроки[0];

	Если СтрокаВида.ИндексВДереве >= 0 Тогда
		Возврат ОбъектыКонфигурации.ПолучитьЭлементы().Получить(СтрокаВида.ИндексВДереве);
	КонецЕсли;

	ТекущийИндекс = ВычислитьИндексВставки(СтрокаВида);
	СтрокаВида.ИндексВДереве = ТекущийИндекс;

	СдвинутьИндексыПосле(СтрокаВида, ТекущийИндекс);

	НоваяГруппа = ОбъектыКонфигурации.ПолучитьЭлементы().Вставить(ТекущийИндекс);
	НоваяГруппа.Представление   = ОписаниеВида.СинонимМн;
	НоваяГруппа.Синоним         = ОписаниеВида.СинонимМн;
	НоваяГруппа.ВидОбъекта      = ВидОбъекта;
	НоваяГруппа.ЭтоГруппа       = Истина;
	НоваяГруппа.КартинкаОбъекта = КартинкаВидаМетаданных(ВидОбъекта);

	Возврат НоваяГруппа;

КонецФункции

&НаСервере
Функция ВычислитьИндексВставки(СтрокаВида)

	ИндексСтроки = ВидыОбъектовВДереве.Индекс(СтрокаВида);
	ТекущийИндекс = 0;

	Если ИндексСтроки > 0 Тогда

		Счетчик = ИндексСтроки - 1;

		Пока Счетчик >= 0 Цикл

			Если ВидыОбъектовВДереве.Получить(Счетчик).ИндексВДереве >= 0 Тогда
				ТекущийИндекс = ВидыОбъектовВДереве.Получить(Счетчик).ИндексВДереве + 1;
				Прервать;
			КонецЕсли;

			Счетчик = Счетчик - 1;

		КонецЦикла;

	КонецЕсли;

	Возврат ТекущийИндекс;

КонецФункции

&НаСервере
Процедура СдвинутьИндексыПосле(СтрокаВида, ТекущийИндекс)

	ИндексСтроки = ВидыОбъектовВДереве.Индекс(СтрокаВида);

	Для Счетчик = ИндексСтроки + 1 По ВидыОбъектовВДереве.Количество() - 1 Цикл

		ТекущаяСтрока = ВидыОбъектовВДереве.Получить(Счетчик);

		Если ТекущаяСтрока.ИндексВДереве >= ТекущийИндекс Тогда
			ТекущаяСтрока.ИндексВДереве = ТекущаяСтрока.ИндексВДереве + 1;
		КонецЕсли;

	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура СортироватьОбъектыВДереве()

	Дерево = РеквизитФормыВЗначение("ОбъектыКонфигурации", Тип("ДеревоЗначений"));

	Для Каждого СтрокаВида Из Дерево.Строки Цикл
		СтрокаВида.Строки.Сортировать("ИмяОбъекта");
	КонецЦикла;

	ЗначениеВРеквизитФормы(Дерево, "ОбъектыКонфигурации");

КонецПроцедуры

&НаСервере
Процедура УдалитьОбъектИзДереваНаСервере(ВидОбъекта, ИмяОбъекта)

	НайденныеСтроки = ОбъектыВДереве.НайтиСтроки(
		Новый Структура("ВидОбъекта, ИмяОбъекта", ВидОбъекта, ИмяОбъекта));

	Для Каждого Найденная Из НайденныеСтроки Цикл
		ОбъектыВДереве.Удалить(Найденная);
	КонецЦикла;

	Для Каждого ГруппаВида Из ОбъектыКонфигурации.ПолучитьЭлементы() Цикл

		Если ГруппаВида.ВидОбъекта <> ВидОбъекта Тогда
			Продолжить;
		КонецЕсли;

		СтрокаКУдалению = Неопределено;

		Для Каждого СтрокаОбъекта Из ГруппаВида.ПолучитьЭлементы() Цикл

			Если СтрокаОбъекта.ИмяОбъекта = ИмяОбъекта И ПустаяСтрока(СтрокаОбъекта.ТипРеквизита) Тогда
				СтрокаКУдалению = СтрокаОбъекта;
				Прервать;
			КонецЕсли;

		КонецЦикла;

		Если СтрокаКУдалению <> Неопределено Тогда
			ГруппаВида.ПолучитьЭлементы().Удалить(СтрокаКУдалению);
		КонецЕсли;

		Если ГруппаВида.ПолучитьЭлементы().Количество() = 0 Тогда
			УдалитьПустуюГруппуВида(ВидОбъекта, ГруппаВида);
		КонецЕсли;

		Прервать;

	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура УдалитьПустуюГруппуВида(ВидОбъекта, ГруппаВида)

	ИндексУдаляемой = -1;
	НайденныеВиды = ВидыОбъектовВДереве.НайтиСтроки(Новый Структура("ВидОбъекта", ВидОбъекта));

	Если НайденныеВиды.Количество() > 0 Тогда
		ИндексУдаляемой = НайденныеВиды[0].ИндексВДереве;
		НайденныеВиды[0].ИндексВДереве = -1;
	КонецЕсли;

	ОбъектыКонфигурации.ПолучитьЭлементы().Удалить(ГруппаВида);

	Если ИндексУдаляемой >= 0 Тогда

		Для Каждого СтрокаВида Из ВидыОбъектовВДереве Цикл

			Если СтрокаВида.ИндексВДереве > ИндексУдаляемой Тогда
				СтрокаВида.ИндексВДереве = СтрокаВида.ИндексВДереве - 1;
			КонецЕсли;

		КонецЦикла;

	КонецЕсли;

КонецПроцедуры

// Добавляет пакет новых объектов в дерево, пропуская уже добавленные.
//
// Параметры:
//  МассивОбъектов - Массив из Структура - элементы с полями ВидОбъекта и ИмяОбъекта
//
&НаСервере
Процедура ДобавитьОбъектыПакетомНаСервере(МассивОбъектов)

	Для Каждого ОбъектДляДобавления Из МассивОбъектов Цикл

		ВидОбъекта = ОбъектДляДобавления.ВидОбъекта;
		ИмяОбъекта = ОбъектДляДобавления.ИмяОбъекта;

		Если ОбъектУжеДобавлен(ВидОбъекта, ИмяОбъекта) Тогда
			Продолжить;
		КонецЕсли;

		ОписаниеВида = цур_РеестрМетаданныхСерверПовтИсп.ОписаниеВида(ВидОбъекта);
		Если ОписаниеВида = Неопределено Тогда
			Продолжить;
		КонецЕсли;

		ОбъектМД = НайтиОбъектМетаданных(ОписаниеВида.ИмяКоллекцииМетаданных, ИмяОбъекта);
		Если ОбъектМД = Неопределено Тогда
			Продолжить;
		КонецЕсли;

		ДобавитьОбъектСПодчиненными(ВидОбъекта, ИмяОбъекта, ОбъектМД, ОписаниеВида);

	КонецЦикла;

	СортироватьОбъектыВДереве();

КонецПроцедуры

// Собирает список объектов, уже присутствующих в дереве, и сериализует их в JSON-строку.
//
// Возвращает:
//  Строка - JSON-массив объектов {ВидОбъекта, ИмяОбъекта}
//
&НаКлиенте
Функция СобратьУжеВыбранныеОбъекты()

	МассивОбъектов = Новый Массив;

	Для Каждого СтрокаГруппы Из ОбъектыКонфигурации.ПолучитьЭлементы() Цикл
		Для Каждого СтрокаОбъекта Из СтрокаГруппы.ПолучитьЭлементы() Цикл
			Если ЗначениеЗаполнено(СтрокаОбъекта.ИмяОбъекта) И НЕ СтрокаОбъекта.ЭтоГруппа Тогда
				МассивОбъектов.Добавить(Новый Структура("ВидОбъекта, ИмяОбъекта",
					СтрокаОбъекта.ВидОбъекта, СтрокаОбъекта.ИмяОбъекта));
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, МассивОбъектов);
	Возврат ЗаписьJSON.Закрыть();

КонецФункции

#КонецОбласти

#Область ЗагрузкаПравИзРегистра

&НаСервере
Процедура ЗагрузитьПраваИзРегистраВДерево()

	Если Объект.Ссылка.Пустая() Тогда
		Возврат;
	КонецЕсли;

	ТаблицаПрав = цур_ВызовСервера.ПолучитьПраваРоли(Объект.Ссылка);
	ЗагрузитьПраваИзТаблицыВДерево(ТаблицаПрав);

КонецПроцедуры

&НаСервере
Функция КартинкаВидаМетаданных(ВидОбъекта)

	Соответствие = КэшКартинокВидовМетаданных();

	Картинка = Соответствие.Получить(ВидОбъекта);

	Если Картинка = Неопределено Тогда
		Возврат Новый Картинка;
	КонецЕсли;

	Возврат Картинка;

КонецФункции

&НаСервере
Функция КэшКартинокВидовМетаданных()

	Результат = Новый Соответствие;

	ДобавитьКартинку(Результат, "Catalog",                    "Справочник");
	ДобавитьКартинку(Результат, "Document",                   "Документ");
	ДобавитьКартинку(Результат, "InformationRegister",        "РегистрСведений");
	ДобавитьКартинку(Результат, "AccumulationRegister",       "РегистрНакопления");
	ДобавитьКартинку(Результат, "AccountingRegister",         "РегистрБухгалтерии");
	ДобавитьКартинку(Результат, "CalculationRegister",        "РегистрРасчета");
	ДобавитьКартинку(Результат, "Report",                     "Отчет");
	ДобавитьКартинку(Результат, "DataProcessor",              "Обработка");
	ДобавитьКартинку(Результат, "ChartOfCharacteristicTypes", "ПланВидовХарактеристик");
	ДобавитьКартинку(Результат, "ChartOfAccounts",            "ПланСчетов");
	ДобавитьКартинку(Результат, "ChartOfCalculationTypes",    "ПланВидовРасчета");
	ДобавитьКартинку(Результат, "BusinessProcess",            "БизнесПроцесс");
	ДобавитьКартинку(Результат, "Task",                       "Задача");
	ДобавитьКартинку(Результат, "ExchangePlan",               "ПланОбмена");
	ДобавитьКартинку(Результат, "Constant",                   "Константа");
	ДобавитьКартинку(Результат, "DocumentJournal",            "ЖурналДокументов");
	ДобавитьКартинку(Результат, "Subsystem",                  "цур_Подсистема");
	ДобавитьКартинку(Результат, "CommonForm",                 "ОбщаяФорма");
	ДобавитьКартинку(Результат, "CommonCommand",              "цур_ОбщаяКоманда");
	ДобавитьКартинку(Результат, "SessionParameter",           "цур_ПараметрСеанса");

	Возврат Результат;

КонецФункции

