
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	Если ПустаяСтрока(РежимРедактора) Тогда
		РежимРедактора = "Простой";
	КонецЕсли;

	ИнициализироватьВидыМетаданных();
	ЗаполнитьДеревоВидов();
	ЗаполнитьДеревоПодсистем();
	УстановитьУсловноеОформление();
	ОбновитьРежимРедактирования();

	Если Объект.Ссылка.Пустая() Тогда
		Объект.Статус = Перечисления.цур_СтатусыРоли.Черновик;
		Объект.ИдентификаторРоли = Строка(Новый УникальныйИдентификатор);
		Объект.УстанавливатьДляРеквизитовПоУмолчанию = Истина;
	Иначе
		ЗапуститьФоновуюЗагрузкуДанных();
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)

	// ПриЧтенииНаСервере вызывается ДО ПриСозданииНаСервере,
	// поэтому инициализируем виды здесь если ещё не заполнены.
	// Загрузка прав и подсистем перенесена в фоновое задание (ЗапуститьФоновуюЗагрузкуДанных).

	Если ВидыОбъектовВДереве.Количество() = 0 Тогда
		ИнициализироватьВидыМетаданных();
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ПриЗагрузкеДанныхИзНастроекНаСервере(Настройки)

	СохраненныйРежим = Настройки.Получить("РежимРедактора");

	Если ЗначениеЗаполнено(СохраненныйРежим) И СохраненныйРежим <> РежимРедактора Тогда
		РежимРедактора = СохраненныйРежим;
		ОбновитьРежимРедактирования();
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)

	Если ЗначениеЗаполнено(ИдентификаторЗадания) Тогда
		ПодключитьОбработчикОжидания("ПроверитьЗавершениеЗагрузки", 1, Ложь);
	Иначе
		РаскрытьПервыйУровеньДерева();
		ОбновитьОбщиеПраваДерева();
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)

	УпаковатьДеревоВРегистрПрав(ТекущийОбъект.Ссылка);
	УпаковатьОграниченияВРегистр(ТекущийОбъект.Ссылка);
	УпаковатьШаблоныВРегистр(ТекущийОбъект.Ссылка);
	УпаковатьПодсистемыВРегистр(ТекущийОбъект.Ссылка);

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ИмяРолиВКонфигурацииПриИзменении(Элемент)

	Объект.Наименование = РазбитьCamelCase(Объект.ИмяРолиВКонфигурации);

КонецПроцедуры

&НаКлиенте
Процедура НаименованиеПриИзменении(Элемент)

	Если ПустаяСтрока(Объект.ИмяРолиВКонфигурации) Тогда
		Объект.ИмяРолиВКонфигурации = Объект.Наименование;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура РежимРедактораПриИзменении(Элемент)

	ОбновитьРежимРедактирования();

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТабличнойЧастиОбъектыКонфигурации

&НаКлиенте
Процедура ОбъектыКонфигурацииПриИзменении(Элемент)

	ТекущиеДанные = Элементы.ОбъектыКонфигурации.ТекущиеДанные;

	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ИмяКолонки = СтрЗаменить(
		Элементы.ОбъектыКонфигурации.ТекущийЭлемент.Имя,
		"ОбъектыКонфигурации", "");

	Если ПустаяСтрока(ИмяКолонки) Тогда
		Возврат;
	КонецЕсли;

	ОбработатьИзменениеПрава(ТекущиеДанные, ИмяКолонки);

КонецПроцедуры

&НаКлиенте
Процедура ОбъектыКонфигурацииПриАктивизацииСтроки(Элемент)

	ТекущиеДанные = Элемент.ТекущиеДанные;

	ЭтоОбъект = ТекущиеДанные <> Неопределено
		И НЕ ТекущиеДанные.ЭтоГруппа
		И ЗначениеЗаполнено(ТекущиеДанные.ИмяОбъекта)
		И ПустаяСтрока(ТекущиеДанные.ТипРеквизита);

	Элементы.ОбъектыКонфигурацииУдалитьОбъект.Доступность = ЭтоОбъект;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТабличнойЧастиПодсистемы

&НаКлиенте
Процедура ДеревоПодсистемИспользованиеПриИзменении(Элемент)

	ТекущиеДанные = Элементы.ДеревоПодсистем.ТекущиеДанные;

	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Если НЕ ТекущиеДанные.Использование Тогда
		УстановитьИспользованиеПодчиненным(ТекущиеДанные, Ложь);
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ДобавитьОбъект(Команда)

	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("УжеВыбранныеОбъекты", СобратьУжеВыбранныеОбъекты());
	ПараметрыФормы.Вставить("ИнформационнаяБаза", Объект.Владелец);

	ТекущиеДанные = Элементы.ОбъектыКонфигурации.ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено И ЗначениеЗаполнено(ТекущиеДанные.ИмяОбъекта) Тогда
		ПараметрыФормы.Вставить("ДанныеТекущегоОбъекта", СериализоватьВJSON(
			Новый Структура("ВидОбъекта, ИмяОбъекта", ТекущиеДанные.ВидОбъекта, ТекущиеДанные.ИмяОбъекта)));
	Иначе
		ПараметрыФормы.Вставить("ДанныеТекущегоОбъекта", "");
	КонецЕсли;

	ОповещениеОЗакрытии = Новый ОписаниеОповещения("ДобавитьОбъектЗавершение", ЭтотОбъект);

	ОткрытьФорму(
		"Справочник.цур_Роли.Форма.ФормаВыбораОбъекта",
		ПараметрыФормы,
		ЭтотОбъект,
		,,,
		ОповещениеОЗакрытии,
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);

КонецПроцедуры

&НаКлиенте
Процедура ДобавитьОбъектЗавершение(Результат, ДополнительныеПараметры) Экспорт

	Если Результат = Неопределено Или ТипЗнч(Результат) <> Тип("Массив") Тогда
		Возврат;
	КонецЕсли;

	Если Результат.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;

	ДобавитьОбъектыПакетомНаСервере(Результат);
	РаскрытьПервыйУровеньДерева();

КонецПроцедуры

&НаКлиенте
Асинх Процедура УдалитьОбъектИзДерева(Команда)

	ТекущиеДанные = Элементы.ОбъектыКонфигурации.ТекущиеДанные;

	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Если ТекущиеДанные.ЭтоГруппа ИЛИ ПустаяСтрока(ТекущиеДанные.ИмяОбъекта) Тогда
		Возврат;
	КонецЕсли;

	ТекстВопроса = СтрШаблон(
		НСтр("ru = 'Удалить объект ""%1"" из дерева?'"),
		ТекущиеДанные.Представление);

	Ответ = Ждать ВопросАсинх(ТекстВопроса, РежимДиалогаВопрос.ДаНет);

	Если Ответ <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;

	УдалитьОбъектИзДереваНаСервере(
		ТекущиеДанные.ВидОбъекта,
		ТекущиеДанные.ИмяОбъекта);

КонецПроцедуры

&НаКлиенте
Асинх Процедура ЗаполнитьПоРоли(Команда)

	ДеревоНеПустое = (ОбъектыКонфигурации.ПолучитьЭлементы().Количество() > 0);

	Если ДеревоНеПустое Тогда

		КодОтвета = Ждать ВопросАсинх(
			НСтр("ru = 'Очистить текущие настройки прав перед заполнением?'"),
			РежимДиалогаВопрос.ДаНетОтмена);

		Если КодОтвета = КодВозвратаДиалога.Отмена Тогда
			Возврат;
		КонецЕсли;

		Если КодОтвета = КодВозвратаДиалога.Да Тогда
			ОчиститьДеревоОбъектов();
		КонецЕсли;

	КонецЕсли;

	ОповещениеОЗакрытии = Новый ОписаниеОповещения("ЗаполнитьПоРолиЗавершение", ЭтотОбъект);

	ПараметрыФормыВыбора = Новый Структура;
	ПараметрыФормыВыбора.Вставить("ИнформационнаяБаза", Объект.Владелец);

	ОткрытьФорму(
		"Справочник.цур_Роли.Форма.ФормаВыбораРоли",
		ПараметрыФормыВыбора,
		ЭтотОбъект,
		,,,
		ОповещениеОЗакрытии,
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);

КонецПроцедуры

&НаКлиенте
Асинх Процедура ЗаполнитьПоПрофилю(Команда)

	ОписаниеТипа = ОписаниеОпределяемогоТипа("цур_ПрофилиГруппДоступа");

	Если НЕ ОписаниеТипа.ЕстьСсылочныйТип Тогда
		Ждать ПредупреждениеАсинх(
			НСтр("ru = 'Справочник ""ПрофилиГруппДоступа"" не найден. Заполните определяемый тип ""цур_ПрофилиГруппДоступа"".'"));
		Возврат;
	КонецЕсли;

	ОповещениеОЗакрытии = Новый ОписаниеОповещения("ЗаполнитьПоПрофилюЗавершение", ЭтотОбъект);
	ПараметрыОткрытия = Новый Структура("РежимВыбора", Истина);
	ОткрытьФорму(ОписаниеТипа.ИмяФормыВыбора, ПараметрыОткрытия, ЭтотОбъект, , , , ОповещениеОЗакрытии);

КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПоПрофилюЗавершение(ВыбранноеЗначение, ДополнительныеПараметры) Экспорт

	Если НЕ ЗначениеЗаполнено(ВыбранноеЗначение) Тогда
		Возврат;
	КонецЕсли;

	ЗаполнитьИзИсточникаПолностьюНаСервере(ТипыИсточниковЗаполнения().Профиль, ВыбранноеЗначение);
	РаскрытьПервыйУровеньДерева();

КонецПроцедуры

&НаКлиенте
Асинх Процедура ЗаполнитьПоПользователю(Команда)

	ОписаниеТипа = ОписаниеОпределяемогоТипа("цур_Пользователи");

	Если ОписаниеТипа.ЕстьСсылочныйТип Тогда

		ОповещениеОЗакрытии = Новый ОписаниеОповещения("ЗаполнитьПоПользователюЗавершение", ЭтотОбъект);
		ПараметрыОткрытия = Новый Структура("РежимВыбора", Истина);
		ОткрытьФорму(ОписаниеТипа.ИмяФормыВыбора, ПараметрыОткрытия, ЭтотОбъект, , , , ОповещениеОЗакрытии);

	Иначе

		ИмяПользователя = Ждать ВвестиСтрокуАсинх(
			НСтр("ru = 'Имя пользователя информационной базы:'"), "");

		Если НЕ ЗначениеЗаполнено(ИмяПользователя) Тогда
			Возврат;
		КонецЕсли;

		ЗаполнитьИзИсточникаПолностьюНаСервере(ТипыИсточниковЗаполнения().Пользователь, ИмяПользователя);
		РаскрытьПервыйУровеньДерева();

	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПоПользователюЗавершение(ВыбранноеЗначение, ДополнительныеПараметры) Экспорт

