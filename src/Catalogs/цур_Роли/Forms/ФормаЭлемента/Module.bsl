&НаСервере
Функция ДоступныеПраваВсехВидов()

	Результат = Новый Соответствие;
	МассивВидов = цур_РеестрМетаданныхСерверПовтИсп.ВсеВидыМетаданных();
	ИменаПрав = СоответствиеИменПрав();

	Для Каждого ОписаниеВида Из МассивВидов Цикл

		ДоступныеКолонки = Новый Массив;

		Для Каждого ИмяПраваАнгл Из ОписаниеВида.ДоступныеПрава Цикл

			ИмяКолонки = ИменаПрав.Получить(ИмяПраваАнгл);

			Если ИмяКолонки <> Неопределено Тогда
				ДоступныеКолонки.Добавить(ИмяКолонки);
			КонецЕсли;

		КонецЦикла;

		ДополнитьОбщимиПравами(ДоступныеКолонки);

		Результат.Вставить(ОписаниеВида.ВидМетаданных, ДоступныеКолонки);

	КонецЦикла;

	Возврат Результат;

КонецФункции

&НаСервере
Процедура ДополнитьОбщимиПравами(ДоступныеКолонки)

	Связь = СвязьОбщихИДетализированныхПрав();

	Для Каждого КлючЗначение Из Связь Цикл

		ЕстьХотяБыОдно = Ложь;

		Для Каждого ДетализированноеПраво Из КлючЗначение.Значение Цикл

			Если ДоступныеКолонки.Найти(ДетализированноеПраво) <> Неопределено Тогда
				ЕстьХотяБыОдно = Истина;
				Прервать;
			КонецЕсли;

		КонецЦикла;

		Если ЕстьХотяБыОдно Тогда
			ДоступныеКолонки.Добавить(КлючЗначение.Ключ);
		КонецЕсли;

	КонецЦикла;

