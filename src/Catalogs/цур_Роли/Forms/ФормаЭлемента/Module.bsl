	Возврат Результат;

КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция СвязьОбщихИДетализированныхПрав()

	Результат = Новый Соответствие;

	ПраваЧтения = Новый Массив;
	ПраваЧтения.Добавить("Чтение");
	ПраваЧтения.Добавить("Просмотр");
	ПраваЧтения.Добавить("ВводПоСтроке");
	Результат.Вставить("ОбщееЧтение", ПраваЧтения);

	ПраваИзменения = Новый Массив;
	ПраваИзменения.Добавить("Изменение");
	ПраваИзменения.Добавить("Редактирование");
	ПраваИзменения.Добавить("Добавление");
	ПраваИзменения.Добавить("ИнтерактивноеДобавление");
	Результат.Вставить("ОбщееИзменение", ПраваИзменения);

	ПраваУдаления = Новый Массив;
	ПраваУдаления.Добавить("Удаление");
	ПраваУдаления.Добавить("ИнтерактивноеУдаление");
	ПраваУдаления.Добавить("ИнтерактивнаяПометкаНаУдаление");
	Результат.Вставить("ОбщееУдаление", ПраваУдаления);

	Возврат Результат;

КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ЗависимостиМеждуПравами()

	Результат = Новый Соответствие;

	ЗависимостиИзменения = Новый Массив;
	ЗависимостиИзменения.Добавить("Чтение");
	ЗависимостиИзменения.Добавить("Просмотр");
	Результат.Вставить("Изменение", ЗависимостиИзменения);

	ЗависимостиДобавления = Новый Массив;
	ЗависимостиДобавления.Добавить("Чтение");
	ЗависимостиДобавления.Добавить("Просмотр");
	Результат.Вставить("Добавление", ЗависимостиДобавления);

	ЗависимостиУдаления = Новый Массив;
	ЗависимостиУдаления.Добавить("Чтение");
	ЗависимостиУдаления.Добавить("Просмотр");
	Результат.Вставить("Удаление", ЗависимостиУдаления);

	ЗависимостиРедактирования = Новый Массив;
	ЗависимостиРедактирования.Добавить("Просмотр");
	Результат.Вставить("Редактирование", ЗависимостиРедактирования);

	ЗависимостиПроведения = Новый Массив;
	ЗависимостиПроведения.Добавить("Чтение");
	ЗависимостиПроведения.Добавить("Просмотр");
	ЗависимостиПроведения.Добавить("Изменение");
	Результат.Вставить("Проведение", ЗависимостиПроведения);

	ЗависимостиОтменыПроведения = Новый Массив;
	ЗависимостиОтменыПроведения.Добавить("Чтение");
	ЗависимостиОтменыПроведения.Добавить("Просмотр");
	ЗависимостиОтменыПроведения.Добавить("Изменение");
	Результат.Вставить("ОтменаПроведения", ЗависимостиОтменыПроведения);

	ЗависимостиИнтерактивногоДобавления = Новый Массив;
	ЗависимостиИнтерактивногоДобавления.Добавить("Добавление");
	ЗависимостиИнтерактивногоДобавления.Добавить("Чтение");
	ЗависимостиИнтерактивногоДобавления.Добавить("Просмотр");
	Результат.Вставить("ИнтерактивноеДобавление", ЗависимостиИнтерактивногоДобавления);

	ЗависимостиИнтерактивногоУдаления = Новый Массив;
	ЗависимостиИнтерактивногоУдаления.Добавить("Удаление");
	ЗависимостиИнтерактивногоУдаления.Добавить("Чтение");
	ЗависимостиИнтерактивногоУдаления.Добавить("Просмотр");
	Результат.Вставить("ИнтерактивноеУдаление", ЗависимостиИнтерактивногоУдаления);

	ЗависимостиИнтерактивнойПометки = Новый Массив;
	ЗависимостиИнтерактивнойПометки.Добавить("Чтение");
	ЗависимостиИнтерактивнойПометки.Добавить("Просмотр");
	Результат.Вставить("ИнтерактивнаяПометкаНаУдаление", ЗависимостиИнтерактивнойПометки);

	ЗависимостиИнтерактивногоПроведения = Новый Массив;
	ЗависимостиИнтерактивногоПроведения.Добавить("Проведение");
	ЗависимостиИнтерактивногоПроведения.Добавить("Чтение");
	ЗависимостиИнтерактивногоПроведения.Добавить("Просмотр");
