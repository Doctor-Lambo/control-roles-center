КонецФункции

&НаСервере
Процедура ДобавитьОбъектСПодчиненнымиБезУмолчаний(ВидОбъекта, ИмяОбъекта, ОбъектМетаданных, ОписаниеВида)

	СохраненныйФлаг = Объект.УстанавливатьДляРеквизитовПоУмолчанию;
	Объект.УстанавливатьДляРеквизитовПоУмолчанию = Ложь;

	ДобавитьОбъектСПодчиненными(ВидОбъекта, ИмяОбъекта, ОбъектМетаданных, ОписаниеВида);

	Объект.УстанавливатьДляРеквизитовПоУмолчанию = СохраненныйФлаг;

КонецПроцедуры

&НаСервере
Процедура ПрименитьПраваИзТаблицы(ТаблицаПрав)

	ИменаПрав = СоответствиеИменПрав();

	Для Каждого СтрокаПрава Из ТаблицаПрав Цикл

		Если НЕ СтрокаПрава.ЗначениеПрава Тогда
			Продолжить;
		КонецЕсли;

		ИмяКолонки = ИменаПрав.Получить(СтрокаПрава.ИмяПрава);

		Если ИмяКолонки = Неопределено Тогда
			Продолжить;
		КонецЕсли;

		СтрокаДерева = НайтиСтрокуВДереве(
			СтрокаПрава.ВидОбъекта,
			СтрокаПрава.ИмяОбъекта,
			СтрокаПрава.ТипРеквизита,
			СтрокаПрава.ИмяРеквизита,
			СтрокаПрава.ИмяРеквизитаТЧ);

		Если СтрокаДерева = Неопределено Тогда
			Продолжить;
		КонецЕсли;

		Попытка
			СтрокаДерева[ИмяКолонки] = Истина;
		Исключение
			Продолжить;
		КонецПопытки;

	КонецЦикла;

КонецПроцедуры

&НаСервере
Функция НайтиСтрокуВДереве(ВидОбъекта, ИмяОбъекта, ТипРеквизита, ИмяРеквизита, ИмяРеквизитаТЧ)

	Для Каждого ГруппаВида Из ОбъектыКонфигурации.ПолучитьЭлементы() Цикл

		Если ГруппаВида.ВидОбъекта <> ВидОбъекта Тогда
			Продолжить;
		КонецЕсли;

		Для Каждого СтрокаОбъекта Из ГруппаВида.ПолучитьЭлементы() Цикл

			Если СтрокаОбъекта.ИмяОбъекта <> ИмяОбъекта Тогда
				Продолжить;
			КонецЕсли;

			Если ПустаяСтрока(ТипРеквизита) И ПустаяСтрока(ИмяРеквизита) Тогда
				Возврат СтрокаОбъекта;
			КонецЕсли;

			Возврат НайтиРеквизитВПоддереве(
				СтрокаОбъекта, ТипРеквизита, ИмяРеквизита, ИмяРеквизитаТЧ);

		КонецЦикла;

	КонецЦикла;

	Возврат Неопределено;

КонецФункции

&НаСервере
Функция НайтиРеквизитВПоддереве(СтрокаРодителя, ТипРеквизита, ИмяРеквизита, ИмяРеквизитаТЧ)

	Для Каждого ГруппаРеквизитов Из СтрокаРодителя.ПолучитьЭлементы() Цикл

		Если ЗначениеЗаполнено(ТипРеквизита) И ГруппаРеквизитов.ТипРеквизита <> ТипРеквизита Тогда
			Продолжить;
		КонецЕсли;

		Для Каждого СтрокаРеквизита Из ГруппаРеквизитов.ПолучитьЭлементы() Цикл

			Если СтрокаРеквизита.ИмяРеквизита = ИмяРеквизита
				И СтрокаРеквизита.ИмяРеквизитаТЧ = ИмяРеквизитаТЧ Тогда
				Возврат СтрокаРеквизита;
			КонецЕсли;

			Если ЗначениеЗаполнено(ИмяРеквизитаТЧ) Тогда

				Для Каждого ПодчиненнаяСтрока Из СтрокаРеквизита.ПолучитьЭлементы() Цикл

					Если ПодчиненнаяСтрока.ИмяРеквизита = ИмяРеквизита
						И ПодчиненнаяСтрока.ИмяРеквизитаТЧ = ИмяРеквизитаТЧ Тогда
						Возврат ПодчиненнаяСтрока;
					КонецЕсли;

				КонецЦикла;

			КонецЕсли;

		КонецЦикла;

	КонецЦикла;

	Возврат Неопределено;

КонецФункции

#КонецОбласти

#Область ЗаписьПравВРегистр

&НаСервере
Процедура УпаковатьДеревоВРегистрПрав(СсылкаРоли)

	Если НЕ ЗначениеЗаполнено(СсылкаРоли) Тогда
		Возврат;
	КонецЕсли;

	НаборЗаписей = РегистрыСведений.цур_ПраваДоступа.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Роль.Установить(СсылкаРоли);

	ИменаПрав = СоответствиеКолонокВИменаПрав();

	Для Каждого ГруппаВида Из ОбъектыКонфигурации.ПолучитьЭлементы() Цикл

		Для Каждого СтрокаОбъекта Из ГруппаВида.ПолучитьЭлементы() Цикл

			СобратьПраваСтроки(НаборЗаписей, СсылкаРоли, СтрокаОбъекта, ИменаПрав);

		КонецЦикла;

	КонецЦикла;

	НаборЗаписей.Записать();

КонецПроцедуры

&НаСервере
Процедура СобратьПраваСтроки(НаборЗаписей, СсылкаРоли, СтрокаДерева, ИменаПрав)

	Для Каждого КлючЗначение Из ИменаПрав Цикл

		ИмяКолонки = КлючЗначение.Ключ;
		ИмяПрава    = КлючЗначение.Значение;

		ЗначениеПрава = Ложь;

		Попытка
			ЗначениеПрава = СтрокаДерева[ИмяКолонки];
		Исключение
			Продолжить;
		КонецПопытки;

		Если НЕ ЗначениеПрава Тогда
			Продолжить;
		КонецЕсли;

		НоваяЗапись = НаборЗаписей.Добавить();
		НоваяЗапись.Роль            = СсылкаРоли;
		НоваяЗапись.ВидОбъекта      = СтрокаДерева.ВидОбъекта;
		НоваяЗапись.ИмяОбъекта      = СтрокаДерева.ИмяОбъекта;
		НоваяЗапись.ИмяПрава        = ИмяПрава;
		НоваяЗапись.ЗначениеПрава   = Истина;
		НоваяЗапись.ТипРеквизита    = ?(ЗначениеЗаполнено(СтрокаДерева.ТипРеквизита), СтрокаДерева.ТипРеквизита, "");
		НоваяЗапись.ИмяРеквизита    = ?(ЗначениеЗаполнено(СтрокаДерева.ИмяРеквизита), СтрокаДерева.ИмяРеквизита, "");
		НоваяЗапись.ИмяРеквизитаТЧ  = ?(ЗначениеЗаполнено(СтрокаДерева.ИмяРеквизитаТЧ), СтрокаДерева.ИмяРеквизитаТЧ, "");

	КонецЦикла;

	Для Каждого ДочерняяСтрока Из СтрокаДерева.ПолучитьЭлементы() Цикл
		СобратьПраваСтроки(НаборЗаписей, СсылкаРоли, ДочерняяСтрока, ИменаПрав);
	КонецЦикла;

КонецПроцедуры

#КонецОбласти

#Область ЗаполнениеИзИсточника

&НаСервере
Процедура ЗаполнитьПраваИзИсточникаНаСервере(ТипИсточника, Источник)

	Типы = ТипыИсточниковЗаполнения();

	Если ТипИсточника = Типы.РольКонфигурации Тогда
		Модель = цур_МодельРолейСервер.ПолучитьМодельРолиКонфигурации(Источник);

	ИначеЕсли ТипИсточника = Типы.Профиль Тогда
		Модель = цур_МодельРолейСервер.ПолучитьМодельПрофиля(Источник);

	ИначеЕсли ТипИсточника = Типы.Пользователь Тогда
		Модель = цур_МодельРолейСервер.ПолучитьМодельПользователя(Источник);

	Иначе
		ВызватьИсключение СтрШаблон(
			НСтр("ru = 'Неизвестный тип источника: ""%1"".'"),
			ТипИсточника);
	КонецЕсли;

	ЗаполнитьДеревоИзМодели(Модель);

	// Сохраняем ограничения и шаблоны в реквизиты формы (запишутся в регистры при записи)
	СохранитьОграниченияВРеквизиты(Модель.Ограничения, Модель.Шаблоны);
	ОтметитьОбъектыСОграничениямиДоступа(Модель.Ограничения);

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДеревоИзМодели(Модель)

	ЗагрузитьПраваИзТаблицыВДерево(Модель.Права);
	ОтметитьОбъектыСОграничениямиДоступа(Модель.Ограничения);
	ПрименитьПодсистемыИзМодели(Модель.Подсистемы);

КонецПроцедуры

&НаСервере
Процедура ПрименитьПодсистемыИзМодели(МассивПодсистем)

	Если МассивПодсистем.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;

	ИменаПодсистем = Новый Соответствие;

	Для Каждого ПолноеИмя Из МассивПодсистем Цикл
		ИменаПодсистем.Вставить(ПолноеИмя, Истина);
	КонецЦикла;

	УстановитьОтметкиПодсистем(ДеревоПодсистем.ПолучитьЭлементы(), ИменаПодсистем);

КонецПроцедуры

&НаСервере
Процедура ОчиститьДеревоОбъектов()

	ОбъектыКонфигурации.ПолучитьЭлементы().Очистить();
	ОбъектыВДереве.Очистить();

	Для Каждого СтрокаВида Из ВидыОбъектовВДереве Цикл
		СтрокаВида.ИндексВДереве = -1;
	КонецЦикла;

КонецПроцедуры

&НаСервереБезКонтекста
// Определяет имя формы выбора для определяемого типа.
// Если определяемый тип содержит ссылочный тип — возвращает полное имя формы выбора.
//
// Параметры:
//  ИмяОпределяемогоТипа - Строка - имя определяемого типа
//
// Возвращаемое значение:
//  Структура:
//   * ЕстьСсылочныйТип - Булево
//   * ИмяФормыВыбора    - Строка - полное имя формы выбора (пусто если нет ссылочного типа)
//
Функция ОписаниеОпределяемогоТипа(ИмяОпределяемогоТипа)

	Результат = Новый Структура("ЕстьСсылочныйТип, ИмяФормыВыбора", Ложь, "");

	ОбъектМД = Метаданные.НайтиПоПолномуИмени("ОпределяемыйТип." + ИмяОпределяемогоТипа);

	Если ОбъектМД = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;

	МассивТипов = ОбъектМД.Тип.Типы();

	Для Каждого ТекущийТип Из МассивТипов Цикл

		Если ТекущийТип = Тип("Строка") Или ТекущийТип = Тип("Неопределено") Тогда
			Продолжить;
		КонецЕсли;

		ОбъектМДТипа = Метаданные.НайтиПоТипу(ТекущийТип);

		Если ОбъектМДТипа <> Неопределено Тогда
			Результат.ЕстьСсылочныйТип = Истина;
			Результат.ИмяФормыВыбора   = ОбъектМДТипа.ПолноеИмя() + ".ФормаСписка";
			Прервать;
		КонецЕсли;

	КонецЦикла;

	Возврат Результат;

КонецФункции

// Заполняет дерево прав, ограничения и шаблоны из источника.
// Данные сохраняются в реквизиты формы, а в регистры — при записи элемента.
//
&НаСервере
Процедура ЗаполнитьИзИсточникаПолностьюНаСервере(ТипИсточника, Источник)

	ЗаполнитьПраваИзИсточникаНаСервере(ТипИсточника, Источник);

КонецПроцедуры

&НаСервере
&НаСервере
Процедура ЗаполнитьПоПользователюБСПНаСервере(СсылкаПользователя)

	Модель = цур_МодельРолейСервер.ПолучитьМодельПользователяБСП(СсылкаПользователя);
	ЗаполнитьДеревоИзМодели(Модель);
	СохранитьОграниченияВРеквизиты(Модель.Ограничения, Модель.Шаблоны);

КонецПроцедуры

Процедура ПрочитатьНаСервере()

	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ЗначениеВДанныеФормы(Объект.Ссылка.ПолучитьОбъект(), Объект);
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьИмяОбъектаНаСервере(Ссылка)

	Возврат цур_ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Ссылка, "Наименование");

КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьИмяПользователяИБНаСервере(СсылкаПользователя)

	ИдентификаторИБ = цур_ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
		СсылкаПользователя, "ИдентификаторПользователяИБ");

	Если НЕ ЗначениеЗаполнено(ИдентификаторИБ) Тогда
		Возврат цур_ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СсылкаПользователя, "Наименование");
	КонецЕсли;

	ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(ИдентификаторИБ);

	Если ПользовательИБ = Неопределено Тогда
		Возврат цур_ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СсылкаПользователя, "Наименование");
	КонецЕсли;

	Возврат ПользовательИБ.Имя;

КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ТипыИсточниковЗаполнения()

	Результат = Новый Структура;
	Результат.Вставить("РольКонфигурации",
		ПредопределенноеЗначение("Перечисление.цур_ТипыИсточниковЗаполнения.РольКонфигурации"));
	Результат.Вставить("Профиль",
		ПредопределенноеЗначение("Перечисление.цур_ТипыИсточниковЗаполнения.Профиль"));
	Результат.Вставить("Пользователь",
		ПредопределенноеЗначение("Перечисление.цур_ТипыИсточниковЗаполнения.Пользователь"));
	Результат.Вставить("ПользовательБСП",
		ПредопределенноеЗначение("Перечисление.цур_ТипыИсточниковЗаполнения.ПользовательБСП"));

	Возврат Результат;

КонецФункции

// Проставляет иконку RLS для объектов, у которых есть ограничения доступа.
//
// Параметры:
//  ТаблицаОграничений - ТаблицаЗначений - колонки: ВидОбъекта, ИмяОбъекта, ИмяПрава, УсловиеОграничения
//
&НаСервере
Процедура ОтметитьОбъектыСОграничениямиДоступа(ТаблицаОграничений)

	Если ТаблицаОграничений.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;

	ОбъектыСОграничениями = Новый Соответствие;

	Для Каждого Строка Из ТаблицаОграничений Цикл
		Ключ = СтрШаблон("%1|%2", Строка.ВидОбъекта, Строка.ИмяОбъекта);
		ОбъектыСОграничениями.Вставить(Ключ, Истина);
	КонецЦикла;

	Для Каждого СтрокаВида Из ОбъектыКонфигурации.ПолучитьЭлементы() Цикл

		Для Каждого СтрокаОбъекта Из СтрокаВида.ПолучитьЭлементы() Цикл

			Ключ = СтрШаблон("%1|%2", СтрокаОбъекта.ВидОбъекта, СтрокаОбъекта.ИмяОбъекта);

			Если ОбъектыСОграничениями.Получить(Ключ) <> Неопределено Тогда
				СтрокаОбъекта.ОграничениеДоступаКДанным = БиблиотекаКартинок.гпр_RLS;
			КонецЕсли;

		КонецЦикла;

	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура ЗапуститьФоновуюЗагрузкуДанных()

	ПараметрыЗадания = Новый Структура("СсылкаРоли", Объект.Ссылка);

	РезультатЗапуска = цур_ФоновыеЗаданияСервер.ВыполнитьВФоне(
		"цур_ВызовСервера.ПодготовитьДанныеРоли",
		ПараметрыЗадания,
		УникальныйИдентификатор,
		НСтр("ru = 'Загрузка прав роли'"));

	ИдентификаторЗадания    = РезультатЗапуска.ИдентификаторЗадания;
	АдресРезультатаЗагрузки = РезультатЗапуска.АдресРезультата;

КонецПроцедуры

&НаКлиенте
Процедура ПроверитьЗавершениеЗагрузки()

	Состояние = цур_ФоновыеЗаданияСервер.ПолучитьСостояние(ИдентификаторЗадания);

	Если Состояние = "Выполняется" Тогда
		Возврат;
	КонецЕсли;

	ОтключитьОбработчикОжидания("ПроверитьЗавершениеЗагрузки");

	Если Состояние = "Завершено" Тогда
		ЗаполнитьДеревоИзФоновогоЗадания(АдресРезультатаЗагрузки);
		РаскрытьПервыйУровеньДерева();
		ОбновитьОбщиеПраваДерева();
	Иначе
		ТекстОшибки = цур_ФоновыеЗаданияСервер.ПолучитьОписаниеОшибки(ИдентификаторЗадания);
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = НСтр("ru = 'Ошибка при загрузке прав роли.'") + " " + ТекстОшибки;
		Сообщение.Сообщить();
	КонецЕсли;

	ИдентификаторЗадания = Неопределено;

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДеревоИзФоновогоЗадания(АдресРезультата)

	Данные = ПолучитьИзВременногоХранилища(АдресРезультата);

	Если Данные = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ЗагрузитьПраваИзТаблицыВДерево(Данные.Права);
	СохранитьОграниченияВРеквизиты(Данные.Ограничения, Данные.Шаблоны);
	ОтметитьОбъектыСОграничениямиДоступа(Данные.Ограничения);
	ПрименитьПодсистемыИзМодели(Данные.Подсистемы);

КонецПроцедуры

&НаСервере
Процедура ЗагрузитьПраваИзТаблицыВДерево(ТаблицаПрав)

	Если ТаблицаПрав.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;

	ПропускаемыеВиды = ВидыМетаданныхБезОтображения();

	УникальныеОбъекты = ТаблицаПрав.Скопировать();
	УникальныеОбъекты.Свернуть("ВидОбъекта, ИмяОбъекта");

	Для Каждого СтрокаОбъекта Из УникальныеОбъекты Цикл

		Если ПропускаемыеВиды.Получить(СтрокаОбъекта.ВидОбъекта) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;

		Если ОбъектУжеДобавлен(СтрокаОбъекта.ВидОбъекта, СтрокаОбъекта.ИмяОбъекта) Тогда
			Продолжить;
		КонецЕсли;

		ОписаниеВида = цур_РеестрМетаданныхСерверПовтИсп.ОписаниеВида(СтрокаОбъекта.ВидОбъекта);

		Если ОписаниеВида = Неопределено Тогда
			Продолжить;
		КонецЕсли;

		ОбъектМД = НайтиОбъектМетаданных(ОписаниеВида.ИмяКоллекцииМетаданных, СтрокаОбъекта.ИмяОбъекта);

		Если ОбъектМД = Неопределено Тогда
			Продолжить;
		КонецЕсли;

		ДобавитьОбъектСПодчиненнымиБезУмолчаний(
			СтрокаОбъекта.ВидОбъекта,
			СтрокаОбъекта.ИмяОбъекта,
			ОбъектМД,
			ОписаниеВида);

	КонецЦикла;

	СортироватьОбъектыВДереве();
	ПрименитьПраваИзТаблицы(ТаблицаПрав);

КонецПроцедуры

// Сохраняет ограничения и шаблоны доступа в реквизиты формы для последующей записи при сохранении.
//
// Параметры:
//  ТаблицаОграничений - ТаблицаЗначений - ограничения доступа
//  ТаблицаШаблонов    - ТаблицаЗначений - шаблоны ограничений
//
&НаСервере
Процедура СохранитьОграниченияВРеквизиты(ТаблицаОграничений, ТаблицаШаблонов)

	ХранилищеОграничений.Очистить();
	Для Каждого Строка Из ТаблицаОграничений Цикл
		НоваяСтрока = ХранилищеОграничений.Добавить();
		НоваяСтрока.ВидОбъекта          = Строка.ВидОбъекта;
		НоваяСтрока.ИмяОбъекта          = Строка.ИмяОбъекта;
		НоваяСтрока.ИмяПрава            = Строка.ИмяПрава;
		НоваяСтрока.УсловиеОграничения  = Строка.УсловиеОграничения;

		Попытка
			НоваяСтрока.Поля = Строка.Поля;
		Исключение
			// Колонка Поля отсутствует в источнике
		КонецПопытки;

	КонецЦикла;

	ХранилищеШаблонов.Очистить();
	Для Каждого Строка Из ТаблицаШаблонов Цикл
		НоваяСтрока = ХранилищеШаблонов.Добавить();
		НоваяСтрока.ИмяШаблона   = Строка.ИмяШаблона;
		НоваяСтрока.ТекстШаблона = Строка.ТекстШаблона;
	КонецЦикла;

КонецПроцедуры

// Записывает ограничения доступа из реквизита формы в регистр.
//
// Параметры:
//  СсылкаРоли - СправочникСсылка.цур_Роли
//
&НаСервере
Процедура УпаковатьОграниченияВРегистр(СсылкаРоли)

	Если НЕ ЗначениеЗаполнено(СсылкаРоли) Тогда
		Возврат;
	КонецЕсли;

	// Если ограничения не менялись (хранилище пустое и данные уже в регистре) — не трогаем.
	// Если хранилище заполнено — перезаписываем.
	цур_МодельРолейСервер.ЗаписатьТаблицуВРегистрОграничений(СсылкаРоли, ХранилищеОграничений);

КонецПроцедуры

// Записывает шаблоны ограничений из реквизита формы в регистр.
//
// Параметры:
//  СсылкаРоли - СправочникСсылка.цур_Роли
//
&НаСервере
Процедура УпаковатьШаблоныВРегистр(СсылкаРоли)

	Если НЕ ЗначениеЗаполнено(СсылкаРоли) Тогда
		Возврат;
	КонецЕсли;

	цур_МодельРолейСервер.ЗаписатьТаблицуВРегистрШаблонов(СсылкаРоли, ХранилищеШаблонов);

КонецПроцедуры

&НаКлиенте
Процедура ОбновитьОбщиеПраваДерева()

	Для Каждого ГруппаВида Из ОбъектыКонфигурации.ПолучитьЭлементы() Цикл

		Для Каждого СтрокаОбъекта Из ГруппаВида.ПолучитьЭлементы() Цикл
			ОбновитьЗначенияОбщихПрав(СтрокаОбъекта);
		КонецЦикла;

	КонецЦикла;

КонецПроцедуры

#КонецОбласти

#Область КаскадныеИзмененияПрав

&НаКлиенте
Процедура ОбработатьИзменениеПрава(ТекущиеДанные, ИмяКолонки)

	Если СтрНачинаетсяС(ИмяКолонки, "Общее") Тогда

		Если ТекущиеДанные[ИмяКолонки] = 2 Тогда
			ТекущиеДанные[ИмяКолонки] = 0;
		КонецЕсли;

		РаспространитьОбщееПравоНаДетализированные(ТекущиеДанные, ИмяКолонки);

	Иначе

		УстановитьЗависимыеПрава(ТекущиеДанные, ИмяКолонки);

	КонецЕсли;

	УстановитьЗначениеДляДочерних(ТекущиеДанные, ИмяКолонки);
	ОбновитьЗначенияОбщихПрав(ТекущиеДанные);

КонецПроцедуры

&НаКлиенте
Процедура УстановитьЗначениеДляДочерних(Данные, ИмяКолонки)

	Значение = Данные[ИмяКолонки];

	Для Каждого Дочерняя Из Данные.ПолучитьЭлементы() Цикл

		Попытка
			Дочерняя[ИмяКолонки] = Значение;
		Исключение
			Продолжить;
		КонецПопытки;

		УстановитьЗначениеДляДочерних(Дочерняя, ИмяКолонки);

	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура РаспространитьОбщееПравоНаДетализированные(Данные, ИмяОбщегоПрава)

	Связь = СвязьОбщихИДетализированныхПрав();
	ДетализированныеПрава = Связь.Получить(ИмяОбщегоПрава);

	Если ДетализированныеПрава = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ЗначениеОбщего = Данные[ИмяОбщегоПрава];

	Для Каждого ИмяДетализированного Из ДетализированныеПрава Цикл

		Попытка
			Данные[ИмяДетализированного] = ?(ЗначениеОбщего = 1, Истина, Ложь);
		Исключение
			Продолжить;
		КонецПопытки;

		УстановитьЗначениеДляДочерних(Данные, ИмяДетализированного);

	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура УстановитьЗависимыеПрава(Данные, ИмяПрава)

	ЗависимостиПрав = ЗависимостиМеждуПравами();

	Если Данные[ИмяПрава] Тогда

		// Право включено — включаем все, от которых оно зависит
		ПраваКВключению = ЗависимостиПрав.Получить(ИмяПрава);

		Если ПраваКВключению = Неопределено Тогда
			Возврат;
		КонецЕсли;

		Для Каждого ЗависимоеПраво Из ПраваКВключению Цикл

			Попытка
				Данные[ЗависимоеПраво] = Истина;
			Исключение
				Продолжить;
			КонецПопытки;

			УстановитьЗначениеДляДочерних(Данные, ЗависимоеПраво);

		КонецЦикла;

	Иначе

		// Право выключено — выключаем все, которые от него зависят
		Для Каждого ПравоИЗависимости Из ЗависимостиПрав Цикл

			Если ПравоИЗависимости.Значение.Найти(ИмяПрава) <> Неопределено Тогда

				Попытка
					Данные[ПравоИЗависимости.Ключ] = Ложь;
				Исключение
					Продолжить;
				КонецПопытки;

				УстановитьЗначениеДляДочерних(Данные, ПравоИЗависимости.Ключ);

			КонецЕсли;

		КонецЦикла;

	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОбновитьЗначенияОбщихПрав(Данные)

	Связь = СвязьОбщихИДетализированныхПрав();

	Для Каждого КлючЗначение Из Связь Цикл

		ИмяОбщего = КлючЗначение.Ключ;
		Детализированные = КлючЗначение.Значение;

		КоличествоУстановленных = 0;
		КоличествоВсего         = 0;

		Для Каждого ИмяДетализированного Из Детализированные Цикл

			Попытка
				Значение = Данные[ИмяДетализированного];
			Исключение
				Продолжить;
			КонецПопытки;

			КоличествоВсего = КоличествоВсего + 1;

			Если Значение Тогда
				КоличествоУстановленных = КоличествоУстановленных + 1;
			КонецЕсли;

		КонецЦикла;

		Если КоличествоВсего = 0 Тогда
			Данные[ИмяОбщего] = 0;

		ИначеЕсли КоличествоУстановленных = 0 Тогда
			Данные[ИмяОбщего] = 0;

		ИначеЕсли КоличествоУстановленных = КоличествоВсего Тогда
			Данные[ИмяОбщего] = 1;

		Иначе
			Данные[ИмяОбщего] = 2;

		КонецЕсли;

	КонецЦикла;

	Для Каждого Дочерняя Из Данные.ПолучитьЭлементы() Цикл
		ОбновитьЗначенияОбщихПрав(Дочерняя);
	КонецЦикла;

КонецПроцедуры

#КонецОбласти

#Область СоответствияПрав

&НаКлиентеНаСервереБезКонтекста
Функция СоответствиеИменПрав()

	Результат = Новый Соответствие;
	Результат.Вставить("Read",                               "Чтение");
	Результат.Вставить("Insert",                             "Добавление");
	Результат.Вставить("Update",                             "Изменение");
	Результат.Вставить("Delete",                             "Удаление");
	Результат.Вставить("View",                               "Просмотр");
	Результат.Вставить("Edit",                               "Редактирование");
	Результат.Вставить("InputByString",                      "ВводПоСтроке");
	Результат.Вставить("Use",                                "Использование");
	Результат.Вставить("Posting",                            "Проведение");
	Результат.Вставить("UndoPosting",                        "ОтменаПроведения");
	Результат.Вставить("InteractiveInsert",                  "ИнтерактивноеДобавление");
	Результат.Вставить("InteractiveDelete",                  "ИнтерактивноеУдаление");
	Результат.Вставить("InteractiveSetDeletionMark",         "ИнтерактивнаяПометкаНаУдаление");
	Результат.Вставить("InteractivePosting",                 "ИнтерактивноеПроведение");
	Результат.Вставить("TotalsControl",                      "УправлениеИтогами");

	Возврат Результат;

КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция СоответствиеКолонокВИменаПрав()

	Результат = Новый Соответствие;
	Результат.Вставить("Чтение",                           "Read");
	Результат.Вставить("Добавление",                       "Insert");
	Результат.Вставить("Изменение",                        "Update");
	Результат.Вставить("Удаление",                         "Delete");
	Результат.Вставить("Просмотр",                         "View");
	Результат.Вставить("Редактирование",                   "Edit");
	Результат.Вставить("ВводПоСтроке",                     "InputByString");
	Результат.Вставить("Использование",                    "Use");
	Результат.Вставить("Проведение",                       "Posting");
	Результат.Вставить("ОтменаПроведения",                 "UndoPosting");
	Результат.Вставить("ИнтерактивноеДобавление",          "InteractiveInsert");
	Результат.Вставить("ИнтерактивноеУдаление",            "InteractiveDelete");
	Результат.Вставить("ИнтерактивнаяПометкаНаУдаление",   "InteractiveSetDeletionMark");
