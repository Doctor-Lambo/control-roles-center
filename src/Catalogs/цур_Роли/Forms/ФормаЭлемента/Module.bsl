Процедура УстановитьОформлениеНедоступныхПрав()

	ВсеКолонкиПрав = Новый Массив;
	ВсеКолонкиПрав.Добавить("Чтение");
	ВсеКолонкиПрав.Добавить("Добавление");
	ВсеКолонкиПрав.Добавить("Изменение");
	ВсеКолонкиПрав.Добавить("Удаление");
	ВсеКолонкиПрав.Добавить("Просмотр");
	ВсеКолонкиПрав.Добавить("Редактирование");
	ВсеКолонкиПрав.Добавить("ВводПоСтроке");
	ВсеКолонкиПрав.Добавить("Использование");
	ВсеКолонкиПрав.Добавить("Проведение");
	ВсеКолонкиПрав.Добавить("ОтменаПроведения");
	ВсеКолонкиПрав.Добавить("ИнтерактивноеДобавление");
	ВсеКолонкиПрав.Добавить("ИнтерактивноеУдаление");
	ВсеКолонкиПрав.Добавить("ИнтерактивнаяПометкаНаУдаление");
	ВсеКолонкиПрав.Добавить("ИнтерактивноеПроведение");
	ВсеКолонкиПрав.Добавить("УправлениеИтогами");
	ВсеКолонкиПрав.Добавить("ОбщееЧтение");
	ВсеКолонкиПрав.Добавить("ОбщееИзменение");
	ВсеКолонкиПрав.Добавить("ОбщееУдаление");

	ДоступныеПраваПоВидам = ДоступныеПраваВсехВидов();

	Для Каждого КлючЗначение Из ДоступныеПраваПоВидам Цикл

		ВидОбъекта = КлючЗначение.Ключ;
		ДоступныеИмена = КлючЗначение.Значение;

		НедоступныеКолонки = Новый Массив;

		Для Каждого ИмяКолонки Из ВсеКолонкиПрав Цикл

			Если ДоступныеИмена.Найти(ИмяКолонки) = Неопределено Тогда
				НедоступныеКолонки.Добавить(ИмяКолонки);
			КонецЕсли;

		КонецЦикла;

		Если НедоступныеКолонки.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;

		НовыйЭлемент = УсловноеОформление.Элементы.Добавить();

		ЗапретОтображения = НовыйЭлемент.Оформление.Элементы.Найти("Отображать");
		ЗапретОтображения.Использование = Истина;
		ЗапретОтображения.Значение      = Ложь;

		ГруппаИ = НовыйЭлемент.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
		ГруппаИ.ТипГруппы    = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИ;
		ГруппаИ.Использование = Истина;

		ОтборВид = ГруппаИ.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ОтборВид.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
		ОтборВид.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("ОбъектыКонфигурации.ВидОбъекта");
		ОтборВид.ПравоеЗначение = ВидОбъекта;
		ОтборВид.Использование  = Истина;

		ОтборТипРеквизита = ГруппаИ.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ОтборТипРеквизита.ВидСравнения   = ВидСравненияКомпоновкиДанных.НеЗаполнено;
		ОтборТипРеквизита.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("ОбъектыКонфигурации.ТипРеквизита");
		ОтборТипРеквизита.Использование  = Истина;

		Для Каждого НедоступнаяКолонка Из НедоступныеКолонки Цикл
			НовыйЭлемент.Поля.Элементы.Добавить().Поле =
				Новый ПолеКомпоновкиДанных("ОбъектыКонфигурации" + НедоступнаяКолонка);
		КонецЦикла;

	КонецЦикла;

	УстановитьОформлениеДляРеквизитов();

КонецПроцедуры

