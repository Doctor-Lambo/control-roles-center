	НовыйОтбор.ВидСравнения   = ВидСравненияКомпоновкиДанных.Заполнено;
	НовыйОтбор.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("ОбъектыКонфигурации.ТипРеквизита");
	НовыйОтбор.Использование  = Истина;

	Для Каждого НедоступнаяКолонка Из НедоступныеКолонки Цикл
		НовыйЭлемент.Поля.Элементы.Добавить().Поле =
			Новый ПолеКомпоновкиДанных("ОбъектыКонфигурации" + НедоступнаяКолонка);
