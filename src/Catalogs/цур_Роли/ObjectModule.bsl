#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ)

	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;

	Если ЭтоГруппа Тогда
		Возврат;
	КонецЕсли;

	Если ЗначениеЗаполнено(ИмяРолиВКонфигурации) Тогда
		ПроверитьУникальностьИмениРоли(Отказ);
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Проверяет, что имя роли не совпадает с существующей ролью основной конфигурации.
//
// Параметры:
//  Отказ - Булево - устанавливается в Истина при обнаружении дубликата
//
Процедура ПроверитьУникальностьИмениРоли(Отказ)

	ПолноеИмяРоли = "Роль." + ИмяРолиВКонфигурации;
	ОбъектМетаданных = Метаданные.НайтиПоПолномуИмени(ПолноеИмяРоли);

	Если ОбъектМетаданных <> Неопределено Тогда

		ТекстОшибки = СтрШаблон(
			НСтр("ru = 'Роль ""%1"" уже существует в основной конфигурации. Укажите другое имя.'"),
			ИмяРолиВКонфигурации);

		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст                = ТекстОшибки;
		Сообщение.ПутьКДанным          = "Объект.ИмяРолиВКонфигурации";
		Сообщение.УстановитьДанные(ЭтотОбъект);
		Сообщение.Сообщить();

		Отказ = Истина;

	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#КонецЕсли
