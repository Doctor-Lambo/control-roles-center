#Область ПрограммныйИнтерфейс

// Экспортирует массив ролей в строку формата Role JSON DSL.
//
// Параметры:
//  МассивСсылокРолей - Массив из СправочникСсылка.цур_Роли - роли для выгрузки
//
// Возвращаемое значение:
//  Строка - JSON-массив объектов ролей по спецификации DSL
//
Функция ЭкспортВJSON(МассивСсылокРолей) Экспорт

	МассивОбъектов = Новый Массив;

	Для Каждого СсылкаРоли Из МассивСсылокРолей Цикл

		Модель = цур_МодельРолейСервер.НормализоватьРоль(СсылкаРоли);
		МассивОбъектов.Добавить(МодельВСтруктуруJSON(Модель));

	КонецЦикла;

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку(Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Авто));
	ЗаписатьJSON(ЗаписьJSON, МассивОбъектов);

	Возврат ЗаписьJSON.Закрыть();

КонецФункции

// Разбирает JSON-строку формата Role JSON DSL и создаёт роли в базе.
//
// Параметры:
//  JSONСтрока - Строка - содержимое JSON (массив или единственный объект роли)
//
// Возвращаемое значение:
//  Массив из СправочникСсылка.цур_Роли - созданные (обновлённые) роли
//
Функция ИмпортИзJSON(JSONСтрока) Экспорт

	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(JSONСтрока);

	ДанныеJSON = ПрочитатьJSON(ЧтениеJSON);
	ЧтениеJSON.Закрыть();

	Если ТипЗнч(ДанныеJSON) = Тип("Структура") Тогда
		МассивРолейJSON = Новый Массив;
		МассивРолейJSON.Добавить(ДанныеJSON);
	ИначеЕсли ТипЗнч(ДанныеJSON) = Тип("Массив") Тогда
		МассивРолейJSON = ДанныеJSON;
	Иначе
		ВызватьИсключение НСтр("ru = 'Некорректный формат JSON: ожидается объект или массив объектов ролей.'");
	КонецЕсли;

	СозданныеРоли = Новый Массив;

	Для Каждого ОбъектРолиJSON Из МассивРолейJSON Цикл

		СсылкаРоли = ЗаписатьРольИзJSON(ОбъектРолиJSON);
		СозданныеРоли.Добавить(СсылкаРоли);

	КонецЦикла;

	Возврат СозданныеРоли;

КонецФункции

// Раскрывает пресет (@view / @edit) в набор имён прав для указанного вида метаданных.
// Возвращает только права, допустимые для данного вида по реестру.
//
// Параметры:
//  Пресет        - Строка - "@view" или "@edit" (без учёта регистра)
//  ВидМетаданных - Строка - строковый идентификатор вида (например "Catalog", "Document")
//
// Возвращаемое значение:
//  Массив из Строка - имена прав для пресета; пустой массив, если пресет не распознан
//
Функция РазрешитьПресет(Пресет, ВидМетаданных) Экспорт

	НормПресет = НРег(СокрЛП(Пресет));

	ОписаниеВида = цур_РеестрМетаданныхСерверПовтИсп.ОписаниеВида(ВидМетаданных);
	ДоступныеПрава = ?(ОписаниеВида <> Неопределено, ОписаниеВида.ДоступныеПрава, Новый Массив);

	Если НормПресет = "@view" Тогда
		КандидатыПрав = ПресетВью(ВидМетаданных);
	ИначеЕсли НормПресет = "@edit" Тогда
		КандидатыПрав = ПресетЭдит(ВидМетаданных);
	Иначе
		Возврат Новый Массив;
	КонецЕсли;

	Возврат ОтфильтроватьПоДоступным(КандидатыПрав, ДоступныеПрава);

КонецФункции

// Разбирает строковый shorthand объекта из DSL в структуру.
// Поддерживает форматы:
//   "Тип.Имя: @пресет"
//   "Тип.Имя: Право1, Право2"
//
// Параметры:
//  СтрокаОбъекта - Строка - строка shorthand
//
// Возвращаемое значение:
//  Структура - результат разбора:
//    * Имя    - Строка        - полное имя объекта (например "Catalog.Контрагенты")
//    * Пресет - Строка        - имя пресета (например "@view") или пустая строка
//    * Права  - Массив из Строка - список имён прав (пуст, если задан пресет)
//
Функция РазобратьСтрокуОбъекта(СтрокаОбъекта) Экспорт

	Результат = Новый Структура("Имя, Пресет, Права", "", "", Новый Массив);

	ПозицияДвоеточия = СтрНайти(СтрокаОбъекта, ":");
	Если ПозицияДвоеточия = 0 Тогда
		Результат.Имя = СокрЛП(СтрокаОбъекта);
		Возврат Результат;
	КонецЕсли;

	Результат.Имя = СокрЛП(Лев(СтрокаОбъекта, ПозицияДвоеточия - 1));
	ЧастьПрав    = СокрЛП(Сред(СтрокаОбъекта, ПозицияДвоеточия + 1));

	Если НачинаетсяС(НРег(ЧастьПрав), "@") Тогда
		Результат.Пресет = НРег(ЧастьПрав);
	Иначе
		МассивПрав = Новый Массив;
		ЧастиПрав  = СтрРазделить(ЧастьПрав, ",", Ложь);

		Для Каждого ЧастьПрава Из ЧастиПрав Цикл
			ИмяПрава = СокрЛП(ЧастьПрава);
			Если Не ПустаяСтрока(ИмяПрава) Тогда
				МассивПрав.Добавить(ИмяПрава);
			КонецЕсли;
		КонецЦикла;

		Результат.Права = МассивПрав;
	КонецЕсли;

	Возврат Результат;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Формирует структуру JSON-объекта роли из нормализованной модели.
Функция МодельВСтруктуруJSON(Модель)

	ОбъектРоли = Новый Структура;
	ОбъектРоли.Вставить("name",                          Модель.Имя);
	ОбъектРоли.Вставить("synonym",                       Модель.Синоним);
	ОбъектРоли.Вставить("comment",                       Модель.Комментарий);
	ОбъектРоли.Вставить("setForNewObjects",               Модель.УстанавливатьДляНовыхОбъектов);
	ОбъектРоли.Вставить("setForAttributesByDefault",      Модель.УстанавливатьДляРеквизитовПоУмолчанию);
	ОбъектРоли.Вставить("independentRightsOfChildObjects", Модель.НезависимыеПраваПодчиненных);
	ОбъектРоли.Вставить("objects",   СформироватьМассивОбъектовJSON(Модель));
	ОбъектРоли.Вставить("templates", СформироватьМассивШаблоновJSON(Модель.Шаблоны));

	Возврат ОбъектРоли;

КонецФункции

// Строит массив объектов прав для JSON-поля "objects" из таблиц прав и ограничений модели.
Функция СформироватьМассивОбъектовJSON(Модель)

	// Собираем уникальные пары ВидОбъекта + ИмяОбъекта
	ИндексОбъектов = Новый Соответствие; // ключ → структура объекта JSON
	МассивОбъектов = Новый Массив;

	Для Каждого СтрокаПрава Из Модель.Права Цикл

		Если Не ПустаяСтрока(СтрокаПрава.ТипРеквизита) Тогда
			Продолжить; // пропускаем права на реквизиты — это уровень объектов
		КонецЕсли;

		КлючОбъекта = СтрокаПрава.ВидОбъекта + "." + СтрокаПрава.ИмяОбъекта;
		ОбъектJSON  = ИндексОбъектов.Получить(КлючОбъекта);

		Если ОбъектJSON = Неопределено Тогда
			ОбъектJSON = Новый Структура;
			ОбъектJSON.Вставить("name",   КлючОбъекта);
			ОбъектJSON.Вставить("rights", Новый Структура);
			ИндексОбъектов.Вставить(КлючОбъекта, ОбъектJSON);
			МассивОбъектов.Добавить(ОбъектJSON);
		КонецЕсли;

		ОбъектJSON.rights.Вставить(СтрокаПрава.ИмяПрава, СтрокаПрава.ЗначениеПрава);

	КонецЦикла;

	// Добавляем RLS-ограничения в поле "rls" соответствующих объектов
	Для Каждого СтрокаОгр Из Модель.Ограничения Цикл

		КлючОбъекта = СтрокаОгр.ВидОбъекта + "." + СтрокаОгр.ИмяОбъекта;
		ОбъектJSON  = ИндексОбъектов.Получить(КлючОбъекта);

		Если ОбъектJSON = Неопределено Тогда
			ОбъектJSON = Новый Структура;
			ОбъектJSON.Вставить("name",   КлючОбъекта);
			ОбъектJSON.Вставить("rights", Новый Структура);
			ИндексОбъектов.Вставить(КлючОбъекта, ОбъектJSON);
			МассивОбъектов.Добавить(ОбъектJSON);
		КонецЕсли;

		Если Не ОбъектJSON.Свойство("rls") Тогда
			ОбъектJSON.Вставить("rls", Новый Структура);
		КонецЕсли;

		ОбъектJSON.rls.Вставить(СтрокаОгр.ИмяПрава, СтрокаОгр.УсловиеОграничения);

	КонецЦикла;

	Возврат МассивОбъектов;

КонецФункции

// Строит массив объектов шаблонов для JSON-поля "templates".
Функция СформироватьМассивШаблоновJSON(ТаблицаШаблонов)

	МассивШаблонов = Новый Массив;

	Для Каждого Строка Из ТаблицаШаблонов Цикл

		ШаблонJSON = Новый Структура;
		ШаблонJSON.Вставить("name",      Строка.ИмяШаблона);
		ШаблонJSON.Вставить("condition", Строка.ТекстШаблона);
		МассивШаблонов.Добавить(ШаблонJSON);

	КонецЦикла;

	Возврат МассивШаблонов;

КонецФункции

// Создаёт или обновляет элемент справочника цур_Роли и записывает права из JSON-объекта.
//
// Возвращаемое значение:
//  СправочникСсылка.цур_Роли
//
Функция ЗаписатьРольИзJSON(ОбъектРолиJSON)

	ИмяРоли = "";
	Если Не ОбъектРолиJSON.Свойство("name", ИмяРоли) Или ПустаяСтрока(ИмяРоли) Тогда
		ВызватьИсключение НСтр("ru = 'Обязательное поле ""name"" отсутствует или пустое в описании роли.'");
	КонецЕсли;

	// Поиск существующей роли по имени
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	цур_Роли.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.цур_Роли КАК цур_Роли
	|ГДЕ
	|	цур_Роли.ИмяРолиВКонфигурации = &ИмяРоли
	|	И НЕ цур_Роли.ЭтоГруппа";

	Запрос.УстановитьПараметр("ИмяРоли", ИмяРоли);
	РезультатЗапроса = Запрос.Выполнить();

	Если Не РезультатЗапроса.Пустой() Тогда
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		ОбъектРоли = Выборка.Ссылка.ПолучитьОбъект();
	Иначе
		ОбъектРоли = Справочники.цур_Роли.СоздатьЭлемент();
		ОбъектРоли.ИмяРолиВКонфигурации = ИмяРоли;
	КонецЕсли;

	// Синоним
	Синоним = "";
	Если ОбъектРолиJSON.Свойство("synonym", Синоним) И Не ПустаяСтрока(Синоним) Тогда
		ОбъектРоли.Наименование = Синоним;
	Иначе
		ОбъектРоли.Наименование = ИмяРоли;
	КонецЕсли;

	// Комментарий
	Комментарий = "";
	Если ОбъектРолиJSON.Свойство("comment", Комментарий) Тогда
		ОбъектРоли.Комментарий = Комментарий;
	КонецЕсли;

	// Флаги
	УстДляНовых = Ложь;
	Если ОбъектРолиJSON.Свойство("setForNewObjects", УстДляНовых) Тогда
		ОбъектРоли.УстанавливатьДляНовыхОбъектов = УстДляНовых;
	КонецЕсли;

	УстДляРеквизитов = Истина;
	Если ОбъектРолиJSON.Свойство("setForAttributesByDefault", УстДляРеквизитов) Тогда
		ОбъектРоли.УстанавливатьДляРеквизитовПоУмолчанию = УстДляРеквизитов;
	КонецЕсли;

	НезависимыеПрава = Ложь;
	Если ОбъектРолиJSON.Свойство("independentRightsOfChildObjects", НезависимыеПрава) Тогда
		ОбъектРоли.НезависимыеПраваПодчиненных = НезависимыеПрава;
	КонецЕсли;

	ОбъектРоли.Записать();
	СсылкаРоли = ОбъектРоли.Ссылка;

	// Права и ограничения
	Модель = цур_МодельРолейСервер.НовыеПараметрыРоли();

	МассивОбъектовJSON = Новый Массив;
	Если ОбъектРолиJSON.Свойство("objects", МассивОбъектовJSON) Тогда
		ЗаполнитьПраваИзОбъектовJSON(МассивОбъектовJSON, Модель);
	КонецЕсли;

	МассивШаблоновJSON = Новый Массив;
	Если ОбъектРолиJSON.Свойство("templates", МассивШаблоновJSON) Тогда
		ЗаполнитьШаблоныИзJSON(МассивШаблоновJSON, Модель.Шаблоны);
	КонецЕсли;

	цур_МодельРолейСервер.ЗаписатьПраваРоли(
		СсылкаРоли,
		Модель.Права,
		Модель.Ограничения,
		Модель.Шаблоны,
		Модель.Подсистемы);

	Возврат СсылкаРоли;

КонецФункции

// Разбирает массив "objects" из JSON и заполняет таблицы прав и ограничений модели.
Процедура ЗаполнитьПраваИзОбъектовJSON(МассивОбъектовJSON, Модель)

	Для Каждого ЭлементОбъекта Из МассивОбъектовJSON Цикл

		Если ТипЗнч(ЭлементОбъекта) = Тип("Строка") Тогда
			ЗаполнитьПраваИзСтрокиShorthand(ЭлементОбъекта, Модель);
		ИначеЕсли ТипЗнч(ЭлементОбъекта) = Тип("Структура") Тогда
			ЗаполнитьПраваИзОбъектногоФормата(ЭлементОбъекта, Модель);
		КонецЕсли;

	КонецЦикла;

КонецПроцедуры

// Обрабатывает строковый shorthand вида "Тип.Имя: @пресет" или "Тип.Имя: Право1, Право2".
Процедура ЗаполнитьПраваИзСтрокиShorthand(СтрокаOбъекта, Модель)

	Разобранное = РазобратьСтрокуОбъекта(СтрокаOбъекта);
	ВидОбъекта  = ВидИзПолногоИмени(Разобранное.Имя);
	ИмяОбъекта  = ИмяИзПолногоИмени(Разобранное.Имя);

	Если Не ПустаяСтрока(Разобранное.Пресет) Тогда
		МассивПрав = РазрешитьПресет(Разобранное.Пресет, ВидОбъекта);
	Иначе
		МассивПрав = Разобранное.Права;
	КонецЕсли;

	ДобавитьПраваВТаблицу(Модель.Права, ВидОбъекта, ИмяОбъекта, МассивПрав, Истина);

КонецПроцедуры

// Обрабатывает объектный формат элемента объекта.
Процедура ЗаполнитьПраваИзОбъектногоФормата(ОбъектJSON, Модель)

	ПолноеИмяОбъекта = "";
	Если Не ОбъектJSON.Свойство("name", ПолноеИмяОбъекта) Или ПустаяСтрока(ПолноеИмяОбъекта) Тогда
		Возврат;
	КонецЕсли;

	ВидОбъекта = ВидИзПолногоИмени(ПолноеИмяОбъекта);
	ИмяОбъекта = ИмяИзПолногоИмени(ПолноеИмяОбъекта);

	// Права из пресета
	СтрПресет = "";
	Если ОбъектJSON.Свойство("preset", СтрПресет) И Не ПустаяСтрока(СтрПресет) Тогда

		НормализованныйПресет = ?(НачинаетсяС(НРег(СтрПресет), "@"), СтрПресет, "@" + СтрПресет);
		МассивПрав = РазрешитьПресет(НормализованныйПресет, ВидОбъекта);
		ДобавитьПраваВТаблицу(Модель.Права, ВидОбъекта, ИмяОбъекта, МассивПрав, Истина);

	КонецЕсли;

	// Явные права
	ПраваJSON = Неопределено;
	Если ОбъектJSON.Свойство("rights", ПраваJSON) И ТипЗнч(ПраваJSON) = Тип("Структура") Тогда
		ЗаполнитьПраваИзСтруктурыJSON(Модель.Права, ВидОбъекта, ИмяОбъекта, ПраваJSON);
	КонецЕсли;

	// RLS-ограничения
	ДанныеRLS = Неопределено;
	Если ОбъектJSON.Свойство("rls", ДанныеRLS) И ТипЗнч(ДанныеRLS) = Тип("Структура") Тогда
		ЗаполнитьОграниченияИзСтруктурыJSON(Модель.Ограничения, ВидОбъекта, ИмяОбъекта, ДанныеRLS);
	КонецЕсли;

КонецПроцедуры

// Добавляет строки прав в таблицу прав модели из структуры JSON {"ИмяПрава": булево}.
Процедура ЗаполнитьПраваИзСтруктурыJSON(ТаблицаПрав, ВидОбъекта, ИмяОбъекта, ПраваJSON)

	Для Каждого КлючЗначение Из ПраваJSON Цикл

		СтрокаПрава = ТаблицаПрав.Добавить();
		СтрокаПрава.ВидОбъекта    = ВидОбъекта;
		СтрокаПрава.ИмяОбъекта    = ИмяОбъекта;
		СтрокаПрава.ИмяПрава      = КлючЗначение.Ключ;
		СтрокаПрава.ЗначениеПрава = КлючЗначение.Значение = Истина;

	КонецЦикла;

КонецПроцедуры

// Добавляет строки ограничений доступа (RLS) в таблицу из структуры JSON {"ИмяПрава": "условие"}.
Процедура ЗаполнитьОграниченияИзСтруктурыJSON(ТаблицаОграничений, ВидОбъекта, ИмяОбъекта, RLSJSON)

	Для Каждого КлючЗначение Из RLSJSON Цикл

		СтрокаОгр = ТаблицаОграничений.Добавить();
		СтрокаОгр.ВидОбъекта        = ВидОбъекта;
		СтрокаОгр.ИмяОбъекта        = ИмяОбъекта;
		СтрокаОгр.ИмяПрава          = КлючЗначение.Ключ;
		СтрокаОгр.УсловиеОграничения = КлючЗначение.Значение;

	КонецЦикла;

КонецПроцедуры

// Добавляет набор прав с одним значением в таблицу прав модели.
Процедура ДобавитьПраваВТаблицу(ТаблицаПрав, ВидОбъекта, ИмяОбъекта, МассивИменПрав, ЗначениеПрава)

	Для Каждого ИмяПрава Из МассивИменПрав Цикл

		СтрокаПрава = ТаблицаПрав.Добавить();
		СтрокаПрава.ВидОбъекта    = ВидОбъекта;
		СтрокаПрава.ИмяОбъекта    = ИмяОбъекта;
		СтрокаПрава.ИмяПрава      = ИмяПрава;
		СтрокаПрава.ЗначениеПрава = ЗначениеПрава;

	КонецЦикла;

КонецПроцедуры

// Разбирает массив "templates" из JSON и заполняет таблицу шаблонов модели.
Процедура ЗаполнитьШаблоныИзJSON(МассивШаблоновJSON, ТаблицаШаблонов)

	Для Каждого ШаблонJSON Из МассивШаблоновJSON Цикл

		Если ТипЗнч(ШаблонJSON) <> Тип("Структура") Тогда
			Продолжить;
		КонецЕсли;

		ИмяШаблона = "";
		ТекстШаблона = "";

		Если Не ШаблонJSON.Свойство("name", ИмяШаблона) Или ПустаяСтрока(ИмяШаблона) Тогда
			Продолжить;
		КонецЕсли;

		ШаблонJSON.Свойство("condition", ТекстШаблона);

		СтрокаШаблона = ТаблицаШаблонов.Добавить();
		СтрокаШаблона.ИмяШаблона   = ИмяШаблона;
		СтрокаШаблона.ТекстШаблона = ТекстШаблона;

	КонецЦикла;

КонецПроцедуры

// Возвращает набор прав для пресета @view в зависимости от вида метаданных.
Функция ПресетВью(ВидМетаданных)

	Если ВидМетаданных = "Catalog" Или ВидМетаданных = "Document" Тогда
		Возврат СтрРазделить("Read,View,InputByString", ",");
	ИначеЕсли ВидМетаданных = "DataProcessor" Или ВидМетаданных = "Report" Тогда
		Возврат СтрРазделить("Use,View", ",");
	ИначеЕсли ВидМетаданных = "InformationRegister"
		Или ВидМетаданных = "AccumulationRegister"
		Или ВидМетаданных = "AccountingRegister"
		Или ВидМетаданных = "CalculationRegister" Тогда
		Возврат СтрРазделить("Read,View", ",");
	Иначе
		// Для остальных видов — первые два применимых права из реестра
		Возврат ПервыеПрименимыеПрава(ВидМетаданных, 2);
	КонецЕсли;

КонецФункции

// Возвращает набор прав для пресета @edit в зависимости от вида метаданных.
Функция ПресетЭдит(ВидМетаданных)

	Если ВидМетаданных = "Catalog" Тогда

		Возврат СтрРазделить(
			"Read,Insert,Update,Delete,View,Edit,InputByString,"
			+ "InteractiveInsert,InteractiveDelete,InteractiveDeleteMarked,"
			+ "InteractiveSetDeletionMark,InteractiveClearDeletionMark",
			",");

	ИначеЕсли ВидМетаданных = "Document" Тогда

		Возврат СтрРазделить(
			"Read,Insert,Update,Delete,View,Edit,InputByString,"
			+ "Posting,UndoPosting,"
			+ "InteractiveInsert,InteractiveDelete,InteractiveDeleteMarked,"
			+ "InteractiveSetDeletionMark,InteractiveClearDeletionMark,"
			+ "InteractivePosting,InteractiveUndoPosting,"
			+ "InteractivePostingRegular",
			",");

	ИначеЕсли ВидМетаданных = "InformationRegister"
		Или ВидМетаданных = "AccumulationRegister"
		Или ВидМетаданных = "AccountingRegister"
		Или ВидМетаданных = "CalculationRegister" Тогда

		Возврат СтрРазделить("Read,Update,View,Edit", ",");

	Иначе
		Возврат ПервыеПрименимыеПрава(ВидМетаданных, 4);
	КонецЕсли;

КонецФункции

// Возвращает первые N доступных прав для вида метаданных из реестра.
Функция ПервыеПрименимыеПрава(ВидМетаданных, КоличествоПрав)

	ОписаниеВида = цур_РеестрМетаданныхСерверПовтИсп.ОписаниеВида(ВидМетаданных);

	Если ОписаниеВида = Неопределено Тогда
		Возврат Новый Массив;
	КонецЕсли;

	Результат = Новый Массив;
	Для Каждого ИмяПрава Из ОписаниеВида.ДоступныеПрава Цикл

		Результат.Добавить(ИмяПрава);

		Если Результат.Количество() >= КоличествоПрав Тогда
			Прервать;
		КонецЕсли;

	КонецЦикла;

	Возврат Результат;

КонецФункции

// Фильтрует массив-кандидатов прав, оставляя только те, что есть в допустимых для вида.
Функция ОтфильтроватьПоДоступным(КандидатыПрав, ДоступныеПрава)

	Если ДоступныеПрава.Количество() = 0 Тогда
		Возврат КандидатыПрав; // реестр не найден — возвращаем без фильтрации
	КонецЕсли;

	ИндексДоступных = Новый Соответствие;
	Для Каждого Право Из ДоступныеПрава Цикл
		ИндексДоступных.Вставить(Право, Истина);
	КонецЦикла;

	Результат = Новый Массив;
	Для Каждого Право Из КандидатыПрав Цикл

		Если ИндексДоступных.Получить(Право) <> Неопределено Тогда
			Результат.Добавить(Право);
		КонецЕсли;

	КонецЦикла;

	Возврат Результат;

КонецФункции

// Извлекает вид метаданных из полного имени "Вид.Имя".
Функция ВидИзПолногоИмени(ПолноеИмя)

	ПозицияТочки = СтрНайти(ПолноеИмя, ".");
	Если ПозицияТочки = 0 Тогда
		Возврат ПолноеИмя;
	КонецЕсли;

	Возврат Лев(ПолноеИмя, ПозицияТочки - 1);

КонецФункции

// Извлекает имя объекта из полного имени "Вид.Имя".
Функция ИмяИзПолногоИмени(ПолноеИмя)

	ПозицияТочки = СтрНайти(ПолноеИмя, ".");
	Если ПозицияТочки = 0 Тогда
		Возврат "";
	КонецЕсли;

	Возврат Сред(ПолноеИмя, ПозицияТочки + 1);

КонецФункции

#КонецОбласти
