#Область ПрограммныйИнтерфейс

// Запускает фоновую генерацию расширения для переданных ролей и подключает
// обработчик ожидания на форме для отслеживания завершения.
//
// Параметры:
//  Форма                - ФормаКлиентскогоПриложения - форма-владелец операции,
//                         должна содержать реквизиты ИдентификаторЗадания, ТекстПрогресса
//                         и элемент ГруппаПрогресс
//  МассивСсылокРолей    - Массив из КаталогСсылка - список ролей для генерации
//
Асинх Процедура ОбработатьКомандуСгенерировать(Форма, МассивСсылокРолей) Экспорт

	ИнтервалПроверкиСек = 2;

	РезультатЗапуска = цур_ВызовСервера.СгенерироватьВФоне(МассивСсылокРолей, Форма.УникальныйИдентификатор);
	Форма.ИдентификаторЗадания = РезультатЗапуска.ИдентификаторЗадания;

	Форма.ПодключитьОбработчикОжидания("ПроверитьЗавершениеГенерации", ИнтервалПроверкиСек, Ложь);

	Форма.Элементы.ГруппаПрогресс.Видимость = Истина;
	Форма.ТекстПрогресса = "Генерация расширения...";

КонецПроцедуры

// Проверяет статус фонового задания генерации и обрабатывает его завершение.
// Вызывается по таймеру через ПодключитьОбработчикОжидания.
//
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - форма с реквизитом ИдентификаторЗадания
//
Асинх Процедура ПроверитьЗавершениеГенерации(Форма) Экспорт

	Результат = цур_ВызовСервера.ПолучитьСтатусФоновогоЗадания(Форма.ИдентификаторЗадания);

	Если НЕ Результат.Завершено Тогда
		Возврат;
	КонецЕсли;

	Форма.ОтключитьОбработчикОжидания("ПроверитьЗавершениеГенерации");
	Форма.Элементы.ГруппаПрогресс.Видимость = Ложь;

	Если Результат.Результат.Успешно Тогда
		ПоказатьОповещениеПользователя("Генерация завершена", , "Расширение успешно создано");
	Иначе
		Ждать ПоказатьПредупреждениеАсинх(Результат.Результат.ТекстОшибки);
	КонецЕсли;

КонецПроцедуры

// Показывает меню выбора источника прав и инициирует заполнение прав
// из выбранного источника (роль, профиль групп доступа, пользователь).
//
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - форма с таблицей прав
//
Асинх Процедура ОбработатьВыборИсточникаПрав(Форма) Экспорт

	МенюВыбора = Новый СписокЗначений;
	МенюВыбора.Добавить("Роль",           "Из роли конфигурации");
	МенюВыбора.Добавить("Профиль",        "Из профиля групп доступа");
	МенюВыбора.Добавить("Пользователь",   "Из прав пользователя");

	ВыбранныйЭлемент = Ждать ПоказатьВыборИзМенюАсинх(МенюВыбора);

	Если ВыбранныйЭлемент = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ТипИсточника = ВыбранныйЭлемент.Значение;

	ПараметрыФормы = Новый Структура("РежимВыбора", Истина);
	ИмяОбъекта    = "";

	Если ТипИсточника = "Роль" Тогда

		ВыбраннаяРоль = Ждать ОткрытьФормуАсинх("Справочник.Роли.ФормаВыбора", ПараметрыФормы, Форма);
		Если ВыбраннаяРоль = Неопределено Тогда
			Возврат;
		КонецЕсли;
		ИмяОбъекта = ВыбраннаяРоль;

	ИначеЕсли ТипИсточника = "Профиль" Тогда

		ВыбранныйПрофиль = Ждать ОткрытьФормуАсинх(
			"Справочник.ПрофилиГруппДоступа.ФормаВыбора", ПараметрыФормы, Форма);
		Если ВыбранныйПрофиль = Неопределено Тогда
			Возврат;
		КонецЕсли;
		ИмяОбъекта = ВыбранныйПрофиль;

	ИначеЕсли ТипИсточника = "Пользователь" Тогда

		ВыбранныйПользователь = Ждать ОткрытьФормуАсинх(
			"Справочник.Пользователи.ФормаВыбора", ПараметрыФормы, Форма);
		Если ВыбранныйПользователь = Неопределено Тогда
			Возврат;
		КонецЕсли;
		ИмяОбъекта = ВыбранныйПользователь;

	Иначе
		Возврат;
	КонецЕсли;

	цур_ВызовСервера.ЗаполнитьПраваИзИсточника(Форма.Объект.Ссылка, ИмяОбъекта, ТипИсточника);

	ОбновитьОтображениеПрав(Форма, ТипИсточника, ИмяОбъекта);

КонецПроцедуры

// Загружает права объекта с сервера и заполняет таблицу прав на форме.
//
// Параметры:
//  Форма       - ФормаКлиентскогоПриложения - форма с таблицей ТаблицаПрав
//  ВидОбъекта  - Строка - тип объекта (например, "Справочник", "Документ")
//  ИмяОбъекта  - Строка - имя объекта метаданных
//
Процедура ОбновитьОтображениеПрав(Форма, ВидОбъекта, ИмяОбъекта) Экспорт

	ТаблицаПрав = цур_ВызовСервера.ПолучитьПраваОбъекта(ВидОбъекта, ИмяОбъекта);
	Форма.ТаблицаПрав.Загрузить(ТаблицаПрав);

КонецПроцедуры

// Обрабатывает выбор строки объекта в дереве метаданных -
// загружает права выбранного объекта и отображает их в таблице формы.
//
// Параметры:
//  Форма          - ФормаКлиентскогоПриложения - форма с деревом и таблицей прав
//  ТекущаяСтрока  - СтрокаДереваЗначений - выбранная строка дерева,
//                   должна содержать поля ВидОбъекта и ИмяОбъекта
//
Процедура ОбработатьВыборОбъектаДерева(Форма, ТекущаяСтрока) Экспорт

	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(ТекущаяСтрока.ВидОбъекта) Тогда
		Возврат;
	КонецЕсли;

	ОбновитьОтображениеПрав(Форма, ТекущаяСтрока.ВидОбъекта, ТекущаяСтрока.ИмяОбъекта);

КонецПроцедуры

// Сохраняет изменение права доступа, инициированное пользователем через чекбокс.
//
// Параметры:
//  Форма    - ФормаКлиентскогоПриложения - форма с таблицей прав
//  Элемент  - ЭлементФормы - элемент-чекбокс, у которого изменилось значение;
//             текущая строка таблицы должна содержать поля ВидОбъекта, ИмяОбъекта,
//             ИмяПрава, Значение
//
Процедура ОбработатьИзменениеПрава(Форма, Элемент) Экспорт

	ТекущаяСтрока = Форма.Элементы.ТаблицаПрав.ТекущиеДанные;

	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;

	цур_ВызовСервера.ЗаписатьПравоДоступа(
		ТекущаяСтрока.ВидОбъекта,
		ТекущаяСтрока.ИмяОбъекта,
		ТекущаяСтрока.ИмяПрава,
		ТекущаяСтрока.Значение);

КонецПроцедуры

#КонецОбласти
