#Область ПрограммныйИнтерфейс

// Возвращает пустую структуру параметров роли (конструктор модели).
//
// Возвращаемое значение:
//  Структура - шаблон модели роли:
//    * Имя                                   - Строка   - программное имя роли в конфигурации
//    * Синоним                               - Строка   - синоним роли
//    * Комментарий                           - Строка   - комментарий к роли
//    * УстанавливатьДляНовыхОбъектов         - Булево   - флаг setForNewObjects
//    * УстанавливатьДляРеквизитовПоУмолчанию - Булево   - флаг setForAttributesByDefault
//    * НезависимыеПраваПодчиненных           - Булево   - флаг independentRightsOfChildObjects
//    * Права                                 - ТаблицаЗначений - права доступа объектов
//    * Ограничения                           - ТаблицаЗначений - ограничения доступа к данным (RLS)
//    * Шаблоны                               - ТаблицаЗначений - шаблоны ограничений
//    * Подсистемы                            - Массив          - полные имена подсистем
//
Функция НовыеПараметрыРоли() Экспорт

	Модель = Новый Структура;
	Модель.Вставить("Имя",                                   "");
	Модель.Вставить("Синоним",                               "");
	Модель.Вставить("Комментарий",                           "");
	Модель.Вставить("УстанавливатьДляНовыхОбъектов",         Ложь);
	Модель.Вставить("УстанавливатьДляРеквизитовПоУмолчанию", Истина);
	Модель.Вставить("НезависимыеПраваПодчиненных",           Ложь);
	Модель.Вставить("Права",        НоваяТаблицаПрав());
	Модель.Вставить("Ограничения",  НоваяТаблицаОграничений());
	Модель.Вставить("Шаблоны",      НоваяТаблицаШаблонов());
	Модель.Вставить("Подсистемы",   Новый Массив);

	Возврат Модель;

КонецФункции

// Читает данные роли из справочника и четырёх регистров в единую модель.
// Использует пакетный запрос для минимизации обращений к базе.
//
// Параметры:
//  СсылкаРоли - СправочникСсылка.цур_Роли - ссылка на элемент справочника ролей
//
// Возвращаемое значение:
//  Структура - заполненная модель роли, см. НовыеПараметрыРоли()
//
Функция НормализоватьРоль(СсылкаРоли) Экспорт

	Модель = НовыеПараметрыРоли();

	МенеджерВТ = Новый МенеджерВременныхТаблиц;

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВТ;
	Запрос.УстановитьПараметр("Роль", СсылкаРоли);

	Запрос.Текст =
	"ВЫБРАТЬ
	|	цур_Роли.ИмяРолиВКонфигурации                 КАК ИмяРолиВКонфигурации,
	|	цур_Роли.Наименование                          КАК Наименование,
	|	цур_Роли.Комментарий                           КАК Комментарий,
	|	цур_Роли.УстанавливатьДляНовыхОбъектов         КАК УстанавливатьДляНовыхОбъектов,
	|	цур_Роли.УстанавливатьДляРеквизитовПоУмолчанию КАК УстанавливатьДляРеквизитовПоУмолчанию,
	|	цур_Роли.НезависимыеПраваПодчиненных           КАК НезависимыеПраваПодчиненных
	|ИЗ
	|	Справочник.цур_Роли КАК цур_Роли
	|ГДЕ
	|	цур_Роли.Ссылка = &Роль
	|;
	|
	|ВЫБРАТЬ
	|	РС.ВидОбъекта     КАК ВидОбъекта,
	|	РС.ИмяОбъекта     КАК ИмяОбъекта,
	|	РС.ИмяПрава       КАК ИмяПрава,
	|	РС.ТипРеквизита   КАК ТипРеквизита,
	|	РС.ИмяРеквизита   КАК ИмяРеквизита,
	|	РС.ИмяРеквизитаТЧ КАК ИмяРеквизитаТЧ,
	|	РС.ЗначениеПрава  КАК ЗначениеПрава
	|ИЗ
	|	РегистрСведений.цур_ПраваДоступа КАК РС
	|ГДЕ
	|	РС.Роль = &Роль
	|;
	|
	|ВЫБРАТЬ
	|	РС.ВидОбъекта         КАК ВидОбъекта,
	|	РС.ИмяОбъекта         КАК ИмяОбъекта,
	|	РС.ИмяПрава           КАК ИмяПрава,
	|	РС.УсловиеОграничения КАК УсловиеОграничения,
	|	РС.Поля               КАК Поля
	|ИЗ
	|	РегистрСведений.цур_ОграниченияДоступа КАК РС
	|ГДЕ
	|	РС.Роль = &Роль
	|;
	|
	|ВЫБРАТЬ
	|	РС.ИмяШаблона   КАК ИмяШаблона,
	|	РС.ТекстШаблона КАК ТекстШаблона
	|ИЗ
	|	РегистрСведений.цур_ШаблоныОграничений КАК РС
	|ГДЕ
	|	РС.Роль = &Роль
	|;
	|
	|ВЫБРАТЬ
	|	РС.ПолноеИмяПодсистемы КАК ПолноеИмяПодсистемы
	|ИЗ
	|	РегистрСведений.цур_ПодсистемыРолей КАК РС
	|ГДЕ
	|	РС.Роль = &Роль";

	РезультатыПакета = Запрос.ВыполнитьПакет();

	ЗаполнитьМодельИзЗапроса(Модель, РезультатыПакета);

	Возврат Модель;

КонецФункции

// Проверяет корректность модели роли.
//
// Параметры:
//  МодельРоли - Структура - модель роли, см. НовыеПараметрыРоли()
//
// Возвращаемое значение:
//  Структура - результат валидации:
//    * Успешно - Булево  - Истина, если ошибок не найдено
//    * Ошибки  - Массив  - список строк с описанием найденных ошибок
//
Функция ВалидироватьРоль(МодельРоли) Экспорт

	Ошибки = Новый Массив;

	ПроверитьИмяРоли(МодельРоли.Имя, Ошибки);
	ПроверитьПраваНаДубликаты(МодельРоли.Права, Ошибки);
	ПроверитьВидыМетаданных(МодельРоли.Права, Ошибки);
	ПроверитьВидыМетаданных(МодельРоли.Ограничения, Ошибки);

	Результат = Новый Структура;
	Результат.Вставить("Успешно", Ошибки.Количество() = 0);
	Результат.Вставить("Ошибки",  Ошибки);

	Возврат Результат;

КонецФункции

// Нормализует и валидирует пакет ролей одним запросом к базе данных.
// Вместо N*5 запросов выполняет 1 пакетный запрос для всего набора ролей.
//
// Параметры:
//  МассивСсылокРолей - Массив - массив СправочникСсылка.цур_Роли
//
// Возвращаемое значение:
//  Массив - массив структур-моделей ролей (только успешно прошедших валидацию)
//
Функция ПодготовитьПакетРолей(МассивСсылокРолей) Экспорт

	Если МассивСсылокРолей.Количество() = 0 Тогда
		Возврат Новый Массив;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("СписокРолей", МассивСсылокРолей);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Роли.Ссылка                            КАК Ссылка,
	|	Роли.Наименование                      КАК Наименование,
	|	Роли.ИмяРолиВКонфигурации              КАК ИмяРолиВКонфигурации,
	|	Роли.Комментарий                       КАК Комментарий,
	|	Роли.УстанавливатьДляНовыхОбъектов     КАК УстанавливатьДляНовыхОбъектов,
	|	Роли.УстанавливатьДляРеквизитовПоУмолчанию КАК УстанавливатьДляРеквизитовПоУмолчанию,
	|	Роли.НезависимыеПраваПодчиненных       КАК НезависимыеПраваПодчиненных
	|ИЗ
	|	Справочник.цур_Роли КАК Роли
	|ГДЕ
	|	Роли.Ссылка В (&СписокРолей)
	|;
	|ВЫБРАТЬ
	|	Права.Роль            КАК Роль,
	|	Права.ВидОбъекта      КАК ВидОбъекта,
	|	Права.ИмяОбъекта      КАК ИмяОбъекта,
	|	Права.ИмяПрава        КАК ИмяПрава,
	|	Права.ТипРеквизита    КАК ТипРеквизита,
	|	Права.ИмяРеквизита    КАК ИмяРеквизита,
	|	Права.ИмяРеквизитаТЧ  КАК ИмяРеквизитаТЧ,
	|	Права.ЗначениеПрава   КАК ЗначениеПрава
	|ИЗ
	|	РегистрСведений.цур_ПраваДоступа КАК Права
	|ГДЕ
	|	Права.Роль В (&СписокРолей)
	|;
	|ВЫБРАТЬ
	|	Ограничения.Роль               КАК Роль,
	|	Ограничения.ВидОбъекта         КАК ВидОбъекта,
	|	Ограничения.ИмяОбъекта         КАК ИмяОбъекта,
	|	Ограничения.ИмяПрава           КАК ИмяПрава,
	|	Ограничения.УсловиеОграничения КАК УсловиеОграничения,
	|	Ограничения.Поля               КАК Поля
	|ИЗ
	|	РегистрСведений.цур_ОграниченияДоступа КАК Ограничения
	|ГДЕ
	|	Ограничения.Роль В (&СписокРолей)
	|;
	|ВЫБРАТЬ
	|	Шаблоны.Роль          КАК Роль,
	|	Шаблоны.ИмяШаблона    КАК ИмяШаблона,
	|	Шаблоны.ТекстШаблона  КАК ТекстШаблона
	|ИЗ
	|	РегистрСведений.цур_ШаблоныОграничений КАК Шаблоны
	|ГДЕ
	|	Шаблоны.Роль В (&СписокРолей)
	|;
	|ВЫБРАТЬ
	|	Подсистемы.Роль                КАК Роль,
	|	Подсистемы.ПолноеИмяПодсистемы КАК ПолноеИмяПодсистемы
	|ИЗ
	|	РегистрСведений.цур_ПодсистемыРолей КАК Подсистемы
	|ГДЕ
	|	Подсистемы.Роль В (&СписокРолей)";

	РезультатыПакета = Запрос.ВыполнитьПакет();

	// Индексы для группировки данных по ссылке роли: Соответствие<Ссылка, ТаблицаЗначений>
	ИндексПрав        = СгруппироватьВыборкуПоРоли(РезультатыПакета[1]);
	ИндексОграничений = СгруппироватьВыборкуПоРоли(РезультатыПакета[2]);
	ИндексШаблонов    = СгруппироватьВыборкуПоРоли(РезультатыПакета[3]);
	ИндексПодсистем   = СгруппироватьВыборкуПоРоли(РезультатыПакета[4]);

	// Собрать модели по данным справочника
	МассивМоделей = Новый Массив;

	ВыборкаРолей = РезультатыПакета[0].Выбрать();
	Пока ВыборкаРолей.Следующий() Цикл

		Модель = СобратьМодельИзИндексов(
			ВыборкаРолей,
			ИндексПрав,
			ИндексОграничений,
			ИндексШаблонов,
			ИндексПодсистем);

		МассивМоделей.Добавить(Модель);

	КонецЦикла;

	Возврат МассивМоделей;

КонецФункции

// Читает XML прав из регистра цур_XMLРолейКонфигурации и заполняет регистры прав,
// ограничений и шаблонов для указанной роли.
//
// Параметры:
//  СсылкаРоли          - СправочникСсылка.цур_Роли - ссылка на роль в справочнике
//  ИмяРолиКонфигурации - Строка - имя роли в конфигурации (ключ регистра цур_XMLРолейКонфигурации)
//
Процедура ЗаполнитьПраваИзРолиКонфигурации(СсылкаРоли, ИмяРолиКонфигурации) Экспорт

	XMLТекст = ПолучитьXMLРолиИзРегистра(ИмяРолиКонфигурации);

	Если ПустаяСтрока(XMLТекст) Тогда
		ВызватьИсключение НСтр("ru = 'XML текст роли не найден в регистре цур_XMLРолейКонфигурации.'");
	КонецЕсли;

	Модель = НовыеПараметрыРоли();
	ПрочитатьМодельИзXML(ИмяРолиКонфигурации, XMLТекст, Модель);

	ЗаписатьПраваРоли(
		СсылкаРоли,
		Модель.Права,
		Модель.Ограничения,
		Модель.Шаблоны,
		Модель.Подсистемы);

КонецПроцедуры

// Собирает права из всех ролей пользователя ИБ и записывает их для роли-агрегата.
// Объединение прав выполняется по правилу OR (право = Истина, если хотя бы одна роль разрешает).
//
// Параметры:
//  СсылкаРоли      - СправочникСсылка.цур_Роли - ссылка на роль-агрегат
//  ИмяПользователя - Строка - имя пользователя информационной базы
//
Процедура ЗаполнитьПраваИзПользователя(СсылкаРоли, ИмяПользователя) Экспорт

	ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоИмени(ИмяПользователя);
	Если ПользовательИБ = Неопределено Тогда
		ВызватьИсключение СтрШаблон(
			НСтр("ru = 'Пользователь ""%1"" не найден.'"),
			ИмяПользователя);
	КонецЕсли;

	МассивРолей = Новый Массив;
	Для Каждого Роль Из ПользовательИБ.Роли Цикл
		МассивРолей.Добавить(Роль.Имя);
	КонецЦикла;

	МодельАгрегат = ОбъединитьПраваРолей(МассивРолей);

	ЗаписатьПраваРоли(
		СсылкаРоли,
		МодельАгрегат.Права,
		МодельАгрегат.Ограничения,
		МодельАгрегат.Шаблоны,
		МодельАгрегат.Подсистемы);

КонецПроцедуры

// Собирает права из ролей профиля (по имени профиля) и записывает их для роли-агрегата.
// Объединение прав выполняется по правилу OR.
// Поиск профиля выполняется через справочник ПрофилиГруппДоступа (при наличии)
// или интерпретируется как имя роли конфигурации (без БСП).
//
// Параметры:
//  СсылкаРоли - СправочникСсылка.цур_Роли - ссылка на роль-агрегат
//  ИмяПрофиля - Строка - строковое имя профиля
//
Процедура ЗаполнитьПраваИзПрофиля(СсылкаРоли, СсылкаПрофиля) Экспорт

	МассивРолей = ПолучитьРолиПрофиля(СсылкаПрофиля);

	Если МассивРолей.Количество() = 0 Тогда
		ВызватьИсключение СтрШаблон(
			НСтр("ru = 'Профиль ""%1"" не содержит ролей или не найден.'"),
			СсылкаПрофиля);
	КонецЕсли;

	МодельАгрегат = ОбъединитьПраваРолей(МассивРолей);

	ЗаписатьПраваРоли(
		СсылкаРоли,
		МодельАгрегат.Права,
		МодельАгрегат.Ограничения,
		МодельАгрегат.Шаблоны,
		МодельАгрегат.Подсистемы);

КонецПроцедуры

// Очищает старые записи и записывает новые права роли в регистры в рамках одной транзакции.
//
// ВАЖНО: Вызывающий код обязан предварительно провалидировать данные через ВалидироватьРоль().
//
// Параметры:
//  СсылкаРоли         - СправочникСсылка.цур_Роли - ссылка на роль
//  ТаблицаПрав        - ТаблицаЗначений - права доступа (колонки: ВидОбъекта, ИмяОбъекта,
//                       ИмяПрава, ТипРеквизита, ИмяРеквизита, ИмяРеквизитаТЧ, ЗначениеПрава)
//  ТаблицаОграничений - ТаблицаЗначений - ограничения (колонки: ВидОбъекта, ИмяОбъекта,
//                       ИмяПрава, УсловиеОграничения)
//  ТаблицаШаблонов    - ТаблицаЗначений - шаблоны (колонки: ИмяШаблона, ТекстШаблона)
//  МассивПодсистем    - Массив - массив строк с полными именами подсистем
//
Процедура ЗаписатьПраваРоли(
		СсылкаРоли,
		ТаблицаПрав,
		ТаблицаОграничений,
		ТаблицаШаблонов,
		МассивПодсистем) Экспорт

	НачатьТранзакцию();
	Попытка

		ЗаписатьТаблицуВРегистрПрав(СсылкаРоли, ТаблицаПрав);
		ЗаписатьТаблицуВРегистрОграничений(СсылкаРоли, ТаблицаОграничений);
		ЗаписатьТаблицуВРегистрШаблонов(СсылкаРоли, ТаблицаШаблонов);
		ЗаписатьПодсистемыРоли(СсылкаРоли, МассивПодсистем);

		ЗафиксироватьТранзакцию();

	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

// Возвращает модель прав роли конфигурации без записи в регистры.
// Используется для заполнения дерева формы напрямую.
//
// Параметры:
//  ИмяРолиКонфигурации - Строка - имя роли в конфигурации (ключ регистра цур_XMLРолейКонфигурации)
//
// Возвращаемое значение:
//  Структура - модель роли, см. НовыеПараметрыРоли()
//
Функция ПолучитьМодельРолиКонфигурации(ИмяРолиКонфигурации) Экспорт

	XMLТекст = ПолучитьXMLРолиИзРегистра(ИмяРолиКонфигурации);

	Если ПустаяСтрока(XMLТекст) Тогда
		ВызватьИсключение НСтр("ru = 'XML текст роли не найден в регистре цур_XMLРолейКонфигурации.'");
	КонецЕсли;

	Модель = НовыеПараметрыРоли();
	ПрочитатьМодельИзXML(ИмяРолиКонфигурации, XMLТекст, Модель);

	Возврат Модель;

КонецФункции

// Возвращает объединённую модель прав из ролей профиля без записи в регистры.
//
// Параметры:
//  СсылкаПрофиля - СправочникСсылка - ссылка на профиль групп доступа
//
// Возвращаемое значение:
//  Структура - модель роли, см. НовыеПараметрыРоли()
//
Функция ПолучитьМодельПрофиля(СсылкаПрофиля) Экспорт

	МассивРолей = ПолучитьРолиПрофиля(СсылкаПрофиля);

	Если МассивРолей.Количество() = 0 Тогда
		ВызватьИсключение СтрШаблон(
			НСтр("ru = 'Профиль ""%1"" не содержит ролей или не найден.'"),
			СсылкаПрофиля);
	КонецЕсли;

	Возврат ОбъединитьПраваРолей(МассивРолей);

КонецФункции

// Возвращает объединённую модель прав из ролей пользователя ИБ без записи в регистры.
//
// Параметры:
//  ИмяПользователя - Строка - имя пользователя информационной базы
//
// Возвращаемое значение:
//  Структура - модель роли, см. НовыеПараметрыРоли()
//
Функция ПолучитьМодельПользователя(ИмяПользователя) Экспорт

	ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоИмени(ИмяПользователя);

	Если ПользовательИБ = Неопределено Тогда
		ВызватьИсключение СтрШаблон(
			НСтр("ru = 'Пользователь ""%1"" не найден.'"),
			ИмяПользователя);
	КонецЕсли;

	МассивРолей = Новый Массив;

	Для Каждого Роль Из ПользовательИБ.Роли Цикл
		МассивРолей.Добавить(Роль.Имя);
	КонецЦикла;

	Возврат ОбъединитьПраваРолей(МассивРолей);

КонецФункции

// Возвращает объединённую модель прав пользователя на основе профилей групп доступа БСП.
// Цепочка: Пользователь → ГруппыДоступа (ТЧ Пользователи) → Профиль → Роли профиля.
//
// Параметры:
//  СсылкаПользователя - СправочникСсылка - ссылка на элемент справочника Пользователи
//
// Возвращаемое значение:
//  Структура - модель роли, см. НовыеПараметрыРоли()
//
Функция ПолучитьМодельПользователяБСП(СсылкаПользователя) Экспорт

	Если Метаданные.НайтиПоПолномуИмени("Справочник.ГруппыДоступа") = Неопределено Тогда
		ВызватьИсключение НСтр("ru = 'Справочник ""ГруппыДоступа"" не найден. Подсистема управления доступом БСП не подключена.'");
	КонецЕсли;

	МассивРолей = ПолучитьРолиПользователяЧерезПрофили(СсылкаПользователя);

	Если МассивРолей.Количество() = 0 Тогда
		ВызватьИсключение НСтр("ru = 'У пользователя нет ролей через профили групп доступа.'");
	КонецЕсли;

	Возврат ОбъединитьПраваРолей(МассивРолей);

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

