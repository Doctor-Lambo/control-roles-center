// Записывает набор прав в регистр цур_ПраваДоступа (очистка + запись).
Процедура ЗаписатьТаблицуВРегистрПрав(СсылкаРоли, ТаблицаПрав)

	НаборЗаписей = РегистрыСведений.цур_ПраваДоступа.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Роль.Установить(СсылкаРоли);

	Для Каждого Строка Из ТаблицаПрав Цикл
		НоваяЗапись = НаборЗаписей.Добавить();
		НоваяЗапись.Роль             = СсылкаРоли;
		НоваяЗапись.ВидОбъекта       = Строка.ВидОбъекта;
		НоваяЗапись.ИмяОбъекта       = Строка.ИмяОбъекта;
		НоваяЗапись.ИмяПрава         = Строка.ИмяПрава;
		НоваяЗапись.ТипРеквизита     = Строка.ТипРеквизита;
		НоваяЗапись.ИмяРеквизита     = Строка.ИмяРеквизита;
		НоваяЗапись.ИмяРеквизитаТЧ   = Строка.ИмяРеквизитаТЧ;
		НоваяЗапись.ЗначениеПрава    = Строка.ЗначениеПрава;
	КонецЦикла;

	НаборЗаписей.Записать();

