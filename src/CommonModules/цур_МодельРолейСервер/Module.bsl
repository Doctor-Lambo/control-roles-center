// Заполняет поля модели из результатов пакетного запроса (5 запросов).
//
// Параметры:
//  Модель           - Структура                   - модель роли для заполнения
//  РезультатыПакета - МассивРезультатовЗапроса - массив из 5 результатов:
//                     [0] - справочник цур_Роли,
//                     [1] - регистр цур_ПраваДоступа,
//                     [2] - регистр цур_ОграниченияДоступа,
//                     [3] - регистр цур_ШаблоныОграничений,
//                     [4] - регистр цур_ПодсистемыРолей
//
Процедура ЗаполнитьМодельИзЗапроса(Модель, РезультатыПакета)

	// Запрос 0: реквизиты справочника
	Если Не РезультатыПакета[0].Пустой() Тогда
		Выборка = РезультатыПакета[0].Выбрать();
		Выборка.Следующий();
		Модель.Имя                                    = Выборка.ИмяРолиВКонфигурации;
		Модель.Синоним                                = Выборка.Наименование;
		Модель.Комментарий                            = Выборка.Комментарий;
		Модель.УстанавливатьДляНовыхОбъектов          = Выборка.УстанавливатьДляНовыхОбъектов;
		Модель.УстанавливатьДляРеквизитовПоУмолчанию  = Выборка.УстанавливатьДляРеквизитовПоУмолчанию;
		Модель.НезависимыеПраваПодчиненных             = Выборка.НезависимыеПраваПодчиненных;
	КонецЕсли;

	// Запросы 1-3: выгрузка в таблицы значений
	Модель.Права        = РезультатыПакета[1].Выгрузить();
	Модель.Ограничения  = РезультатыПакета[2].Выгрузить();
	Модель.Шаблоны      = РезультатыПакета[3].Выгрузить();

	// Запрос 4: подсистемы
	ВыборкаПодсистем = РезультатыПакета[4].Выбрать();
	Пока ВыборкаПодсистем.Следующий() Цикл
		Модель.Подсистемы.Добавить(ВыборкаПодсистем.ПолноеИмяПодсистемы);
	КонецЦикла;

КонецПроцедуры

// Проверяет имя роли: должно быть заполнено и содержать только латинские буквы, цифры и знак _.
Процедура ПроверитьИмяРоли(ИмяРоли, Ошибки)

	Если ПустаяСтрока(ИмяРоли) Тогда
		Ошибки.Добавить(НСтр("ru = 'Не заполнено имя роли в конфигурации.'"));
		Возврат;
	КонецЕсли;

	Для Ном = 1 По СтрДлина(ИмяРоли) Цикл
		Символ     = Сред(ИмяРоли, Ном, 1);
		КодСимвола = КодСимвола(Символ);

		ЭтоБукваЛат      = (КодСимвола >= 65 И КодСимвола <= 90)
			Или (КодСимвола >= 97 И КодСимвола <= 122);
		ЭтоЦифра         = КодСимвола >= 48 И КодСимвола <= 57;
		ЭтоПодчеркивание = КодСимвола = 95;

		Если Не (ЭтоБукваЛат Или ЭтоЦифра Или ЭтоПодчеркивание) Тогда
			Ошибки.Добавить(СтрШаблон(
				НСтр("ru = 'Имя роли ""%1"" содержит недопустимый символ ""%2"" (позиция %3).'"),
				ИмяРоли, Символ, Ном));
			Возврат;
		КонецЕсли;

	КонецЦикла;

КонецПроцедуры

// Проверяет отсутствие дублирующихся записей прав по ключу ВидОбъекта+ИмяОбъекта+ИмяПрава+ТипРеквизита+ИмяРеквизита.
Процедура ПроверитьПраваНаДубликаты(ТаблицаПрав, Ошибки)

	ИндексДубликатов = Новый Соответствие;

	Для Каждого Строка Из ТаблицаПрав Цикл
		Ключ = СтрШаблон("%1|%2|%3|%4|%5",
			Строка.ВидОбъекта,
			Строка.ИмяОбъекта,
			Строка.ИмяПрава,
			Строка.ТипРеквизита,
			Строка.ИмяРеквизита);

		Если ИндексДубликатов.Получить(Ключ) <> Неопределено Тогда
			Ошибки.Добавить(СтрШаблон(
				НСтр("ru = 'Дублирующееся право: объект ""%1.%2"", право ""%3"".'"),
				Строка.ВидОбъекта, Строка.ИмяОбъекта, Строка.ИмяПрава));
		Иначе
			ИндексДубликатов.Вставить(Ключ, Истина);
		КонецЕсли;

	КонецЦикла;

КонецПроцедуры

// Проверяет, что виды метаданных из таблицы прав/ограничений существуют в реестре.
// Ожидает колонку ВидОбъекта в таблице.
//
// Параметры:
//  Таблица - ТаблицаЗначений - таблица прав или ограничений
//  Ошибки  - Массив          - массив строк для добавления найденных ошибок
//
Процедура ПроверитьВидыМетаданных(Таблица, Ошибки)

	МассивВидов = цур_РеестрМетаданныхСерверПовтИсп.ВсеВидыМетаданных();

	ДопустимыеВиды = Новый Соответствие;
	Для Каждого Вид Из МассивВидов Цикл
		ДопустимыеВиды.Вставить(Вид.ВидМетаданных, Истина);
	КонецЦикла;

	ПроверенныеВиды = Новый Соответствие;

	Для Каждого Строка Из Таблица Цикл
		ВидОбъекта = Строка.ВидОбъекта;

		Если ПустаяСтрока(ВидОбъекта) Тогда
			Продолжить;
		КонецЕсли;

		Если ПроверенныеВиды.Получить(ВидОбъекта) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;

		ПроверенныеВиды.Вставить(ВидОбъекта, Истина);

		Если ДопустимыеВиды.Получить(ВидОбъекта) = Неопределено Тогда
			Ошибки.Добавить(СтрШаблон(
				НСтр("ru = 'Вид метаданных ""%1"" не найден в реестре видов метаданных.'"),
				ВидОбъекта));
		КонецЕсли;

	КонецЦикла;

КонецПроцедуры

// Группирует выборку результата запроса по колонке Роль.
// Возвращает Соответствие<СправочникСсылка.цур_Роли, ТаблицаЗначений>.
// Используется для O(1)-доступа при сборке пакетных моделей.
//
// Параметры:
//  РезультатЗапроса - РезультатЗапроса - результат запроса с колонкой Роль
//
// Возвращаемое значение:
//  Соответствие - ключ: ссылка на роль, значение: таблица строк этой роли
//
Функция СгруппироватьВыборкуПоРоли(РезультатЗапроса)

	Индекс    = Новый Соответствие;
	Выгрузка  = РезультатЗапроса.Выгрузить();

	Для Каждого Строка Из Выгрузка Цикл

		Ссылка = Строка.Роль;
		ТаблицаРоли = Индекс.Получить(Ссылка);

		Если ТаблицаРоли = Неопределено Тогда
			ТаблицаРоли = Выгрузка.СкопироватьКолонки();
			Индекс.Вставить(Ссылка, ТаблицаРоли);
		КонецЕсли;

		ЗаполнитьЗначенияСвойств(ТаблицаРоли.Добавить(), Строка);

	КонецЦикла;

	Возврат Индекс;

КонецФункции

// Собирает модель роли из предварительно сгруппированных индексов пакетного запроса.
// Ожидает, что курсор ВыборкаРолей уже позиционирован на нужной строке.
//
// Параметры:
//  ВыборкаРолей      - ВыборкаИзРезультатаЗапроса - текущая строка справочника
//  ИндексПрав        - Соответствие - сгруппированные права по ссылке роли
//  ИндексОграничений - Соответствие - сгруппированные ограничения по ссылке роли
//  ИндексШаблонов    - Соответствие - сгруппированные шаблоны по ссылке роли
//  ИндексПодсистем   - Соответствие - сгруппированные подсистемы по ссылке роли
//
// Возвращаемое значение:
//  Структура - заполненная модель роли, см. НовыеПараметрыРоли()
//
Функция СобратьМодельИзИндексов(
		ВыборкаРолей,
		ИндексПрав,
		ИндексОграничений,
		ИндексШаблонов,
		ИндексПодсистем)

	Модель = НовыеПараметрыРоли();

	Модель.Имя                                   = ВыборкаРолей.ИмяРолиВКонфигурации;
	Модель.Синоним                               = ВыборкаРолей.Наименование;
	Модель.Комментарий                           = ВыборкаРолей.Комментарий;
	Модель.УстанавливатьДляНовыхОбъектов         = ВыборкаРолей.УстанавливатьДляНовыхОбъектов;
	Модель.УстанавливатьДляРеквизитовПоУмолчанию = ВыборкаРолей.УстанавливатьДляРеквизитовПоУмолчанию;
	Модель.НезависимыеПраваПодчиненных           = ВыборкаРолей.НезависимыеПраваПодчиненных;

	Ссылка = ВыборкаРолей.Ссылка;

	ТаблицаПрав = ИндексПрав.Получить(Ссылка);
	Если ТаблицаПрав <> Неопределено Тогда
		Модель.Права = ТаблицаПрав;
	КонецЕсли;

	ТаблицаОграничений = ИндексОграничений.Получить(Ссылка);
	Если ТаблицаОграничений <> Неопределено Тогда
		Модель.Ограничения = ТаблицаОграничений;
	КонецЕсли;

	ТаблицаШаблонов = ИндексШаблонов.Получить(Ссылка);
	Если ТаблицаШаблонов <> Неопределено Тогда
		Модель.Шаблоны = ТаблицаШаблонов;
	КонецЕсли;

	СтрокиПодсистем = ИндексПодсистем.Получить(Ссылка);
	Если СтрокиПодсистем <> Неопределено Тогда
		Для Каждого СтрокаПодсистемы Из СтрокиПодсистем Цикл
			Модель.Подсистемы.Добавить(СтрокаПодсистемы.ПолноеИмяПодсистемы);
		КонецЦикла;
	КонецЕсли;

	Возврат Модель;

КонецФункции

// Читает XML текст всех ролей из регистра цур_XMLРолейКонфигурации одним запросом.
//
// Параметры:
//  МассивИмен - Массив - массив строк с именами ролей конфигурации
//
// Возвращаемое значение:
//  Соответствие - ключ: имя роли (Строка), значение: XML текст (Строка)
//
Функция ПолучитьXMLРолейПакетом(МассивИмен)

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	XMLРолей.ИмяРоли  КАК ИмяРоли,
	|	XMLРолей.XMLТекст КАК XMLТекст
	|ИЗ
	|	РегистрСведений.цур_XMLРолейКонфигурации КАК XMLРолей
	|ГДЕ
	|	XMLРолей.ИмяРоли В (&МассивИмен)";
	Запрос.УстановитьПараметр("МассивИмен", МассивИмен);

	РезультатЗапроса = Запрос.Выполнить();
	Выборка          = РезультатЗапроса.Выбрать();

	СоответствиеXML = Новый Соответствие;
	Пока Выборка.Следующий() Цикл
		СоответствиеXML.Вставить(Выборка.ИмяРоли, Выборка.XMLТекст);
	КонецЦикла;

	Возврат СоответствиеXML;

КонецФункции

// Получает XML текст роли из регистра цур_XMLРолейКонфигурации по имени роли.
//
// Параметры:
//  ИмяРоли - Строка - имя роли в конфигурации
//
// Возвращаемое значение:
//  Строка - XML текст прав роли или пустая строка, если запись не найдена
//
Функция ПолучитьXMLРолиИзРегистра(ИмяРоли)

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	РС.XMLТекст КАК XMLТекст
	|ИЗ
	|	РегистрСведений.цур_XMLРолейКонфигурации КАК РС
	|ГДЕ
	|	РС.ИмяРоли = &ИмяРоли";
	Запрос.УстановитьПараметр("ИмяРоли", ИмяРоли);

	РезультатЗапроса = Запрос.Выполнить();

	Если РезультатЗапроса.Пустой() Тогда
		Возврат "";
	КонецЕсли;

	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	Возврат Выборка.XMLТекст;

КонецФункции

// Разбирает XML прав роли (содержимое Rights.xml) и заполняет модель.
//
// Параметры:
//  ИмяРоли  - Строка    - имя роли (используется в контексте разбора)
//  XMLТекст - Строка    - текст XML файла прав (Rights.xml)
//  Модель   - Структура - модель роли для заполнения (Права, Ограничения, Шаблоны, флаги)
//
Процедура ПрочитатьМодельИзXML(ИмяРоли, XMLТекст, Модель)

	ЧтениеXML = Новый ЧтениеXML;
	ЧтениеXML.УстановитьСтроку(XMLТекст);

	Пока ЧтениеXML.Прочитать() Цикл

		Если ЧтениеXML.ТипУзла <> ТипУзлаXML.НачалоЭлемента Тогда
			Продолжить;
		КонецЕсли;

		Если ЧтениеXML.Имя = "setForNewObjects" Тогда
			Модель.УстанавливатьДляНовыхОбъектов = ПрочитатьФлагXML(ЧтениеXML);

		ИначеЕсли ЧтениеXML.Имя = "setForAttributesByDefault" Тогда
			Модель.УстанавливатьДляРеквизитовПоУмолчанию = ПрочитатьФлагXML(ЧтениеXML);

		ИначеЕсли ЧтениеXML.Имя = "independentRightsOfChildObjects" Тогда
			Модель.НезависимыеПраваПодчиненных = ПрочитатьФлагXML(ЧтениеXML);

		ИначеЕсли ЧтениеXML.Имя = "object" Тогда
			ПрочитатьОбъектXML(ЧтениеXML, Модель);

		ИначеЕсли ЧтениеXML.Имя = "restrictionTemplate" Тогда
			ПрочитатьШаблонXML(ЧтениеXML, Модель);

		Иначе
			// Прочие элементы верхнего уровня игнорируем

		КонецЕсли;

	КонецЦикла;

	ЧтениеXML.Закрыть();

КонецПроцедуры

// Читает текстовое значение булева флага из текущего элемента XML.
// Ожидаемый формат: <имяЭлемента>true</имяЭлемента> или <имяЭлемента>false</имяЭлемента>.
//
// Параметры:
//  ЧтениеXML - ЧтениеXML - позиционировано на НачалоЭлемента нужного тега
//
// Возвращаемое значение:
//  Булево
//
Функция ПрочитатьФлагXML(ЧтениеXML)

	Если ЧтениеXML.Прочитать() И ЧтениеXML.ТипУзла = ТипУзлаXML.Текст Тогда
		Возврат НРег(ЧтениеXML.Значение) = "true";
	КонецЕсли;

	Возврат Ложь;

КонецФункции

// Разбирает блок <object> из Rights.xml и добавляет строки в таблицы прав и ограничений.
//
// Dot-нотация имени объекта:
//   ТипОбъекта.ИмяОбъекта[.ТипВложенного.ИмяВложенного]
//
Процедура ПрочитатьОбъектXML(ЧтениеXML, Модель)

	ВидОбъекта     = "";
	ИмяОбъекта     = "";
	ТипРеквизита   = "";
	ИмяРеквизита   = "";
	ИмяРеквизитаТЧ = "";

	Пока ЧтениеXML.Прочитать() Цикл

		Если ЧтениеXML.ТипУзла = ТипУзлаXML.КонецЭлемента И ЧтениеXML.Имя = "object" Тогда
			Прервать;
		КонецЕсли;

		Если ЧтениеXML.ТипУзла <> ТипУзлаXML.НачалоЭлемента Тогда
			Продолжить;
		КонецЕсли;

		Если ЧтениеXML.Имя = "name" Тогда
			ЧтениеXML.Прочитать();
			РазобратьДотНотацию(
				ЧтениеXML.Значение,
				ВидОбъекта, ИмяОбъекта, ТипРеквизита, ИмяРеквизита, ИмяРеквизитаТЧ);

		ИначеЕсли ЧтениеXML.Имя = "right" Тогда
			ПрочитатьПравоXML(
				ЧтениеXML, Модель,
				ВидОбъекта, ИмяОбъекта, ТипРеквизита, ИмяРеквизита, ИмяРеквизитаТЧ);

		Иначе
			// Прочие элементы объекта игнорируем

		КонецЕсли;

	КонецЦикла;

КонецПроцедуры

// Разбирает блок <right> внутри <object> и добавляет строки прав и ограничений в модель.
Процедура ПрочитатьПравоXML(
		ЧтениеXML,
		Модель,
		ВидОбъекта,
		ИмяОбъекта,
		ТипРеквизита,
		ИмяРеквизита,
		ИмяРеквизитаТЧ)

	ИмяПрава          = "";
	ЗначениеПрава     = Ложь;
	ДанныеОграничения = Неопределено;

	Пока ЧтениеXML.Прочитать() Цикл

		Если ЧтениеXML.ТипУзла = ТипУзлаXML.КонецЭлемента И ЧтениеXML.Имя = "right" Тогда
			Прервать;
		КонецЕсли;

		Если ЧтениеXML.ТипУзла <> ТипУзлаXML.НачалоЭлемента Тогда
			Продолжить;
		КонецЕсли;

		Если ЧтениеXML.Имя = "name" Тогда
			ЧтениеXML.Прочитать();
			ИмяПрава = ЧтениеXML.Значение;

		ИначеЕсли ЧтениеXML.Имя = "value" Тогда
			ЧтениеXML.Прочитать();
			ЗначениеПрава = (НРег(ЧтениеXML.Значение) = "true");

		ИначеЕсли ЧтениеXML.Имя = "restrictionByCondition" Тогда
			ДанныеОграничения = ПрочитатьУсловиеОграничения(ЧтениеXML);

		Иначе
			// Прочие элементы внутри <right> игнорируем

		КонецЕсли;

	КонецЦикла;

	НоваяСтрока = Модель.Права.Добавить();
	НоваяСтрока.ВидОбъекта     = ВидОбъекта;
	НоваяСтрока.ИмяОбъекта     = ИмяОбъекта;
	НоваяСтрока.ИмяПрава       = ИмяПрава;
	НоваяСтрока.ТипРеквизита   = ТипРеквизита;
	НоваяСтрока.ИмяРеквизита   = ИмяРеквизита;
	НоваяСтрока.ИмяРеквизитаТЧ = ИмяРеквизитаТЧ;
	НоваяСтрока.ЗначениеПрава  = ЗначениеПрава;

	Если ДанныеОграничения <> Неопределено
			И НЕ ПустаяСтрока(ДанныеОграничения.Условие) Тогда
		НовоеОграничение = Модель.Ограничения.Добавить();
		НовоеОграничение.ВидОбъекта         = ВидОбъекта;
		НовоеОграничение.ИмяОбъекта         = ИмяОбъекта;
		НовоеОграничение.ИмяПрава           = ИмяПрава;
		НовоеОграничение.УсловиеОграничения = ДанныеОграничения.Условие;
		НовоеОграничение.Поля               = ДанныеОграничения.Поля;
	КонецЕсли;

КонецПроцедуры

// Читает условие ограничения доступа из блока <restrictionByCondition>.
//
// Возвращаемое значение:
//  Структура:
//    * Условие - Строка - текст условия ограничения
//    * Поля    - Строка - поля ограничения, разделённые переносом строки
//
Функция ПрочитатьУсловиеОграничения(ЧтениеXML)

	Условие    = "";
	МассивПолей = Новый Массив;

	Пока ЧтениеXML.Прочитать() Цикл

		Если ЧтениеXML.ТипУзла = ТипУзлаXML.КонецЭлемента
				И ЧтениеXML.Имя = "restrictionByCondition" Тогда
			Прервать;
		ИначеЕсли ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента
				И ЧтениеXML.Имя = "condition" Тогда
			ЧтениеXML.Прочитать();
			Условие = ЧтениеXML.Значение;
		ИначеЕсли ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента
				И ЧтениеXML.Имя = "field" Тогда
			ЧтениеXML.Прочитать();
			МассивПолей.Добавить(ЧтениеXML.Значение);
		Иначе
			// Прочие узлы игнорируем
		КонецЕсли;

	КонецЦикла;

	Результат = Новый Структура;
	Результат.Вставить("Условие", Условие);
	Результат.Вставить("Поля",    СтрСоединить(МассивПолей, Символы.ПС));

	Возврат Результат;

КонецФункции

// Читает блок <restrictionTemplate> и добавляет шаблон в модель.
Процедура ПрочитатьШаблонXML(ЧтениеXML, Модель)

	ИмяШаблона   = "";
	ТекстШаблона = "";

	Пока ЧтениеXML.Прочитать() Цикл

		Если ЧтениеXML.ТипУзла = ТипУзлаXML.КонецЭлемента
				И ЧтениеXML.Имя = "restrictionTemplate" Тогда
			Прервать;
		КонецЕсли;

		Если ЧтениеXML.ТипУзла <> ТипУзлаXML.НачалоЭлемента Тогда
			Продолжить;
		КонецЕсли;

		Если ЧтениеXML.Имя = "name" Тогда
			ЧтениеXML.Прочитать();
			ИмяШаблона = ЧтениеXML.Значение;

		ИначеЕсли ЧтениеXML.Имя = "condition" Тогда
			ЧтениеXML.Прочитать();
			ТекстШаблона = ЧтениеXML.Значение;

		Иначе
			// Прочие элементы шаблона игнорируем

		КонецЕсли;

	КонецЦикла;

	НоваяСтрока = Модель.Шаблоны.Добавить();
	НоваяСтрока.ИмяШаблона   = ИмяШаблона;
	НоваяСтрока.ТекстШаблона = ТекстШаблона;

КонецПроцедуры

// Разбирает dot-нотацию имени объекта из Rights.xml на составляющие части.
//
// Примеры нотации:
//   "Catalog.Контрагенты"                              → ВидОбъекта=Catalog, ИмяОбъекта=Контрагенты
//   "Catalog.X.Attribute.ИНН"                          → +ТипРеквизита=Attribute, ИмяРеквизита=ИНН
//   "Document.X.TabularSection.Товары.Attribute.Ном"   → +ИмяРеквизитаТЧ=Товары, ИмяРеквизита=Ном
//
// Параметры:
//  ДотНотация     - Строка - полное имя объекта в dot-нотации
//  ВидОбъекта     - Строка - [вых] вид метаданных
//  ИмяОбъекта     - Строка - [вых] имя объекта метаданных
//  ТипРеквизита   - Строка - [вых] тип вложенного реквизита
//  ИмяРеквизита   - Строка - [вых] имя реквизита
//  ИмяРеквизитаТЧ - Строка - [вых] имя ТЧ (для вложенных реквизитов)
//
Процедура РазобратьДотНотацию(
		ДотНотация,
		ВидОбъекта,
		ИмяОбъекта,
		ТипРеквизита,
		ИмяРеквизита,
		ИмяРеквизитаТЧ)

	ВидОбъекта     = "";
	ИмяОбъекта     = "";
	ТипРеквизита   = "";
	ИмяРеквизита   = "";
	ИмяРеквизитаТЧ = "";

	Части = СтрРазделить(ДотНотация, ".", Ложь);
	КоличествоЧастей = Части.Количество();

	Если КоличествоЧастей < 2 Тогда
		Возврат;
	КонецЕсли;

	ВидОбъекта = Части[0];
	ИмяОбъекта = Части[1];

	Если КоличествоЧастей < 4 Тогда
		Возврат;
	КонецЕсли;

	ТипРеквизита = Части[2];

	// Document.X.TabularSection.ИмяТС.ТипРеквизита.ИмяРеквизита — 6 частей
	Если НРег(ТипРеквизита) = "tabularsection" И КоличествоЧастей >= 6 Тогда
		ИмяРеквизитаТЧ = Части[3];
		ТипРеквизита   = Части[4];
		ИмяРеквизита   = Части[5];
	Иначе
		// Catalog.X.Attribute.ИмяРеквизита — 4 части
		ИмяРеквизита = Части[3];
	КонецЕсли;

КонецПроцедуры

// Получает список имён ролей, входящих в профиль с указанным именем.
// При наличии справочника ПрофилиГруппДоступа — читает из него.
// При отсутствии БСП — интерпретирует ИмяПрофиля как имя роли конфигурации.
//
// Параметры:
//  ИмяПрофиля - Строка - наименование профиля или имя роли конфигурации
//
// Возвращаемое значение:
//  Массив - массив строк с именами ролей конфигурации
//
// Получает роли профиля групп доступа по ссылке.
//
// Параметры:
//  СсылкаПрофиля - СправочникСсылка - ссылка на элемент справочника ПрофилиГруппДоступа
//
// Возвращаемое значение:
//  Массив - массив строк с именами ролей конфигурации
//
Функция ПолучитьРолиПрофиля(СсылкаПрофиля)

	МассивРолей = Новый Массив;

	Если Метаданные.НайтиПоПолномуИмени("Справочник.ПрофилиГруппДоступа") = Неопределено Тогда
		Возврат МассивРолей;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	РолиПрофиля.Роль.Имя КАК ИмяРоли
	|ИЗ
	|	Справочник.ПрофилиГруппДоступа.Роли КАК РолиПрофиля
	|ГДЕ
	|	РолиПрофиля.Ссылка = &Профиль";
	Запрос.УстановитьПараметр("Профиль", СсылкаПрофиля);

	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();

	Пока Выборка.Следующий() Цикл
		МассивРолей.Добавить(Выборка.ИмяРоли);
	КонецЦикла;

	Возврат МассивРолей;

КонецФункции

// Получает все роли пользователя через цепочку: Пользователь → ГруппыДоступа → Профиль → Роли.
//
// Параметры:
//  СсылкаПользователя - СправочникСсылка - ссылка на пользователя
//
// Возвращаемое значение:
//  Массив - массив строк с именами ролей конфигурации (без дублей)
//
Функция ПолучитьРолиПользователяЧерезПрофили(СсылкаПользователя)

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	РолиПрофиля.Роль.Имя КАК ИмяРоли
	|ИЗ
	|	Справочник.ГруппыДоступа.Пользователи КАК ПользователиГрупп
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ПрофилиГруппДоступа.Роли КАК РолиПрофиля
	|		ПО ПользователиГрупп.Ссылка.Профиль = РолиПрофиля.Ссылка
	|ГДЕ
	|	ПользователиГрупп.Пользователь = &Пользователь
	|	И НЕ ПользователиГрупп.Ссылка.ПометкаУдаления";
	Запрос.УстановитьПараметр("Пользователь", СсылкаПользователя);

	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();

	МассивРолей = Новый Массив;

	Пока Выборка.Следующий() Цикл
		МассивРолей.Добавить(Выборка.ИмяРоли);
	КонецЦикла;

	Возврат МассивРолей;

КонецФункции

// Объединяет права набора ролей конфигурации в единую модель по правилу OR.
// Для каждого уникального ключа права значение = Истина, если хотя бы одна роль его разрешает.
// Читает XML всех ролей одним запросом к регистру цур_XMLРолейКонфигурации.
//
// Параметры:
//  МассивИменРолей - Массив - массив строк с именами ролей конфигурации
//
// Возвращаемое значение:
//  Структура - объединённая модель роли, см. НовыеПараметрыРоли()
//
Функция ОбъединитьПраваРолей(МассивИменРолей)

	МодельАгрегат = НовыеПараметрыРоли();

	Если МассивИменРолей.Количество() = 0 Тогда
		Возврат МодельАгрегат;
	КонецЕсли;

	// Один запрос для всех ролей вместо N отдельных
	СоответствиеXML = ПолучитьXMLРолейПакетом(МассивИменРолей);

	ИндексПрав        = Новый Соответствие;
	ИндексОграничений = Новый Соответствие;
	ИндексШаблонов    = Новый Соответствие;

	Для Каждого ИмяРоли Из МассивИменРолей Цикл

		XMLТекст = СоответствиеXML.Получить(ИмяРоли);
		Если XMLТекст = Неопределено Или ПустаяСтрока(XMLТекст) Тогда
			Продолжить;
		КонецЕсли;

		МодельТекущей = НовыеПараметрыРоли();
		МодельТекущей.Имя = ИмяРоли;
		ПрочитатьМодельИзXML(ИмяРоли, XMLТекст, МодельТекущей);

		МодельАгрегат.УстанавливатьДляНовыхОбъектов = МодельАгрегат.УстанавливатьДляНовыхОбъектов
			Или МодельТекущей.УстанавливатьДляНовыхОбъектов;

		МодельАгрегат.НезависимыеПраваПодчиненных = МодельАгрегат.НезависимыеПраваПодчиненных
			Или МодельТекущей.НезависимыеПраваПодчиненных;

		ОбъединитьТаблицуПрав(МодельАгрегат.Права, МодельТекущей.Права, ИндексПрав);
		ОбъединитьТаблицуОграничений(МодельАгрегат.Ограничения, МодельТекущей.Ограничения, ИндексОграничений);
		ОбъединитьТаблицуШаблонов(МодельАгрегат.Шаблоны, МодельТекущей.Шаблоны, ИндексШаблонов);

	КонецЦикла;

	Возврат МодельАгрегат;

КонецФункции

// Объединяет таблицу прав в агрегат по правилу OR для ЗначениеПрава.
// Использует индекс для O(1) поиска дублей.
Процедура ОбъединитьТаблицуПрав(ТаблицаАгрегат, ТаблицаИсточник, ИндексПрав)

	Для Каждого Строка Из ТаблицаИсточник Цикл
		Ключ = СтрШаблон("%1|%2|%3|%4|%5",
			Строка.ВидОбъекта,
			Строка.ИмяОбъекта,
			Строка.ИмяПрава,
			Строка.ТипРеквизита,
			Строка.ИмяРеквизита);

		СуществующаяСтрока = ИндексПрав.Получить(Ключ);
		Если СуществующаяСтрока <> Неопределено Тогда
			СуществующаяСтрока.ЗначениеПрава = СуществующаяСтрока.ЗначениеПрава Или Строка.ЗначениеПрава;
		Иначе
			НоваяСтрока = ТаблицаАгрегат.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Строка);
			ИндексПрав.Вставить(Ключ, НоваяСтрока);
		КонецЕсли;

	КонецЦикла;

КонецПроцедуры

// Объединяет таблицу ограничений в агрегат, добавляя первое встречное условие по ключу объект+право.
Процедура ОбъединитьТаблицуОграничений(ТаблицаАгрегат, ТаблицаИсточник, ИндексОграничений)

	Для Каждого Строка Из ТаблицаИсточник Цикл
		Ключ = СтрШаблон("%1|%2|%3",
			Строка.ВидОбъекта,
			Строка.ИмяОбъекта,
			Строка.ИмяПрава);

		Если ИндексОграничений.Получить(Ключ) = Неопределено Тогда
			НоваяСтрока = ТаблицаАгрегат.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Строка);
			ИндексОграничений.Вставить(Ключ, Истина);
		КонецЕсли;

	КонецЦикла;

КонецПроцедуры

// Объединяет таблицу шаблонов в агрегат, пропуская дубли по ИмяШаблона.
Процедура ОбъединитьТаблицуШаблонов(ТаблицаАгрегат, ТаблицаИсточник, ИндексШаблонов)

	Для Каждого Строка Из ТаблицаИсточник Цикл
		Если ИндексШаблонов.Получить(Строка.ИмяШаблона) = Неопределено Тогда
			НоваяСтрока = ТаблицаАгрегат.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Строка);
			ИндексШаблонов.Вставить(Строка.ИмяШаблона, Истина);
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

