	//BSLLS:DeprecatedMethods8317-on
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Рекурсивно ищет подсистему в коллекции по массиву частей имени.
//
// Параметры:
//  КоллекцияПодсистем - КоллекцияОбъектовМетаданных - коллекция для поиска.
//  ЧастиИмени         - Массив из Строка             - части полного имени подсистемы.
//  Уровень            - Число                        - текущий уровень рекурсии (индекс в массиве частей).
//
// Возвращаемое значение:
//  Булево - Истина, если подсистема найдена.
//
Функция НайтиПодсистемуВИерархии(КоллекцияПодсистем, ЧастиИмени, Уровень)

	Если Уровень >= ЧастиИмени.Количество() Тогда
		Возврат Истина;
	КонецЕсли;

	ИмяТекущегоУровня = ЧастиИмени[Уровень];
	Подсистема = КоллекцияПодсистем.Найти(ИмяТекущегоУровня);

	Если Подсистема = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;

	Возврат НайтиПодсистемуВИерархии(Подсистема.Подсистемы, ЧастиИмени, Уровень + 1);

КонецФункции

// Определяет, следует ли использовать модули БСП для выполнения операций.
// Читает реквизит ИспользоватьБСП из справочника информационных баз и проверяет наличие модуля БСП.
//
// Параметры:
//  ИнформационнаяБаза - СправочникСсылка.цур_ИнформационныеБазы
//
// Возвращаемое значение:
//  Булево
//
Функция ИспользоватьБСП(ИнформационнаяБаза)

	Если НЕ ЗначениеЗаполнено(ИнформационнаяБаза) Тогда
		Возврат Ложь;
	КонецЕсли;

	Флаг = ЗначениеРеквизитаОбъекта(ИнформационнаяБаза, "ИспользоватьБСП");

	Возврат Флаг
		И Метаданные.НайтиПоПолномуИмени("ОбщийМодуль.ОбщегоНазначения") <> Неопределено;

КонецФункции

#КонецОбласти
