#Область ПрограммныйИнтерфейс

// Возвращает значение реквизита объекта, прочитанное из информационной базы по ссылке.
// Рекомендуется использовать вместо обращения к реквизиту через точку от ссылки,
// так как не загружает весь объект из базы данных.
//
// Параметры:
//  Ссылка       - ЛюбаяСсылка - объект, значение реквизита которого необходимо получить.
//  ИмяРеквизита - Строка      - имя получаемого реквизита, например "Код" или "Наименование".
//
// Возвращаемое значение:
//  Произвольный - значение реквизита.
//               Возвращает Неопределено, если передана пустая ссылка или ссылка несуществующего объекта.
//
Функция ЗначениеРеквизитаОбъекта(Ссылка, ИмяРеквизита) Экспорт

	// TODO: передать ИнформационнаяБазу из контекста
	Если ИспользоватьБСП(Неопределено) Тогда
		Возврат ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Ссылка, ИмяРеквизита);
	КонецЕсли;

	Если ПустаяСтрока(ИмяРеквизита) Тогда
		ВызватьИсключение НСтр("ru = 'Параметр ИмяРеквизита не может быть пустым.'");
	КонецЕсли;

	Результат = ЗначенияРеквизитовОбъекта(Ссылка, ИмяРеквизита);
	Возврат Результат[ИмяРеквизита];

КонецФункции

// Возвращает структуру со значениями реквизитов объекта, прочитанными из информационной базы по ссылке.
// Рекомендуется использовать вместо обращения к реквизитам через точку от ссылки,
// так как выполняет один целевой запрос вместо загрузки всего объекта.
//
// Параметры:
//  Ссылка         - ЛюбаяСсылка - объект, значения реквизитов которого необходимо получить.
//  ИменаРеквизитов - Строка     - имена реквизитов через запятую, например "Код, Наименование, Родитель".
//
// Возвращаемое значение:
//  Структура - ключи соответствуют именам реквизитов, значения - прочитанным данным.
//              Если передана пустая ссылка или ссылка несуществующего объекта,
//              все ключи будут присутствовать, а значения равны Неопределено.
//
Функция ЗначенияРеквизитовОбъекта(Ссылка, ИменаРеквизитов) Экспорт

	// TODO: передать ИнформационнаяБазу из контекста
	Если ИспользоватьБСП(Неопределено) Тогда
		Возврат ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Ссылка, ИменаРеквизитов);
	КонецЕсли;

	Результат = Новый Структура;

	Если ПустаяСтрока(ИменаРеквизитов) Тогда
		Возврат Результат;
	КонецЕсли;

	МассивИмен = СтрРазделить(ИменаРеквизитов, ",", Ложь);
	Для Каждого ИмяРеквизита Из МассивИмен Цикл
		Результат.Вставить(СокрЛП(ИмяРеквизита));
	КонецЦикла;

	Если Не ЗначениеЗаполнено(Ссылка) Тогда
		Возврат Результат;
	КонецЕсли;

	ПолноеИмяОбъекта = Ссылка.Метаданные().ПолноеИмя();

	ЧастиПолей = Новый Массив;
	Индекс = 0;
	СоответствиеПолей = Новый Соответствие;

	Для Каждого ИмяРеквизита Из МассивИмен Цикл

		ИмяРеквизита = СокрЛП(ИмяРеквизита);
		АлиасПоля = СтрШаблон("Поле%1", Формат(Индекс, "ЧГ=0"));

		ЧастиПолей.Добавить(СтрШаблон("ОбъектМетаданных.%1 КАК %2", ИмяРеквизита, АлиасПоля));
		СоответствиеПолей.Вставить(АлиасПоля, ИмяРеквизита);
		Индекс = Индекс + 1;

	КонецЦикла;

	РазделительПолей = ", ";

	ТекстЗапроса = СтрШаблон(
		"ВЫБРАТЬ
		|	%1
		|ИЗ
		|	%2 КАК ОбъектМетаданных
		|ГДЕ
		|	ОбъектМетаданных.Ссылка = &Ссылка",
		СтрСоединить(ЧастиПолей, РазделительПолей),
		ПолноеИмяОбъекта);

	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("Ссылка", Ссылка);

	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();

	Если Выборка.Следующий() Тогда
		Для Каждого Элемент Из СоответствиеПолей Цикл
			Результат.Вставить(Элемент.Значение, Выборка[Элемент.Ключ]);
		КонецЦикла;
	КонецЕсли;

	Возврат Результат;

КонецФункции

// Возвращает значения одного реквизита для нескольких объектов.
// Выполняет один пакетный запрос вместо обращений к каждому объекту по отдельности.
// Поддерживает полиморфные массивы (объекты разных типов).
//
// Параметры:
//  МассивСсылок - Массив из ЛюбаяСсылка
//               - ФиксированныйМассив из ЛюбаяСсылка - ссылки на объекты.
//  ИмяРеквизита - Строка - имя получаемого реквизита, например "ИНН".
//
// Возвращаемое значение:
//  Соответствие из КлючИЗначение:
//   * Ключ     - ЛюбаяСсылка  - ссылка на объект;
//   * Значение - Произвольный - значение реквизита.
//
Функция ЗначениеРеквизитаОбъектов(МассивСсылок, ИмяРеквизита) Экспорт

	Результат = Новый Соответствие;

	Если МассивСсылок.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;

	Если ПустаяСтрока(ИмяРеквизита) Тогда
		ВызватьИсключение НСтр("ru = 'Параметр ИмяРеквизита не может быть пустым.'");
	КонецЕсли;

	// Группируем ссылки по типу для поддержки полиморфных массивов.
	СсылкиПоТипам = Новый Соответствие;
	Для Каждого Ссылка Из МассивСсылок Цикл

		ТипСсылки = ТипЗнч(Ссылка);
		Если СсылкиПоТипам[ТипСсылки] = Неопределено Тогда
			СсылкиПоТипам[ТипСсылки] = Новый Массив;
		КонецЕсли;

		СсылкиПоТипам[ТипСсылки].Добавить(Ссылка);

	КонецЦикла;

	ТекстыЗапросов = Новый Массив;
	ПараметрыЗапроса = Новый Структура;

	Для Каждого ЭлементТипа Из СсылкиПоТипам Цикл

		ОбъектМетаданных = Метаданные.НайтиПоТипу(ЭлементТипа.Ключ);
		Если ОбъектМетаданных = Неопределено Тогда
			ВызватьИсключение СтрШаблон(
				НСтр("ru = 'Элементы массива МассивСсылок должны быть ссылками. Тип: %1.'"),
				Строка(ЭлементТипа.Ключ));
		КонецЕсли;

		ПолноеИмяОбъекта = ОбъектМетаданных.ПолноеИмя();
		ИмяПараметра = "Ссылки" + СтрЗаменить(ПолноеИмяОбъекта, ".", "");

		ТекстЗапроса =
		"ВЫБРАТЬ
		|	ОбъектМетаданных.Ссылка КАК Ссылка,
		|	ОбъектМетаданных." + ИмяРеквизита + " КАК ЗначениеРеквизита
		|ИЗ
		|	" + ПолноеИмяОбъекта + " КАК ОбъектМетаданных
		|ГДЕ
		|	ОбъектМетаданных.Ссылка В (&" + ИмяПараметра + ")";

		ТекстыЗапросов.Добавить(ТекстЗапроса);
		ПараметрыЗапроса.Вставить(ИмяПараметра, ЭлементТипа.Значение);

	КонецЦикла;

	ТекстЗапроса = СтрСоединить(ТекстыЗапросов, Символы.ПС + "ОБЪЕДИНИТЬ ВСЕ" + Символы.ПС);

	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	Для Каждого Параметр Из ПараметрыЗапроса Цикл
		Запрос.УстановитьПараметр(Параметр.Ключ, Параметр.Значение);
	КонецЦикла;

	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();

	Пока Выборка.Следующий() Цикл
		Результат[Выборка.Ссылка] = Выборка.ЗначениеРеквизита;
	КонецЦикла;

	Возврат Результат;

КонецФункции

// Проверяет, доступна ли роль текущему пользователю информационной базы.
//
// Параметры:
//  ИмяРоли - Строка - имя роли, например "ПолныеПрава".
//
// Возвращаемое значение:
//  Булево - Истина, если роль доступна текущему пользователю.
//
Функция ЕстьРоль(ИмяРоли) Экспорт
	Возврат РольДоступна(ИмяРоли);
КонецФункции

// Проверяет существование подсистемы в метаданных конфигурации по полному имени.
//
// Параметры:
//  ПолноеИмяПодсистемы - Строка - полное имя подсистемы, например "СтандартныеПодсистемы.ЗагрузкаДанныхИзФайла".
//
// Возвращаемое значение:
//  Булево - Истина, если подсистема найдена в метаданных.
//
Функция ПодсистемаСуществует(ПолноеИмяПодсистемы) Экспорт
	ЧастиИмени = СтрРазделить(ПолноеИмяПодсистемы, ".");
	Возврат НайтиПодсистемуВИерархии(Метаданные.Подсистемы, ЧастиИмени, 0);
КонецФункции

// Определяет, что сервер работает под управлением Windows.
//
// Возвращаемое значение:
//  Булево
//
Функция ЭтоWindowsСервер() Экспорт

	СистемнаяИнформация = Новый СистемнаяИнформация;
	Возврат СистемнаяИнформация.ТипПлатформы = ТипПлатформы.Windows_x86
		Или СистемнаяИнформация.ТипПлатформы = ТипПлатформы.Windows_x86_64;

КонецФункции

// Определяет, что сервер работает под управлением Linux.
//
// Возвращаемое значение:
//  Булево
//
Функция ЭтоLinuxСервер() Экспорт

	СистемнаяИнформация = Новый СистемнаяИнформация;
	Возврат СистемнаяИнформация.ТипПлатформы = ТипПлатформы.Linux_x86
		Или СистемнаяИнформация.ТипПлатформы = ТипПлатформы.Linux_x86_64;

КонецФункции

// Возвращает подробное текстовое представление ошибки.
// Использует ОбработкаОшибок из БСП при наличии, иначе встроенную платформенную функцию.
//
// Параметры:
//  ИнформацияОбОшибке - ИнформацияОбОшибке
//
// Возвращаемое значение:
//  Строка
//
Функция ОписаниеОшибкиПодробное(ИнформацияОбОшибке) Экспорт
	// TODO: передать ИнформационнаяБазу из контекста
	ЕстьМодульОшибок = Метаданные.НайтиПоПолномуИмени("ОбщийМодуль.ОбработкаОшибок") <> Неопределено;
	Если ИспользоватьБСП(Неопределено) И ЕстьМодульОшибок Тогда
		Возврат ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
	КонецЕсли;
	//BSLLS:DeprecatedMethods8317-off
	Возврат ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
	//BSLLS:DeprecatedMethods8317-on
КонецФункции

