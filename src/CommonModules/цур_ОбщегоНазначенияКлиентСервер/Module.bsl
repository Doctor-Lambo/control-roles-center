
#Область ПрограммныйИнтерфейс

// Выводит сообщение пользователю. При необходимости привязывает сообщение к объекту или полю формы.
//
// Параметры:
//  ТекстСообщения - Строка - текст сообщения для пользователя.
//  КлючДанных     - Произвольный - ссылка на объект (документ, элемент справочника и т.п.),
//                   к которому привязывается сообщение. Если Неопределено - привязка не выполняется.
//  Поле           - Строка - имя реквизита объекта или элемента формы, к которому привязывается сообщение.
//  ПутьКДанным    - Строка - путь к данным реквизита формы.
//  Отказ          - Булево - если передан, устанавливается в Истина.
//
//BSLLS:NumberOfOptionalParams-off
Процедура СообщитьПользователю(
		Знач ТекстСообщения,
		Знач КлючДанных = Неопределено,
		Знач Поле = "",
		Знач ПутьКДанным = "",
		Отказ = Ложь) Экспорт
//BSLLS:NumberOfOptionalParams-on

	Сообщение = Новый СообщениеПользователю;
	Сообщение.Текст = ТекстСообщения;

	Если КлючДанных <> Неопределено Тогда
		Сообщение.КлючДанных = КлючДанных;
	КонецЕсли;

	Если Не ПустаяСтрока(Поле) Тогда
		Сообщение.Поле = Поле;
	КонецЕсли;

	Если Не ПустаяСтрока(ПутьКДанным) Тогда
		Сообщение.ПутьКДанным = ПутьКДанным;
	КонецЕсли;

	Сообщение.Сообщить();
	Отказ = Истина;

КонецПроцедуры

// Создает массив из одного элемента и помещает в него переданное значение.
//
// Параметры:
//  Значение - Произвольный - любое значение.
//
// Возвращаемое значение:
//  Массив из Произвольный - массив из одного элемента.
//
Функция ЗначениеВМассиве(Знач Значение) Экспорт

	Результат = Новый Массив;
	Результат.Добавить(Значение);
	Возврат Результат;

КонецФункции

// Проверяет, заполнено ли значение (делегирует к ЗначениеЗаполнено).
//
// Параметры:
//  Значение - Произвольный - проверяемое значение.
//
// Возвращаемое значение:
//  Булево - Истина, если значение заполнено.
//
Функция ТипОпределен(Знач Значение) Экспорт

	Возврат ЗначениеЗаполнено(Значение);

КонецФункции

// Проверяет соответствие типа значения параметра ожидаемым типам.
// Вызывает исключение, если тип не совпадает.
//
// Параметры:
//  ИмяПроцедуры  - Строка       - имя проверяемой процедуры или функции.
//  ИмяПараметра  - Строка       - имя проверяемого параметра.
//  Значение      - Произвольный - фактическое значение параметра.
//  ОжидаемыеТипы - ОписаниеТипов
//                - Тип
//                - Массив
//                - ФиксированныйМассив
//                - Соответствие
//                - ФиксированноеСоответствие - ожидаемые типы параметра.
//
Процедура ПроверитьПараметр(
		Знач ИмяПроцедуры,
		Знач ИмяПараметра,
		Знач Значение,
		Знач ОжидаемыеТипы) Экспорт

	ЭтоКорректныйТип = ЗначениеОжидаемогоТипа(Значение, ОжидаемыеТипы);

	Если ЭтоКорректныйТип = Неопределено Тогда
		//BSLLS:Typo-off
		ТекстОшибки = "цур_ОбщегоНазначенияКлиентСервер.ПроверитьПараметр:"
			+ " недопустимое значение параметра ОжидаемыеТипы.";
		//BSLLS:Typo-on
		ВызватьИсключение ТекстОшибки;
	КонецЕсли;

	Если Не ЭтоКорректныйТип Тогда

		Если Значение = Неопределено Тогда
			ПредставлениеЗначения = "Неопределено";
		ИначеЕсли ТипЗнч(Значение) = Тип("ДвоичныеДанные") И Значение.Размер() = 0 Тогда
			ПредставлениеЗначения = "";
		Иначе
			ПредставлениеЗначения = Строка(Значение);
		КонецЕсли;

		ВызватьИсключение СтрШаблон(
			"Недопустимое значение параметра %1 в %2.%3Ожидалось: %4; передано значение: %5 (тип %6).",
			ИмяПараметра,
			ИмяПроцедуры,
			Символы.ПС,
			ПредставлениеТипов(ОжидаемыеТипы),
			ПредставлениеЗначения,
			ТипЗнч(Значение));

	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Проверяет соответствие типа значения ожидаемым типам.
//
// Параметры:
//  Значение      - Произвольный  - проверяемое значение.
//  ОжидаемыеТипы - ОписаниеТипов - тип, массив или соответствие ожидаемых типов.
//                - Тип
//                - Массив
//                - ФиксированныйМассив
//                - Соответствие
//                - ФиксированноеСоответствие
//
// Возвращаемое значение:
//  Булево       - Истина, если тип совпадает; Ложь, если не совпадает.
//  Неопределено - если ОжидаемыеТипы передан в неподдерживаемом виде.
//
Функция ЗначениеОжидаемогоТипа(Значение, ОжидаемыеТипы)

	ТипЗначения   = ТипЗнч(Значение);
	ТипОжидаемых  = ТипЗнч(ОжидаемыеТипы);

	Если ТипОжидаемых = Тип("ОписаниеТипов") Тогда
		Возврат ОжидаемыеТипы.Типы().Найти(ТипЗначения) <> Неопределено;
	ИначеЕсли ТипОжидаемых = Тип("Тип") Тогда
		Возврат ТипЗначения = ОжидаемыеТипы;
	ИначеЕсли ТипОжидаемых = Тип("Массив")
		Или ТипОжидаемых = Тип("ФиксированныйМассив") Тогда
		Возврат ОжидаемыеТипы.Найти(ТипЗначения) <> Неопределено;
	ИначеЕсли ТипОжидаемых = Тип("Соответствие")
		Или ТипОжидаемых = Тип("ФиксированноеСоответствие") Тогда
		Возврат ОжидаемыеТипы.Получить(ТипЗначения) <> Неопределено;
	Иначе
		Возврат Неопределено;
	КонецЕсли;

КонецФункции

// Формирует строковое представление набора ожидаемых типов для сообщения об ошибке.
//
// Параметры:
//  ОжидаемыеТипы - ОписаниеТипов - тип, массив или соответствие ожидаемых типов.
//                - Тип
//                - Массив
//                - ФиксированныйМассив
//                - Соответствие
//                - ФиксированноеСоответствие
//
// Возвращаемое значение:
//  Строка - перечисление типов через запятую.
//
Функция ПредставлениеТипов(ОжидаемыеТипы)

	МаксимальноТипов = 10;
	ТипОжидаемых     = ТипЗнч(ОжидаемыеТипы);

	Если ТипОжидаемых = Тип("Массив")
		Или ТипОжидаемых = Тип("ФиксированныйМассив")
		Или ТипОжидаемых = Тип("Соответствие")
		Или ТипОжидаемых = Тип("ФиксированноеСоответствие") Тогда

		Результат = "";
		Индекс    = 0;

		Для Каждого Элемент Из ОжидаемыеТипы Цикл

			Если ТипОжидаемых = Тип("Соответствие")
				Или ТипОжидаемых = Тип("ФиксированноеСоответствие") Тогда
				ТекущийТип = Элемент.Ключ;
			Иначе
				ТекущийТип = Элемент;
			КонецЕсли;

			Если Не ПустаяСтрока(Результат) Тогда
				Результат = Результат + ", ";
			КонецЕсли;

			Результат = Результат + Строка(ТекущийТип);
			Индекс    = Индекс + 1;

			Если Индекс > МаксимальноТипов Тогда
				Результат = СтрШаблон("%1,... (всего %2 типов)", Результат, ОжидаемыеТипы.Количество());
				Прервать;
			КонецЕсли;

		КонецЦикла;

		Возврат Результат;

	КонецЕсли;

	Возврат Строка(ОжидаемыеТипы);

КонецФункции

#КонецОбласти
