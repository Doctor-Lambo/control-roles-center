#Область ПрограммныйИнтерфейс

// Формирует и записывает XML-файлы adopted-объектов для всех уникальных объектов из пакета ролей.
// Использует DOM для формирования XML и ЗаписьDOM для записи в файлы.
//
// Параметры:
//  ПакетРолей         - Массив - массив структур-моделей ролей
//  КаталогИсходников  - Строка - путь к каталогу ExtensionConfiguration
//
// Возвращаемое значение:
//  Число - количество записанных файлов
//
Функция СформироватьВсеОбъекты(ПакетРолей, КаталогИсходников) Экспорт

	УникальныеОбъекты = СобратьУникальныеОбъекты(ПакетРолей);
	КоличествоЗаписанных = 0;
	ШаблонXML = ШаблонМетаданныхОбъекта();

	// Имена ролей для включения в Content подсистем
	ИменаРолей = Новый Массив;
	Для Каждого МодельРоли Из ПакетРолей Цикл
		ИменаРолей.Добавить(МодельРоли.Имя);
	КонецЦикла;

	Для Каждого КлючОбъекта Из УникальныеОбъекты Цикл

		ПараметрыОбъекта = КлючОбъекта.Значение;
		ВидМетаданных    = ПараметрыОбъекта.Ключ;
		ИмяОбъекта       = ПараметрыОбъекта.Значение;

		Попытка
			ЗаписатьXMLОбъекта(ВидМетаданных, ИмяОбъекта, КаталогИсходников, ШаблонXML, ИменаРолей);
			КоличествоЗаписанных = КоличествоЗаписанных + 1;
		Исключение
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = СтрШаблон("ОШИБКА adopted: %1.%2 - %3",
				ВидМетаданных, ИмяОбъекта, цур_ОбщегоНазначения.ОписаниеОшибкиПодробное(ИнформацияОбОшибке()));
			Сообщение.Сообщить();
		КонецПопытки;

	КонецЦикла;

	Возврат КоличествоЗаписанных;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Формирует и записывает XML-файл одного adopted-объекта через DOM.
//
// Параметры:
//  ВидМетаданных     - Строка - строковый идентификатор вида
//  ИмяОбъекта        - Строка - имя объекта метаданных
//  КаталогИсходников - Строка - путь к каталогу ExtensionConfiguration
//  ШаблонXML         - Строка - XML-шаблон MetaDataObject
//
Процедура ЗаписатьXMLОбъекта(ВидМетаданных, ИмяОбъекта, КаталогИсходников, ШаблонXML, ИменаРолей = Неопределено)

	// Планы обмена требуют ThisNode в InternalInfo — пока пропускаем
	Если ВидМетаданных = "ExchangePlan" Тогда
		Возврат;
	КонецЕсли;

	// Подсистемы и планы обмена — в бэклоге (требуют ExtendedConfigurationObject с реальным UUID)
	Если ВидМетаданных = "Subsystem" Тогда
		Возврат;
	КонецЕсли;

	ОписаниеВида = цур_РеестрМетаданныхСерверПовтИсп.ОписаниеВида(ВидМетаданных);

	Если ОписаниеВида = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ДокументDOM = ПрочитатьШаблон(ШаблонXML);

	ЭлементОбъекта = ДокументDOM.СоздатьЭлемент(ОписаниеВида.ИмяЭлементаРасширения);
	УстановитьАтрибутУИД(ДокументDOM, ЭлементОбъекта);

	//BSLLS:LatinAndCyrillicSymbolInWord-off
	GeneratedTypes = ОписаниеВида.GeneratedTypes;
	Если GeneratedTypes.Количество() > 0 Тогда
		ДобавитьInternalInfo(ДокументDOM, ЭлементОбъекта, ИмяОбъекта, GeneratedTypes);
	КонецЕсли;
	//BSLLS:LatinAndCyrillicSymbolInWord-on

	ДобавитьСвойстваОбъекта(ДокументDOM, ЭлементОбъекта, ИмяОбъекта);

	Если НЕ ОбъектБезПодчиненныхЭлементов(ВидМетаданных) Тогда

		ЭлементДочерних = ДокументDOM.СоздатьЭлемент("ChildObjects");
		ЭлементОбъекта.ДобавитьДочерний(ЭлементДочерних);

	КонецЕсли;

	ДокументDOM.ПервыйДочерний.ДобавитьДочерний(ЭлементОбъекта);

	// Путь файла: для подсистем — Subsystems/Имя.xml
	ИмяКаталога  = ОписаниеВида.ИмяКоллекцииРасширения;
	ПутьКаталога = цур_ФайловыеОперацииСервер.ОбъединитьПути(КаталогИсходников, ИмяКаталога);
	цур_ФайловыеОперацииСервер.СоздатьКаталогиПоПути(ПутьКаталога);

	ПутьФайла = цур_ФайловыеОперацииСервер.ОбъединитьПути(ПутьКаталога, ИмяОбъекта + ".xml");
	ЗаписатьДокументDOM(ДокументDOM, ПутьФайла);

КонецПроцедуры

// Разбирает XML-шаблон в документ DOM.
//
// Параметры:
//  ШаблонXML - Строка - текст XML-шаблона
//
// Возвращаемое значение:
//  ДокументDOM - разобранный DOM-документ
//
Функция ПрочитатьШаблон(ШаблонXML)

	ЧтениеXML = Новый ЧтениеXML;
	ЧтениеXML.УстановитьСтроку(ШаблонXML);

	ПостроительDOM = Новый ПостроительDOM;
	ДокументDOM = ПостроительDOM.Прочитать(ЧтениеXML);
	ЧтениеXML.Закрыть();

	Возврат ДокументDOM;

КонецФункции

// Возвращает XML-шаблон корневого элемента MetaDataObject.
//
// Возвращаемое значение:
//  Строка - XML-шаблон
//
Функция ШаблонМетаданныхОбъекта()

	Возврат
		"<?xml version=""1.0"" encoding=""UTF-8""?>
		|<MetaDataObject xmlns=""http://v8.1c.ru/8.3/MDClasses"""
		+ " xmlns:app=""http://v8.1c.ru/8.2/managed-application/core"""
		+ " xmlns:cfg=""http://v8.1c.ru/8.1/data/enterprise/current-config"""
		+ " xmlns:cmi=""http://v8.1c.ru/8.2/managed-application/cmi"""
		+ " xmlns:ent=""http://v8.1c.ru/8.1/data/enterprise"""
		+ " xmlns:lf=""http://v8.1c.ru/8.2/managed-application/logform"""
		+ " xmlns:style=""http://v8.1c.ru/8.1/data/ui/style"""
		+ " xmlns:sys=""http://v8.1c.ru/8.1/data/ui/fonts/system"""
		+ " xmlns:v8=""http://v8.1c.ru/8.1/data/core"""
		+ " xmlns:v8ui=""http://v8.1c.ru/8.1/data/ui"""
		+ " xmlns:web=""http://v8.1c.ru/8.1/data/ui/colors/web"""
		+ " xmlns:win=""http://v8.1c.ru/8.1/data/ui/colors/windows"""
		+ " xmlns:xen=""http://v8.1c.ru/8.3/xcf/enums"""
		+ " xmlns:xpr=""http://v8.1c.ru/8.3/xcf/predef"""
		+ " xmlns:xr=""http://v8.1c.ru/8.3/xcf/readable"""
		+ " xmlns:xs=""http://www.w3.org/2001/XMLSchema"""
		+ " xmlns:xsi=""http://www.w3.org/2001/XMLSchema-instance"""
		+ " version=""2.20"">
		|</MetaDataObject>";

КонецФункции

// Устанавливает атрибут uuid со случайным значением на элемент DOM.
//
// Параметры:
//  ДокументDOM - ДокументDOM - документ DOM
//  Элемент     - ЭлементDOM  - целевой элемент
//
Процедура УстановитьАтрибутУИД(ДокументDOM, Элемент)

	АтрибутУИД = ДокументDOM.СоздатьАтрибут("uuid");
	АтрибутУИД.Значение = Строка(Новый УникальныйИдентификатор());
	Элемент.Атрибуты.УстановитьИменованныйЭлемент(АтрибутУИД);

КонецПроцедуры

// Добавляет блок InternalInfo с элементами GeneratedType в элемент объекта.
//
// Параметры:
//  ДокументDOM    - ДокументDOM  - документ DOM
//  ЭлементОбъекта - ЭлементDOM   - элемент объекта (Catalog, Document и т.д.)
//  ИмяОбъекта     - Строка       - имя объекта метаданных
//  GeneratedTypes - Соответствие  - ключ: имя типа, значение: категория
//
//BSLLS:LatinAndCyrillicSymbolInWord-off
Процедура ДобавитьInternalInfo(ДокументDOM, ЭлементОбъекта, ИмяОбъекта, GeneratedTypes)
//BSLLS:LatinAndCyrillicSymbolInWord-on

	НС_XR = "http://v8.1c.ru/8.3/xcf/readable";

	ВнутренняяИнформация = ДокументDOM.СоздатьЭлемент("InternalInfo");

	Для Каждого ЭлементТипа Из GeneratedTypes Цикл

		//BSLLS:LatinAndCyrillicSymbolInWord-off
		ЭлементGT = ДокументDOM.СоздатьЭлемент(НС_XR, "GeneratedType");
		//BSLLS:LatinAndCyrillicSymbolInWord-on

		АтрибутИмени = ДокументDOM.СоздатьАтрибут("name");
		АтрибутИмени.Значение = СтрШаблон("%1.%2", ЭлементТипа.Ключ, ИмяОбъекта);
		ЭлементGT.Атрибуты.УстановитьИменованныйЭлемент(АтрибутИмени);

		АтрибутКатегории = ДокументDOM.СоздатьАтрибут("category");
		АтрибутКатегории.Значение = ЭлементТипа.Значение;
		ЭлементGT.Атрибуты.УстановитьИменованныйЭлемент(АтрибутКатегории);

		//BSLLS:LatinAndCyrillicSymbolInWord-off
		ЭлементTypeId = ДокументDOM.СоздатьЭлемент(НС_XR, "TypeId");
		//BSLLS:LatinAndCyrillicSymbolInWord-on
		ЭлементTypeId.ТекстовоеСодержимое = Строка(Новый УникальныйИдентификатор());
		ЭлементGT.ДобавитьДочерний(ЭлементTypeId);

		//BSLLS:LatinAndCyrillicSymbolInWord-off
		ЭлементValueId = ДокументDOM.СоздатьЭлемент(НС_XR, "ValueId");
		//BSLLS:LatinAndCyrillicSymbolInWord-on
		ЭлементValueId.ТекстовоеСодержимое = Строка(Новый УникальныйИдентификатор());
		ЭлементGT.ДобавитьДочерний(ЭлементValueId);

		ВнутренняяИнформация.ДобавитьДочерний(ЭлементGT);

	КонецЦикла;

	ЭлементОбъекта.ДобавитьДочерний(ВнутренняяИнформация);

КонецПроцедуры

// Добавляет блок Properties (Name, Comment, ObjectBelonging=Adopted).
//
// Параметры:
//  ДокументDOM    - ДокументDOM - документ DOM
//  ЭлементОбъекта - ЭлементDOM  - элемент объекта
//  ИмяОбъекта     - Строка      - имя объекта метаданных
//
Процедура ДобавитьСвойстваОбъекта(ДокументDOM, ЭлементОбъекта, ИмяОбъекта)

	Свойства = ДокументDOM.СоздатьЭлемент("Properties");

	ЭлементПринадлежность = ДокументDOM.СоздатьЭлемент("ObjectBelonging");
	ЭлементПринадлежность.ТекстовоеСодержимое = "Adopted";
	Свойства.ДобавитьДочерний(ЭлементПринадлежность);

	ЭлементИмя = ДокументDOM.СоздатьЭлемент("Name");
	ЭлементИмя.ТекстовоеСодержимое = ИмяОбъекта;
	Свойства.ДобавитьДочерний(ЭлементИмя);

	ЭлементКомментарий = ДокументDOM.СоздатьЭлемент("Comment");
	Свойства.ДобавитьДочерний(ЭлементКомментарий);

	ЭлементОбъекта.ДобавитьДочерний(Свойства);

КонецПроцедуры

// Генерирует XML adopted-подсистемы и рекурсивно — вложенных подсистем.
//
// Параметры:
//  ИмяОбъекта        - Строка - имя подсистемы (как в правах: "_ДемоАнкетирование")
//  КаталогИсходников - Строка - путь к ExtensionConfiguration
//  ШаблонXML         - Строка - XML-шаблон MetaDataObject
//  ОбъектМДПодсистемы - ОбъектМетаданных - метаданные подсистемы (Неопределено — искать по имени)
//  ПутьКаталогаПодсистем - Строка - каталог для записи (Неопределено — Subsystems)
//
Процедура ЗаписатьПодсистему(ИмяОбъекта, КаталогИсходников, ШаблонXML,
		ОбъектМДПодсистемы = Неопределено, ПутьКаталогаПодсистем = Неопределено,
		ИменаРолей = Неопределено)

	// Находим метаданные подсистемы
	Если ОбъектМДПодсистемы = Неопределено Тогда
		ОбъектМДПодсистемы = Метаданные.Подсистемы.Найти(ИмяОбъекта);
	КонецЕсли;

	Если ОбъектМДПодсистемы = Неопределено Тогда
		Возврат;
	КонецЕсли;

	НС_XR = "http://v8.1c.ru/8.3/xcf/readable";

	ДокументDOM = ПрочитатьШаблон(ШаблонXML);

	ЭлементПодсистемы = ДокументDOM.СоздатьЭлемент("Subsystem");
	УстановитьАтрибутУИД(ДокументDOM, ЭлементПодсистемы);

	// InternalInfo с PropertyState (CommandInterface = Extended)
	ВнутренняяИнформация = ДокументDOM.СоздатьЭлемент("InternalInfo");

	ЭлементСостояние = ДокументDOM.СоздатьЭлемент(НС_XR, "PropertyState");
	ЭлементСвойство = ДокументDOM.СоздатьЭлемент(НС_XR, "Property");
	ЭлементСвойство.ТекстовоеСодержимое = "CommandInterface";
	ЭлементСостояние.ДобавитьДочерний(ЭлементСвойство);
	ЭлементЗначение = ДокументDOM.СоздатьЭлемент(НС_XR, "State");
	ЭлементЗначение.ТекстовоеСодержимое = "Extended";
	ЭлементСостояние.ДобавитьДочерний(ЭлементЗначение);
	ВнутренняяИнформация.ДобавитьДочерний(ЭлементСостояние);

	ЭлементПодсистемы.ДобавитьДочерний(ВнутренняяИнформация);

	// Properties
	Свойства = ДокументDOM.СоздатьЭлемент("Properties");

	ЭлементПринадлежность = ДокументDOM.СоздатьЭлемент("ObjectBelonging");
	ЭлементПринадлежность.ТекстовоеСодержимое = "Adopted";
	Свойства.ДобавитьДочерний(ЭлементПринадлежность);

	ЭлементИмя = ДокументDOM.СоздатьЭлемент("Name");
	ЭлементИмя.ТекстовоеСодержимое = ИмяОбъекта;
	Свойства.ДобавитьДочерний(ЭлементИмя);

	ЭлементКомментарий = ДокументDOM.СоздатьЭлемент("Comment");
	Свойства.ДобавитьДочерний(ЭлементКомментарий);

	// Content — роли, включённые в подсистему
	ЭлементСодержимое = ДокументDOM.СоздатьЭлемент("Content");

	Если ИменаРолей <> Неопределено Тогда

		Для Каждого ИмяРоли Из ИменаРолей Цикл

			ЭлементItem = ДокументDOM.СоздатьЭлемент(НС_XR, "Item");

			АтрибутТипа = ДокументDOM.СоздатьАтрибут("http://www.w3.org/2001/XMLSchema-instance", "type");
			АтрибутТипа.Значение = "xr:MDObjectRef";
			ЭлементItem.Атрибуты.УстановитьИменованныйЭлемент(АтрибутТипа);

			ЭлементItem.ТекстовоеСодержимое = "Role." + ИмяРоли;
			ЭлементСодержимое.ДобавитьДочерний(ЭлементItem);

		КонецЦикла;

	КонецЕсли;

	Свойства.ДобавитьДочерний(ЭлементСодержимое);

	ЭлементПодсистемы.ДобавитьДочерний(Свойства);

	// ChildObjects — вложенные подсистемы
	ЭлементДочерних = ДокументDOM.СоздатьЭлемент("ChildObjects");

	Для Каждого Дочерняя Из ОбъектМДПодсистемы.Подсистемы Цикл

		ЧастиИмени = СтрРазделить(Дочерняя.ПолноеИмя(), ".");
		ИмяДочерней = ЧастиИмени[ЧастиИмени.ВГраница()];

		ЭлементВложенной = ДокументDOM.СоздатьЭлемент("Subsystem");
		ЭлементВложенной.ТекстовоеСодержимое = ИмяДочерней;
		ЭлементДочерних.ДобавитьДочерний(ЭлементВложенной);

	КонецЦикла;

	ЭлементПодсистемы.ДобавитьДочерний(ЭлементДочерних);
	ДокументDOM.ПервыйДочерний.ДобавитьДочерний(ЭлементПодсистемы);

	// Путь файла
	Если ПутьКаталогаПодсистем = Неопределено Тогда
		ПутьКаталога = цур_ФайловыеОперацииСервер.ОбъединитьПути(КаталогИсходников, "Subsystems");
	Иначе
		ПутьКаталога = ПутьКаталогаПодсистем;
	КонецЕсли;

	цур_ФайловыеОперацииСервер.СоздатьКаталогиПоПути(ПутьКаталога);
	ПутьФайла = цур_ФайловыеОперацииСервер.ОбъединитьПути(ПутьКаталога, ИмяОбъекта + ".xml");
	ЗаписатьДокументDOM(ДокументDOM, ПутьФайла);

	// Рекурсивно генерируем вложенные подсистемы
	Для Каждого Дочерняя Из ОбъектМДПодсистемы.Подсистемы Цикл

		ЧастиИмени = СтрРазделить(Дочерняя.ПолноеИмя(), ".");
		ИмяДочерней = ЧастиИмени[ЧастиИмени.ВГраница()];

		ПутьДочерней = цур_ФайловыеОперацииСервер.ОбъединитьПути(
			ПутьКаталога,
			цур_ФайловыеОперацииСервер.ОбъединитьПути(ИмяОбъекта, "Subsystems"));

		ЗаписатьПодсистему(ИмяДочерней, КаталогИсходников, ШаблонXML,
			Дочерняя, ПутьДочерней, ИменаРолей);

	КонецЦикла;

КонецПроцедуры

// Проверяет, нужен ли элемент ChildObjects для данного вида метаданных.
// Объекты без подчинённых: ОбщаяКоманда, ПараметрСеанса, ОбщийРеквизит, ОбщаяФорма, Константа.
//
// Параметры:
//  ВидМетаданных - Строка - строковый идентификатор вида
//
// Возвращаемое значение:
//  Булево - Истина, если объект не имеет подчинённых элементов
//
Функция ОбъектБезПодчиненныхЭлементов(ВидМетаданных)

	ВидыБезДочерних = Новый Соответствие;
	ВидыБезДочерних.Вставить("CommonCommand",     Истина);
	ВидыБезДочерних.Вставить("SessionParameter",  Истина);
	ВидыБезДочерних.Вставить("CommonAttribute",   Истина);
	ВидыБезДочерних.Вставить("CommonForm",         Истина);
	ВидыБезДочерних.Вставить("Constant",           Истина);

	Возврат ВидыБезДочерних.Получить(ВидМетаданных) <> Неопределено;

КонецФункции

// Записывает документ DOM в XML-файл через ЗаписьDOM + ЗаписьXML.ОткрытьФайл.
//
// Параметры:
//  ДокументDOM - ДокументDOM - документ для записи
//  ПутьФайла   - Строка      - полный путь к файлу
//
Процедура ЗаписатьДокументDOM(ДокументDOM, ПутьФайла)

	ЗаписьXML = Новый ЗаписьXML;
	ЗаписьXML.ОткрытьФайл(ПутьФайла);

	СохранениеDOM = Новый ЗаписьDOM;
	СохранениеDOM.Записать(ДокументDOM, ЗаписьXML);

	ЗаписьXML.Закрыть();

КонецПроцедуры

// Собирает уникальные пары (ВидОбъекта, ИмяОбъекта) из всех моделей ролей пакета.
//
// Параметры:
//  ПакетРолей - Массив - массив структур-моделей ролей
//
// Возвращаемое значение:
//  Соответствие - ключ: "ВидОбъекта|ИмяОбъекта", значение: Структура("Ключ, Значение")
//
Функция СобратьУникальныеОбъекты(ПакетРолей)

	УникальныеОбъекты = Новый Соответствие;

	Для Каждого МодельРоли Из ПакетРолей Цикл

		Для Каждого СтрокаПрава Из МодельРоли.Права Цикл

			ВидОбъекта = СтрокаПрава.ВидОбъекта;
			ИмяОбъекта = СтрокаПрава.ИмяОбъекта;

			Если НЕ ЗначениеЗаполнено(ВидОбъекта) Или НЕ ЗначениеЗаполнено(ИмяОбъекта) Тогда
				Продолжить;
			КонецЕсли;

			КлючЗаписи = СтрШаблон("%1|%2", ВидОбъекта, ИмяОбъекта);

			Если УникальныеОбъекты.Получить(КлючЗаписи) <> Неопределено Тогда
				Продолжить;
			КонецЕсли;

			ПараметрыОбъекта = Новый Структура("Ключ, Значение", ВидОбъекта, ИмяОбъекта);
			УникальныеОбъекты.Вставить(КлючЗаписи, ПараметрыОбъекта);

		КонецЦикла;

	КонецЦикла;

	Возврат УникальныеОбъекты;

КонецФункции

#КонецОбласти
