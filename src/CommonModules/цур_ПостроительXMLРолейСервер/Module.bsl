#Область ПрограммныйИнтерфейс

// Создаёт новый контекст построителя Rights.xml.
// Построитель работает в потоковом режиме через ЗаписьXML в строку.
//
// Возвращаемое значение:
//  Структура - контекст построителя:
//    * ЗаписьXML - ЗаписьXML  - поток записи XML
//    * Состояние - Строка - текущее состояние ("НеНачат", "РольНачата", "ОбъектНачат")
//
Функция НовыйПостроитель() Экспорт

	Запись = Новый ЗаписьXML;
	Запись.УстановитьСтроку("UTF-8");

	Построитель = Новый Структура;
	Построитель.Вставить("ЗаписьXML",  Запись);
	Построитель.Вставить("Состояние", "НеНачат");

	Возврат Построитель;

КонецФункции

// Открывает корневой элемент <Rights> и записывает корневые флаги роли.
//
// Параметры:
//  Построитель   - Структура - контекст построителя, см. НовыйПостроитель()
//  ПараметрыРоли - Структура - параметры роли:
//    * УстанавливатьДляНовыхОбъектов         - Булево
//    * УстанавливатьДляРеквизитовПоУмолчанию - Булево
//    * НезависимыеПраваПодчиненных           - Булево
//
Процедура НачатьРоль(Построитель, ПараметрыРоли) Экспорт

	Запись = Построитель.ЗаписьXML;

	Запись.ЗаписатьОбъявлениеXML();

	Запись.ЗаписатьНачалоЭлемента("Rights");
	Запись.ЗаписатьАтрибут("xmlns",     "http://v8.1c.ru/8.2/roles");
	Запись.ЗаписатьАтрибут("xmlns:xs",  "http://www.w3.org/2001/XMLSchema");
	Запись.ЗаписатьАтрибут("xmlns:xsi", "http://www.w3.org/2001/XMLSchema-instance");
	Запись.ЗаписатьАтрибут("version",   "2.20");

	ЗаписатьЭлементСЗначением(Запись, "setForNewObjects",
		?(ПараметрыРоли.УстанавливатьДляНовыхОбъектов, "true", "false"));

	ЗаписатьЭлементСЗначением(Запись, "setForAttributesByDefault",
		?(ПараметрыРоли.УстанавливатьДляРеквизитовПоУмолчанию, "true", "false"));

	ЗаписатьЭлементСЗначением(Запись, "independentRightsOfChildObjects",
		?(ПараметрыРоли.НезависимыеПраваПодчиненных, "true", "false"));

	Построитель.Состояние = "РольНачата";

КонецПроцедуры

// Открывает блок <object> для указанного объекта метаданных.
//
// Параметры:
//  Построитель       - Структура - контекст построителя
//  ПолноеИмяОбъекта  - Строка   - полное dot-имя объекта (например "Catalog.Контрагенты")
//
Процедура НачатьОбъект(Построитель, ПолноеИмяОбъекта) Экспорт

	Запись = Построитель.ЗаписьXML;

	Запись.ЗаписатьНачалоЭлемента("object");
	ЗаписатьЭлементСЗначением(Запись, "name", ПолноеИмяОбъекта);

	Построитель.Состояние = "ОбъектНачат";

КонецПроцедуры

// Добавляет право без ограничения в текущий открытый блок <object>.
//
// Параметры:
//  Построитель - Структура - контекст построителя
//  ИмяПрава   - Строка    - имя права (например "Read", "Update")
//  Значение    - Булево    - значение права
//
Процедура ДобавитьПраво(Построитель, ИмяПрава, Значение) Экспорт

	Запись = Построитель.ЗаписьXML;

	Запись.ЗаписатьНачалоЭлемента("right");
	ЗаписатьЭлементСЗначением(Запись, "name",  ИмяПрава);
	ЗаписатьЭлементСЗначением(Запись, "value", ?(Значение, "true", "false"));
	Запись.ЗаписатьКонецЭлемента(); // right

КонецПроцедуры

// Добавляет право с RLS-ограничением в текущий открытый блок <object>.
// Амперсанды в условии экранируются как &amp; для корректного XML.
//
// Параметры:
//  Построитель - Структура - контекст построителя
//  ИмяПрава   - Строка    - имя права
//  Значение    - Булево    - значение права
//  Условие     - Строка    - текст условия RLS (амперсанды будут экранированы)
//  Поля        - Строка    - поля ограничения, разделённые переносом строки (необязательный)
//
Процедура ДобавитьПравоСОграничением(Построитель, ИмяПрава, Значение, Условие, Поля = "") Экспорт

	Запись = Построитель.ЗаписьXML;

	Запись.ЗаписатьНачалоЭлемента("right");
	ЗаписатьЭлементСЗначением(Запись, "name",  ИмяПрава);
	ЗаписатьЭлементСЗначением(Запись, "value", ?(Значение, "true", "false"));

	Запись.ЗаписатьНачалоЭлемента("restrictionByCondition");
	ЗаписатьЭлементСЗначением(Запись, "condition", УсловиеДляXML(Условие));

	Если НЕ ПустаяСтрока(Поля) Тогда
		МассивПолей = СтрРазделить(Поля, Символы.ПС, Ложь);
		Для Каждого ИмяПоля Из МассивПолей Цикл

			ИмяПоляТримм = СокрЛП(ИмяПоля);
			Если НЕ ПустаяСтрока(ИмяПоляТримм) И ИмяПоляТримм <> "<Прочие поля>" Тогда
				ЗаписатьЭлементСЗначением(Запись, "field", ИмяПоляТримм);
			КонецЕсли;

		КонецЦикла;
	КонецЕсли;

	Запись.ЗаписатьКонецЭлемента(); // restrictionByCondition

	Запись.ЗаписатьКонецЭлемента(); // right

КонецПроцедуры

// Закрывает текущий открытый блок <object>.
//
// Параметры:
//  Построитель - Структура - контекст построителя
//
Процедура ЗавершитьОбъект(Построитель) Экспорт

	Построитель.ЗаписьXML.ЗаписатьКонецЭлемента(); // object
	Построитель.Состояние = "РольНачата";

КонецПроцедуры

// Добавляет шаблон ограничения в корень документа (вне блоков <object>).
//
// Параметры:
//  Построитель  - Структура - контекст построителя
//  ИмяШаблона   - Строка   - имя шаблона
//  ТекстШаблона - Строка   - текст условия шаблона
//
Процедура ДобавитьШаблон(Построитель, ИмяШаблона, ТекстШаблона) Экспорт

	Запись = Построитель.ЗаписьXML;

	Запись.ЗаписатьНачалоЭлемента("restrictionTemplate");
	ЗаписатьЭлементСЗначением(Запись, "name",      ИмяШаблона);
	ЗаписатьЭлементСЗначением(Запись, "condition",  УсловиеДляXML(ТекстШаблона));
	Запись.ЗаписатьКонецЭлемента(); // restrictionTemplate

КонецПроцедуры

// Закрывает корневой элемент <Rights> и возвращает итоговую XML-строку.
//
// Параметры:
//  Построитель - Структура - контекст построителя
//
// Возвращаемое значение:
//  Строка - сформированный XML-текст файла Rights.xml
//
Функция ЗавершитьРоль(Построитель) Экспорт

	Построитель.ЗаписьXML.ЗаписатьКонецЭлемента(); // Rights
	Построитель.Состояние = "Завершён";

	Возврат Построитель.ЗаписьXML.Закрыть();

КонецФункции

// Высокоуровневый метод: формирует XML-содержимое файла Rights.xml из нормализованной модели роли.
//
// Параметры:
//  МодельРоли - Структура - нормализованная модель роли (см. цур_МодельРолейСервер.НовыеПараметрыРоли()):
//    * УстанавливатьДляНовыхОбъектов         - Булево
//    * УстанавливатьДляРеквизитовПоУмолчанию - Булево
//    * НезависимыеПраваПодчиненных           - Булево
//    * Права       - ТаблицаЗначений - колонки: ВидОбъекта, ИмяОбъекта, ИмяПрава, ТипРеквизита,
//                                               ИмяРеквизита, ИмяРеквизитаТЧ, ЗначениеПрава
//    * Ограничения - ТаблицаЗначений - колонки: ВидОбъекта, ИмяОбъекта, ИмяПрава, УсловиеОграничения
//    * Шаблоны     - ТаблицаЗначений - колонки: ИмяШаблона, ТекстШаблона
//
// Возвращаемое значение:
//  Строка - XML-текст файла Rights.xml
//
Функция СформироватьRightsXML(МодельРоли) Экспорт

	Построитель = НовыйПостроитель();
	НачатьРоль(Построитель, МодельРоли);

	// Индекс ограничений: "ВидОбъекта|ИмяОбъекта|ИмяПрава" → УсловиеОграничения
	ИндексОграничений = ПостроитьИндексОграничений(МодельРоли.Ограничения);

	// Группируем права по полному dot-имени объекта
	ИндексОбъектов = СгруппироватьПраваПоОбъектам(МодельРоли.Права);

	// Записываем объекты и права
	Для Каждого ЭлементОбъекта Из ИндексОбъектов Цикл

		ПолноеИмяОбъекта = ЭлементОбъекта.Ключ;
		СтрокиПрав       = ЭлементОбъекта.Значение;

		НачатьОбъект(Построитель, ПолноеИмяОбъекта);

		Для Каждого СтрокаПрава Из СтрокиПрав Цикл

			КлючОграничения    = СтрокаПрава.КлючОграничения;
			ДанныеОграничения = ИндексОграничений.Получить(КлючОграничения);

			Если ДанныеОграничения <> Неопределено Тогда
				ДобавитьПравоСОграничением(Построитель,
					СтрокаПрава.ИмяПрава,
					СтрокаПрава.ЗначениеПрава,
					ДанныеОграничения.Условие,
					ДанныеОграничения.Поля);
			Иначе
				ДобавитьПраво(Построитель,
					СтрокаПрава.ИмяПрава,
					СтрокаПрава.ЗначениеПрава);
			КонецЕсли;

		КонецЦикла;

		ЗавершитьОбъект(Построитель);

	КонецЦикла;

	// Шаблоны ограничений — после блоков object
	Для Каждого СтрокаШаблона Из МодельРоли.Шаблоны Цикл
		ДобавитьШаблон(Построитель, СтрокаШаблона.ИмяШаблона, СтрокаШаблона.ТекстШаблона);
	КонецЦикла;

	Возврат ЗавершитьРоль(Построитель);

КонецФункции

// Формирует XML-содержимое файла метаданных роли (ИмяРоли.xml).
//
// Параметры:
//  МодельРоли - Структура - нормализованная модель роли (см. цур_МодельРолейСервер.НовыеПараметрыРоли()):
//    * Имя        - Строка - программное имя роли
//    * Синоним    - Строка - синоним роли
//    * Комментарий - Строка - комментарий
//
// Возвращаемое значение:
//  Строка - XML-текст файла ИмяРоли.xml
//
Функция СформироватьМетаданныеРолиXML(МодельРоли) Экспорт

	УИД = Строка(Новый УникальныйИдентификатор);

	Запись = Новый ЗаписьXML;
	Запись.УстановитьСтроку("UTF-8");
	Запись.ЗаписатьОбъявлениеXML();

	Запись.ЗаписатьНачалоЭлемента("MetaDataObject");
	Запись.ЗаписатьАтрибут("xmlns",      "http://v8.1c.ru/8.3/MDClasses");
	Запись.ЗаписатьАтрибут("xmlns:app",  "http://v8.1c.ru/8.2/managed-application/core");
	Запись.ЗаписатьАтрибут("xmlns:cfg",  "http://v8.1c.ru/8.1/data/enterprise/current-config");
	Запись.ЗаписатьАтрибут("xmlns:cmi",  "http://v8.1c.ru/8.2/managed-application/cmi");
	Запись.ЗаписатьАтрибут("xmlns:ent",  "http://v8.1c.ru/8.1/data/enterprise");
	Запись.ЗаписатьАтрибут("xmlns:lf",   "http://v8.1c.ru/8.2/managed-application/logform");
	Запись.ЗаписатьАтрибут("xmlns:style", "http://v8.1c.ru/8.1/data/ui/style");
	Запись.ЗаписатьАтрибут("xmlns:sys",  "http://v8.1c.ru/8.1/data/ui/fonts/system");
	Запись.ЗаписатьАтрибут("xmlns:v8",   "http://v8.1c.ru/8.1/data/core");
	Запись.ЗаписатьАтрибут("xmlns:v8ui", "http://v8.1c.ru/8.1/data/ui");
	Запись.ЗаписатьАтрибут("xmlns:web",  "http://v8.1c.ru/8.1/data/ui/colors/web");
	Запись.ЗаписатьАтрибут("xmlns:win",  "http://v8.1c.ru/8.1/data/ui/colors/windows");
	Запись.ЗаписатьАтрибут("xmlns:xen",  "http://v8.1c.ru/8.3/xcf/enums");
	Запись.ЗаписатьАтрибут("xmlns:xpr",  "http://v8.1c.ru/8.3/xcf/predef");
	Запись.ЗаписатьАтрибут("xmlns:xr",   "http://v8.1c.ru/8.3/xcf/readable");
	Запись.ЗаписатьАтрибут("xmlns:xs",   "http://www.w3.org/2001/XMLSchema");
	Запись.ЗаписатьАтрибут("xmlns:xsi",  "http://www.w3.org/2001/XMLSchema-instance");
	Запись.ЗаписатьАтрибут("version",    "2.20");

	Запись.ЗаписатьНачалоЭлемента("Role");
	Запись.ЗаписатьАтрибут("uuid", УИД);

	Запись.ЗаписатьНачалоЭлемента("Properties");

	ЗаписатьЭлементСЗначением(Запись, "Name", МодельРоли.Имя);

	Запись.ЗаписатьНачалоЭлемента("Synonym");
	Запись.ЗаписатьНачалоЭлемента("v8:item");
	ЗаписатьЭлементСЗначением(Запись, "v8:lang",    "ru");
	ЗаписатьЭлементСЗначением(Запись, "v8:content", МодельРоли.Синоним);
	Запись.ЗаписатьКонецЭлемента(); // v8:item
	Запись.ЗаписатьКонецЭлемента(); // Synonym

	Запись.ЗаписатьНачалоЭлемента("Comment");
	Если Не ПустаяСтрока(МодельРоли.Комментарий) Тогда
		Запись.ЗаписатьТекст(МодельРоли.Комментарий);
	КонецЕсли;
	Запись.ЗаписатьКонецЭлемента(); // Comment

	Запись.ЗаписатьКонецЭлемента(); // Properties
	Запись.ЗаписатьКонецЭлемента(); // Role
	Запись.ЗаписатьКонецЭлемента(); // MetaDataObject

	Возврат Запись.Закрыть();

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Записывает простой элемент XML с текстовым содержимым.
//
// Параметры:
//  Запись    - ЗаписьXML - поток записи XML
//  ИмяЭлемента - Строка - имя XML-элемента
//  Значение    - Строка - текстовое содержимое элемента
//
Процедура ЗаписатьЭлементСЗначением(Запись, ИмяЭлемента, Значение)

	Запись.ЗаписатьНачалоЭлемента(ИмяЭлемента);
	Запись.ЗаписатьТекст(Значение);
	Запись.ЗаписатьКонецЭлемента();

КонецПроцедуры

// Экранирует амперсанды в тексте условия RLS для корректного XML-вывода.
// ЗаписьXML.ЗаписатьТекст() автоматически экранирует спецсимволы (<, >, &),
// поэтому для условий, уже содержащих &amp;, нужно передавать исходный & — платформа сама справится.
// Данная функция нормализует ввод: заменяет уже экранированные &amp; обратно на &,
// чтобы избежать двойного экранирования.
//
// Параметры:
//  Условие - Строка - текст условия (может содержать & или &amp;)
//
// Возвращаемое значение:
//  Строка - нормализованный текст с одиночными &
//
Функция УсловиеДляXML(Условие)

	// Нормализация: если условие уже содержит &amp; — разворачиваем в &,
	// так как ЗаписатьТекст сам выполнит экранирование
	Возврат СтрЗаменить(Условие, "&amp;", "&");

КонецФункции

// Строит индекс ограничений из таблицы значений.
// Ключ индекса: "ВидОбъекта|ИмяОбъекта|ИмяПрава"
//
// Параметры:
//  Ограничения - ТаблицаЗначений - таблица ограничений (колонки: ВидОбъекта, ИмяОбъекта,
//                                  ИмяПрава, УсловиеОграничения, Поля)
//
// Возвращаемое значение:
//  Соответствие - ключ → Структура:
//    * Условие - Строка - текст условия ограничения
//    * Поля    - Строка - поля ограничения (разделённые переносом строки)
//
Функция ПостроитьИндексОграничений(Ограничения)

	Индекс = Новый Соответствие;

	Для Каждого Строка Из Ограничения Цикл

		Ключ = СтрШаблон("%1|%2|%3",
			Строка.ВидОбъекта,
			Строка.ИмяОбъекта,
			Строка.ИмяПрава);

		ДанныеОграничения = Новый Структура;
		ДанныеОграничения.Вставить("Условие", Строка.УсловиеОграничения);

		Поля = "";
		Попытка
			Поля = Строка.Поля;
		Исключение
			// Колонка Поля отсутствует в источнике
		КонецПопытки;
		ДанныеОграничения.Вставить("Поля", Поля);

		Индекс.Вставить(Ключ, ДанныеОграничения);

	КонецЦикла;

	Возврат Индекс;

КонецФункции

// Группирует строки прав по полному dot-имени XML-объекта.
// Определяет dot-имя на основе полей: ВидОбъекта, ИмяОбъекта, ТипРеквизита,
// ИмяРеквизита, ИмяРеквизитаТЧ — по логике dot-нотации Rights.xml.
//
// Параметры:
//  Права - ТаблицаЗначений - таблица прав (колонки: ВидОбъекта, ИмяОбъекта, ИмяПрава,
//                            ТипРеквизита, ИмяРеквизита, ИмяРеквизитаТЧ, ЗначениеПрава)
//
// Возвращаемое значение:
//  Соответствие - полное dot-имя объекта → Массив из Структура:
//    * ИмяПрава         - Строка
//    * ЗначениеПрава    - Булево
//    * КлючОграничения  - Строка ("ВидОбъекта|ИмяОбъекта|ИмяПрава" для поиска в индексе ограничений)
//
Функция СгруппироватьПраваПоОбъектам(Права)

	ИндексОбъектов = Новый Соответствие;

	Для Каждого СтрокаПрава Из Права Цикл

		ПолноеИмя = ПолноеИмяОбъектаДляXML(СтрокаПрава);

		МассивПрав = ИндексОбъектов.Получить(ПолноеИмя);
		Если МассивПрав = Неопределено Тогда
			МассивПрав = Новый Массив;
			ИндексОбъектов.Вставить(ПолноеИмя, МассивПрав);
		КонецЕсли;

		ЗаписьПрава = Новый Структура;
		ЗаписьПрава.Вставить("ИмяПрава",        СтрокаПрава.ИмяПрава);
		ЗаписьПрава.Вставить("ЗначениеПрава",   СтрокаПрава.ЗначениеПрава);
		// Ключ ограничения всегда ссылается на уровень объекта верхнего уровня (не реквизит)
		ЗаписьПрава.Вставить("КлючОграничения", СтрШаблон("%1|%2|%3",
			СтрокаПрава.ВидОбъекта,
			СтрокаПрава.ИмяОбъекта,
			СтрокаПрава.ИмяПрава));

		МассивПрав.Добавить(ЗаписьПрава);

	КонецЦикла;

	Возврат ИндексОбъектов;

КонецФункции

// Формирует полное dot-имя объекта для XML по строке таблицы прав.
//
// Логика dot-нотации:
//   Верхний уровень:       ВидОбъекта.ИмяОбъекта
//   Реквизит:               ВидОбъекта.ИмяОбъекта.Attribute.ИмяРеквизита
//   Стандартный реквизит:   ВидОбъекта.ИмяОбъекта.StandardAttribute.ИмяРеквизита
//   Табличная часть:        ВидОбъекта.ИмяОбъекта.TabularSection.ИмяРеквизита
//   Реквизит ТЧ:            ВидОбъекта.ИмяОбъекта.TabularSection.ИмяРеквизита.Attribute.ИмяРеквизитаТЧ
//   Команда:                ВидОбъекта.ИмяОбъекта.Command.ИмяРеквизита
//   Измерение:              ВидОбъекта.ИмяОбъекта.Dimension.ИмяРеквизита
//   Ресурс:                 ВидОбъекта.ИмяОбъекта.Resource.ИмяРеквизита
//
// Параметры:
//  СтрокаПрава - СтрокаТаблицыЗначений - строка таблицы прав
//
// Возвращаемое значение:
//  Строка - полное dot-имя объекта в Rights.xml
//
Функция ПолноеИмяОбъектаДляXML(СтрокаПрава)

	ВидОбъекта  = СтрокаПрава.ВидОбъекта;
	ИмяОбъекта  = СтрокаПрава.ИмяОбъекта;
	ТипРеквизита = СтрокаПрава.ТипРеквизита;
	ИмяРеквизита = СтрокаПрава.ИмяРеквизита;
	ИмяРеквизитаТЧ = СтрокаПрава.ИмяРеквизитаТЧ;

	// Нет реквизита — объект верхнего уровня
	Если ПустаяСтрока(ТипРеквизита) Или ПустаяСтрока(ИмяРеквизита) Тогда
		Возврат СтрШаблон("%1.%2", ВидОбъекта, ИмяОбъекта);
	КонецЕсли;

	СегментТипа = ПреобразоватьТипРеквизитаВСегментXML(ТипРеквизита);

	// Реквизит ТЧ: Document.X.TabularSection.ТЧ.Attribute.Реквизит
	Если Не ПустаяСтрока(ИмяРеквизитаТЧ) Тогда
		Возврат СтрШаблон("%1.%2.%3.%4.Attribute.%5",
			ВидОбъекта, ИмяОбъекта, СегментТипа, ИмяРеквизита, ИмяРеквизитаТЧ);
	КонецЕсли;

	// Реквизит / стандартный реквизит / ТЧ / команда / измерение / ресурс
	Возврат СтрШаблон("%1.%2.%3.%4",
		ВидОбъекта, ИмяОбъекта, СегментТипа, ИмяРеквизита);

КонецФункции

// Преобразует строковый идентификатор типа реквизита в сегмент dot-нотации Rights.xml.
//
// Параметры:
//  ТипРеквизита - Строка - идентификатор типа из модели ("Attribute", "StandardAttribute",
//                          "TabularSection", "StandardTabularSection", "Command",
//                          "Dimension", "Resource", "Requisite", "AccountingFlag",
//                          "AddressingAttribute")
//
// Возвращаемое значение:
//  Строка - сегмент dot-нотации (например "Attribute", "TabularSection")
//
Функция ПреобразоватьТипРеквизитаВСегментXML(ТипРеквизита)

	СоответствиеТипов = Новый Соответствие;
	СоответствиеТипов.Вставить("Attribute",              "Attribute");
	СоответствиеТипов.Вставить("StandardAttribute",      "StandardAttribute");
	СоответствиеТипов.Вставить("TabularSection",         "TabularSection");
	СоответствиеТипов.Вставить("StandardTabularSection", "TabularSection");
	СоответствиеТипов.Вставить("Command",                "Command");
	СоответствиеТипов.Вставить("Dimension",              "Dimension");
	СоответствиеТипов.Вставить("Resource",               "Resource");
	СоответствиеТипов.Вставить("Requisite",              "Requisite");
	СоответствиеТипов.Вставить("AccountingFlag",         "AccountingFlag");
	СоответствиеТипов.Вставить("AddressingAttribute",    "AddressingAttribute");

	Сегмент = СоответствиеТипов.Получить(ТипРеквизита);

	Если Сегмент = Неопределено Тогда
		// Неизвестный тип — возвращаем как есть, чтобы не потерять данные
		Возврат ТипРеквизита;
	КонецЕсли;

	Возврат Сегмент;

КонецФункции

#КонецОбласти
