#Область ПрограммныйИнтерфейс

// Возвращает конструктор параметров расширения с заполненными значениями по умолчанию.
//
// Возврат:
//  Структура - параметры расширения:
//   * ИмяРасширения - Строка  - программное имя расширения
//   * Синоним       - Строка  - синоним (человекочитаемое название)
//   * Версия        - Строка  - версия в формате "1.0.0.1"
//   * Префикс       - Строка  - префикс имён объектов расширения
//   * UUID          - Строка  - UUID конфигурации расширения
//
Функция НовыеПараметрыРасширения() Экспорт

	Параметры = Новый Структура;
	Параметры.Вставить("ИмяРасширения", "");
	Параметры.Вставить("Синоним",       "");
	Параметры.Вставить("Версия",        "1.0.0.1");
	Параметры.Вставить("Префикс",       "пр_цур_");
	Параметры.Вставить("UUID",          Строка(Новый УникальныйИдентификатор));

	Возврат Параметры;

КонецФункции

// Формирует полный текст Configuration.xml расширения на основе пакета ролей.
// Adopted-объекты группируются по коллекциям согласно реестру видов метаданных.
// Роли добавляются последними в блоке ChildObjects.
//
// Параметры:
//  ПакетРолей          - Массив из Структура - массив моделей ролей (см. цур_МодельРолейСервер.НовыеПараметрыРоли())
//  ПараметрыРасширения - Структура           - параметры расширения (см. НовыеПараметрыРасширения())
//
// Возврат:
//  Строка - текст XML файла Configuration.xml расширения
//
Функция СформироватьConfigurationXML(ПакетРолей, ПараметрыРасширения) Экспорт

	ОбъектыПоКоллекциям = СобратьУникальныеОбъектыПоКоллекциям(ПакетРолей);

	Запись = Новый ЗаписьXML;
	Запись.УстановитьСтроку();

	ЗаписатьЗаголовокXML(Запись, ПараметрыРасширения);
	ЗаписатьInternalInfo(Запись);
	ЗаписатьProperties(Запись, ПараметрыРасширения);
	ЗаписатьChildObjects(Запись, ОбъектыПоКоллекциям, ПакетРолей);

	Запись.ЗаписатьКонецЭлемента(); // Configuration
	Запись.ЗаписатьКонецЭлемента(); // MetaDataObject

	Возврат Запись.Закрыть();

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Записывает корневой элемент MetaDataObject и открывает элемент Configuration.
//
// Параметры:
//  Запись              - ЗаписьXML  - объект потоковой записи XML
//  ПараметрыРасширения - Структура  - параметры расширения
//
Процедура ЗаписатьЗаголовокXML(Запись, ПараметрыРасширения)

	НсМДО = "http://v8.1c.ru/8.3/MDClasses";

	Запись.ЗаписатьНачалоЭлемента("MetaDataObject");
	Запись.ЗаписатьАтрибут("xmlns",      НсМДО);
	Запись.ЗаписатьАтрибут("xmlns:app",  "http://v8.1c.ru/8.2/managed-application/core");
	Запись.ЗаписатьАтрибут("xmlns:cfg",  "http://v8.1c.ru/8.1/data/enterprise/current-config");
	Запись.ЗаписатьАтрибут("xmlns:cmi",  "http://v8.1c.ru/8.2/managed-application/cmi");
	Запись.ЗаписатьАтрибут("xmlns:ent",  "http://v8.1c.ru/8.1/data/enterprise");
	Запись.ЗаписатьАтрибут("xmlns:lf",   "http://v8.1c.ru/8.2/managed-application/logform");
	Запись.ЗаписатьАтрибут("xmlns:style", "http://v8.1c.ru/8.1/data/ui/style");
	Запись.ЗаписатьАтрибут("xmlns:sys",  "http://v8.1c.ru/8.1/data/ui/fonts/system");
	Запись.ЗаписатьАтрибут("xmlns:v8",   "http://v8.1c.ru/8.1/data/core");
	Запись.ЗаписатьАтрибут("xmlns:v8ui", "http://v8.1c.ru/8.1/data/ui");
	Запись.ЗаписатьАтрибут("xmlns:web",  "http://v8.1c.ru/8.1/data/ui/colors/web");
	Запись.ЗаписатьАтрибут("xmlns:win",  "http://v8.1c.ru/8.1/data/ui/colors/windows");
	Запись.ЗаписатьАтрибут("xmlns:xen",  "http://v8.1c.ru/8.3/xcf/enums");
	Запись.ЗаписатьАтрибут("xmlns:xpr",  "http://v8.1c.ru/8.3/xcf/predef");
	Запись.ЗаписатьАтрибут("xmlns:xr",   "http://v8.1c.ru/8.3/xcf/readable");
	Запись.ЗаписатьАтрибут("xmlns:xs",   "http://www.w3.org/2001/XMLSchema");
	Запись.ЗаписатьАтрибут("xmlns:xsi",  "http://www.w3.org/2001/XMLSchema-instance");
	Запись.ЗаписатьАтрибут("version",    "2.20");

	Запись.ЗаписатьНачалоЭлемента("Configuration");
	Запись.ЗаписатьАтрибут("uuid", ПараметрыРасширения.UUID);

КонецПроцедуры

// Записывает блок InternalInfo с фиксированными ClassId и новыми ObjectId для каждого расширения,
// а также блоки PropertyState для модулей расширения.
//
// Параметры:
//  Запись - ЗаписьXML - объект потоковой записи XML
//
Процедура ЗаписатьInternalInfo(Запись)

	// ClassId фиксированы платформой; ObjectId генерируются для каждого расширения заново
	МассивClassId = Новый Массив;
	МассивClassId.Добавить("9cd510cd-abfc-11d4-9434-004095e12fc7"); // ManagedApplicationModule
	МассивClassId.Добавить("9fcd25a0-4822-11d4-9414-008048da11f9"); // SessionModule
	МассивClassId.Добавить("e3687481-0a87-462c-a166-9f34594f9bba"); // ExternalConnectionModule
	МассивClassId.Добавить("9de14907-ec23-4a07-96f0-85521cb6b53b"); // CommandInterface
	МассивClassId.Добавить("51f2d5d8-ea4d-4064-8892-82951750031e"); // MainSectionCommandInterface
	МассивClassId.Добавить("e68182ea-4237-4383-967f-90c1e3370bc7"); // OrdinaryApplicationModule
	МассивClassId.Добавить("fb282519-d103-4dd3-bc12-cb271d631dfc"); // CommonModule (container)

	МассивPropertyState = Новый Массив;
	МассивPropertyState.Добавить("ManagedApplicationModule");
	МассивPropertyState.Добавить("SessionModule");
	МассивPropertyState.Добавить("ExternalConnectionModule");
	МассивPropertyState.Добавить("CommandInterface");
	МассивPropertyState.Добавить("MainSectionCommandInterface");

	Запись.ЗаписатьНачалоЭлемента("InternalInfo");

	Для Каждого ClassId Из МассивClassId Цикл

		Запись.ЗаписатьНачалоЭлемента("xr:ContainedObject");

		Запись.ЗаписатьНачалоЭлемента("xr:ClassId");
		Запись.ЗаписатьТекст(ClassId);
		Запись.ЗаписатьКонецЭлемента();

		Запись.ЗаписатьНачалоЭлемента("xr:ObjectId");
		Запись.ЗаписатьТекст(Строка(Новый УникальныйИдентификатор));
		Запись.ЗаписатьКонецЭлемента();

		Запись.ЗаписатьКонецЭлемента(); // xr:ContainedObject

	КонецЦикла;

	Для Каждого ИмяСвойства Из МассивPropertyState Цикл

		Запись.ЗаписатьНачалоЭлемента("xr:PropertyState");

		Запись.ЗаписатьНачалоЭлемента("xr:Property");
		Запись.ЗаписатьТекст(ИмяСвойства);
		Запись.ЗаписатьКонецЭлемента();

		Запись.ЗаписатьНачалоЭлемента("xr:State");
		Запись.ЗаписатьТекст("Extended");
		Запись.ЗаписатьКонецЭлемента();

		Запись.ЗаписатьКонецЭлемента(); // xr:PropertyState

	КонецЦикла;

	Запись.ЗаписатьКонецЭлемента(); // InternalInfo

КонецПроцедуры

// Записывает блок Properties конфигурации расширения.
//
// Параметры:
//  Запись              - ЗаписьXML - объект потоковой записи XML
//  ПараметрыРасширения - Структура - параметры расширения
//
Процедура ЗаписатьProperties(Запись, ПараметрыРасширения)

	Запись.ЗаписатьНачалоЭлемента("Properties");

	ЗаписатьЭлементTekст(Запись, "ObjectBelonging", "Adopted");
	ЗаписатьЭлементTekст(Запись, "Name",            ПараметрыРасширения.ИмяРасширения);

	Запись.ЗаписатьНачалоЭлемента("Synonym");
	Запись.ЗаписатьНачалоЭлемента("v8:item");
	ЗаписатьЭлементTekст(Запись, "v8:lang",    "ru");
	ЗаписатьЭлементTekст(Запись, "v8:content", ПараметрыРасширения.Синоним);
	Запись.ЗаписатьКонецЭлемента(); // v8:item
	Запись.ЗаписатьКонецЭлемента(); // Synonym

	ЗаписатьЭлементTekст(Запись, "Comment", "");
	ЗаписатьЭлементTekст(Запись, "ConfigurationExtensionPurpose",            "AddOn");
	ЗаписатьЭлементTekст(Запись, "KeepMappingToExtendedConfigurationObjectsByIDs", "true");
	ЗаписатьЭлементTekст(Запись, "NamePrefix",                               ПараметрыРасширения.Префикс);
	ЗаписатьЭлементTekст(Запись, "ConfigurationExtensionCompatibilityMode",  "Version8_3_24");
	ЗаписатьЭлементTekст(Запись, "DefaultRunMode",                           "ManagedApplication");
	ЗаписатьЭлементTekст(Запись, "ScriptVariant",                            "Russian");
	ЗаписатьЭлементTekст(Запись, "Version",                                  ПараметрыРасширения.Версия);

	Запись.ЗаписатьКонецЭлемента(); // Properties

КонецПроцедуры

// Записывает блок ChildObjects: сначала adopted-объекты по коллекциям, затем роли.
//
// Параметры:
//  Запись                 - ЗаписьXML                         - объект потоковой записи XML
//  ОбъектыПоКоллекциям   - Соответствие из Массив из Строка  - ключ: тег коллекции, значение: массив имён объектов
//  ПакетРолей             - Массив из Структура               - массив моделей ролей
//
Процедура ЗаписатьChildObjects(Запись, ОбъектыПоКоллекциям, ПакетРолей)

	Запись.ЗаписатьНачалоЭлемента("ChildObjects");

	// Adopted-объекты, сгруппированные по коллекциям в порядке реестра
	ВсеВиды = цур_РеестрМетаданныхСерверПовтИсп.ВсеВидыМетаданных();

	Для Каждого ОписаниеВида Из ВсеВиды Цикл

		// Подсистемы и планы обмена пока не поддерживаются
		Если ОписаниеВида.ВидМетаданных = "Subsystem"
				Или ОписаниеВида.ВидМетаданных = "ExchangePlan" Тогда
			Продолжить;
		КонецЕсли;

		ТегКоллекции = ОписаниеВида.ИмяЭлементаРасширения;

		Если НЕ ЗначениеЗаполнено(ТегКоллекции) Тогда
			Продолжить;
		КонецЕсли;

		МассивОбъектов = ОбъектыПоКоллекциям.Получить(ТегКоллекции);

		Если МассивОбъектов = Неопределено Тогда
			Продолжить;
		КонецЕсли;

		Для Каждого ИмяОбъекта Из МассивОбъектов Цикл
			ЗаписатьЭлементTekст(Запись, ТегКоллекции, ИмяОбъекта);
		КонецЦикла;

	КонецЦикла;

	// Роли из пакета
	Для Каждого МодельРоли Из ПакетРолей Цикл

		Если НЕ ПустаяСтрока(МодельРоли.Имя) Тогда
			ЗаписатьЭлементTekст(Запись, "Role", МодельРоли.Имя);
		КонецЕсли;

	КонецЦикла;

	Запись.ЗаписатьКонецЭлемента(); // ChildObjects

КонецПроцедуры

// Собирает уникальные объекты из всех ролей пакета и группирует их по тегу коллекции расширения.
// Тег коллекции (ИмяЭлементаРасширения) берётся из реестра видов метаданных по полю ВидОбъекта.
//
// Параметры:
//  ПакетРолей - Массив из Структура - массив моделей ролей
//
// Возврат:
//  Соответствие - ключ: ИмяЭлементаРасширения (Строка), значение: Массив из Строка (имена объектов)
//
Функция СобратьУникальныеОбъектыПоКоллекциям(ПакетРолей)

	// Используем соответствие для исключения дублей: "ТегКоллекции|ИмяОбъекта" -> Истина
	УникальныеКлючи    = Новый Соответствие;
	ОбъектыПоКоллекциям = Новый Соответствие;

	Для Каждого МодельРоли Из ПакетРолей Цикл

		Для Каждого СтрокаПрава Из МодельРоли.Права Цикл

			Если ПустаяСтрока(СтрокаПрава.ВидОбъекта) ИЛИ ПустаяСтрока(СтрокаПрава.ИмяОбъекта) Тогда
				Продолжить;
			КонецЕсли;

			ОписаниеВида = цур_РеестрМетаданныхСерверПовтИсп.ОписаниеВида(СтрокаПрава.ВидОбъекта);

			Если ОписаниеВида = Неопределено Тогда
				Продолжить;
			КонецЕсли;

			ТегКоллекции = ОписаниеВида.ИмяЭлементаРасширения;

			Если НЕ ЗначениеЗаполнено(ТегКоллекции) Тогда
				Продолжить;
			КонецЕсли;

			КлючДубля = ТегКоллекции + "|" + СтрокаПрава.ИмяОбъекта;

			Если УникальныеКлючи.Получить(КлючДубля) <> Неопределено Тогда
				Продолжить;
			КонецЕсли;

			УникальныеКлючи.Вставить(КлючДубля, Истина);

			МассивОбъектов = ОбъектыПоКоллекциям.Получить(ТегКоллекции);

			Если МассивОбъектов = Неопределено Тогда
				МассивОбъектов = Новый Массив;
				ОбъектыПоКоллекциям.Вставить(ТегКоллекции, МассивОбъектов);
			КонецЕсли;

			МассивОбъектов.Добавить(СтрокаПрава.ИмяОбъекта);

		КонецЦикла;

	КонецЦикла;

	Возврат ОбъектыПоКоллекциям;

КонецФункции

// Вспомогательная процедура: записывает простой XML-элемент с текстовым содержимым.
//
// Параметры:
//  Запись - ЗаписьXML - объект потоковой записи XML
//  Тег    - Строка    - имя элемента
//  Текст  - Строка    - текстовое содержимое элемента
//
Процедура ЗаписатьЭлементTekст(Запись, Тег, Текст)

	Запись.ЗаписатьНачалоЭлемента(Тег);

	Если НЕ ПустаяСтрока(Текст) Тогда
		Запись.ЗаписатьТекст(Текст);
	КонецЕсли;

	Запись.ЗаписатьКонецЭлемента();

КонецПроцедуры

#КонецОбласти
