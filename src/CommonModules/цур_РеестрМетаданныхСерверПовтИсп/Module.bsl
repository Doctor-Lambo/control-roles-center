#Область ПрограммныйИнтерфейс

// Возвращает описание вида метаданных. Результат кэшируется на время сеанса.
//
// Параметры:
//  ВидМетаданных - Строка - строковый идентификатор вида (например "Catalog", "Document")
//
// Возврат:
//  Структура - описание вида (см. цур_РеестрМетаданныхСервер.ОписаниеВида())
//  Неопределено - если запись не найдена
//
Функция ОписаниеВида(ВидМетаданных) Экспорт
	Возврат цур_РеестрМетаданныхСервер.ОписаниеВида(ВидМетаданных);
КонецФункции

// Возвращает все виды метаданных, упорядоченные по полю Порядок.
// Результат кэшируется на время сеанса.
//
// Возврат:
//  Массив из Структура - каждый элемент имеет ту же структуру, что и результат ОписаниеВида()
//
Функция ВсеВидыМетаданных() Экспорт
	Возврат цур_РеестрМетаданныхСервер.ВсеВидыМетаданных();
КонецФункции

#КонецОбласти
