
#Область ПрограммныйИнтерфейс

// Подставляет параметры в строку-шаблон.
// Параметры задаются в строке как %1, %2, %3.
//
// Параметры:
//  ШаблонСтроки - Строка - шаблон с вхождениями вида "%1", "%2", "%3"
//  Параметр1    - Строка - значение первого параметра
//  Параметр2    - Строка - значение второго параметра; если не задан, подстановка не выполняется
//  Параметр3    - Строка - значение третьего параметра; если не задан, подстановка не выполняется
//
// Возвращаемое значение:
//  Строка - строка с подставленными значениями параметров
//
Функция ПодставитьПараметрыВСтроку(Знач ШаблонСтроки,
	Знач Параметр1, Знач Параметр2 = Неопределено, Знач Параметр3 = Неопределено) Экспорт

	Если Параметр3 <> Неопределено Тогда
		Возврат СтрШаблон(ШаблонСтроки, Параметр1, Параметр2, Параметр3);
	ИначеЕсли Параметр2 <> Неопределено Тогда
		Возврат СтрШаблон(ШаблонСтроки, Параметр1, Параметр2);
	Иначе
		Возврат СтрШаблон(ШаблонСтроки, Параметр1);
	КонецЕсли;

КонецФункции

// Разбивает строку на массив подстрок по заданному разделителю.
// Каждый элемент результирующего массива обрезается от пробелов по краям.
//
// Параметры:
//  Строка      - Строка - исходная строка
//  Разделитель - Строка - символ-разделитель; по умолчанию запятая
//
// Возвращаемое значение:
//  Массив из Строка - массив подстрок без ведущих и хвостовых пробелов
//
Функция СтрокаВМассивПодстрок(Знач Строка, Знач Разделитель = ",") Экспорт

	Части = СтрРазделить(Строка, Разделитель, Ложь);

	Для Индекс = 0 По Части.ВГраница() Цикл
		Части[Индекс] = СокрЛП(Части[Индекс]);
	КонецЦикла;

	Возврат Части;

КонецФункции

// Проверяет, начинается ли строка с заданной подстроки.
//
// Параметры:
//  Строка    - Строка - проверяемая строка
//  Подстрока - Строка - искомое начало строки
//
// Возвращаемое значение:
//  Булево - Истина, если строка начинается с заданной подстроки
//
Функция ЕстьПодстрокаВНачалеСтроки(Знач Строка, Знач Подстрока) Экспорт

	Возврат СтрНачинаетсяС(Строка, Подстрока);

КонецФункции

// Преобразует число в строку без лидирующих пробелов и разделителей групп разрядов.
//
// Параметры:
//  Число - Число - преобразуемое число
//
// Возвращаемое значение:
//  Строка - строковое представление числа
//
Функция ЧислоВСтроку(Знач Число) Экспорт

	Возврат Формат(Число, "ЧГ=0; ЧН=0");

КонецФункции

// Проверяет, является ли строка корректным уникальным идентификатором в формате UUID.
// Ожидаемый формат: 32 hex-символа, разбитые дефисами на группы 8-4-4-4-12.
//
// Параметры:
//  Строка - Строка - проверяемая строка
//
// Возвращаемое значение:
//  Булево - Истина, если строка является корректным UUID
//
Функция ЭтоУникальныйИдентификатор(Знач Строка) Экспорт

	ДлинаСтандартногоИдентификатора = 36;

	Если СтрДлина(Строка) <> ДлинаСтандартногоИдентификатора Тогда
		Возврат Ложь;
	КонецЕсли;

	Если НЕ ДефисыИдентификатораНаМесте(Строка) Тогда
		Возврат Ложь;
	КонецЕсли;

	ДопустимыеСимволы = "0123456789abcdefABCDEF";
	ПозицииДефисов    = ПозицииДефисовИдентификатора();

	Для Позиция = 1 По ДлинаСтандартногоИдентификатора Цикл

		Если ПозицииДефисов[Позиция] <> Неопределено Тогда
			Продолжить;
		КонецЕсли;

		Если СтрНайти(ДопустимыеСимволы, Сред(Строка, Позиция, 1)) = 0 Тогда
			Возврат Ложь;
		КонецЕсли;

	КонецЦикла;

	Возврат Истина;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Возвращает соответствие позиций дефисов в стандартном UUID (группы 8-4-4-4-12).
// Дефисы расположены на позициях 9, 14, 19 и 24.
//
// Возвращаемое значение:
//  Соответствие - ключи: позиции дефисов (Число), значение: Истина
//
Функция ПозицииДефисовИдентификатора()

	ПозицияДефиса1 = 9;
	ПозицияДефиса2 = 14;
	ПозицияДефиса3 = 19;
	ПозицияДефиса4 = 24;

	Позиции = Новый Соответствие;
	Позиции.Вставить(ПозицияДефиса1, Истина);
	Позиции.Вставить(ПозицияДефиса2, Истина);
	Позиции.Вставить(ПозицияДефиса3, Истина);
	Позиции.Вставить(ПозицияДефиса4, Истина);
	Возврат Позиции;

КонецФункции

// Проверяет, что дефисы в строке стоят на позициях, соответствующих формату UUID.
//
// Параметры:
//  Строка - Строка - строка длиной 36 символов
//
// Возвращаемое значение:
//  Булево - Истина, если дефисы расставлены в позициях 9, 14, 19, 24
//
Функция ДефисыИдентификатораНаМесте(Знач Строка)

	ПозицияДефиса1 = 9;
	ПозицияДефиса2 = 14;
	ПозицияДефиса3 = 19;
	ПозицияДефиса4 = 24;
	Дефис          = "-";

	Возврат Сред(Строка, ПозицияДефиса1, 1) = Дефис
		И Сред(Строка, ПозицияДефиса2, 1) = Дефис
		И Сред(Строка, ПозицияДефиса3, 1) = Дефис
		И Сред(Строка, ПозицияДефиса4, 1) = Дефис;

КонецФункции

#КонецОбласти
