#Область ПрограммныйИнтерфейс

// Создаёт временный каталог с уникальным именем на сервере.
//
// Параметры:
//  Префикс - Строка - Префикс имени создаваемого каталога.
//
// Возвращаемое значение:
//  Строка - Полный путь к созданному каталогу.
//
Функция СоздатьВременныйКаталог(Префикс = "гпр") Экспорт // BSLLS:Typo-off

	ДлинаФрагментаУИД = 8;

	ПутьКаталога = КаталогВременныхФайлов() // BSLLS:TempFilesDir-off
		+ Префикс + "_"
		+ Формат(ТекущаяДатаСеанса(), "ДФ=yyyyMMddHHmmss") + "_"
		+ Сред(Строка(Новый УникальныйИдентификатор()), 1, ДлинаФрагментаУИД);

	СоздатьКаталог(ПутьКаталога);

	Возврат ПутьКаталога;

КонецФункции

// Распаковывает макет гпр_ШаблонРасширения (ZIP-архив) в указанный каталог.
//
// Параметры:
//  КаталогНазначения - Строка - Путь к каталогу, в который распаковывается шаблон.
//
Процедура РаспаковатьШаблонРасширения(КаталогНазначения) Экспорт // BSLLS:Typo-off

	ДлинаФрагментаУИД = 8;

	// BSLLS:Typo-off
	ДвоичныеДанные = ПолучитьОбщийМакет("гпр_ШаблонРасширения");
	// BSLLS:Typo-on

	ПутьВременногоАрхива = ОбъединитьПути(КаталогВременныхФайлов(), // BSLLS:TempFilesDir-off
		// BSLLS:Typo-off
		"цур_template_" + Сред(Строка(Новый УникальныйИдентификатор()), 1, ДлинаФрагментаУИД) + ".zip");
		// BSLLS:Typo-on

	ДвоичныеДанные.Записать(ПутьВременногоАрхива);

	Архив = Новый ЧтениеZipФайла(ПутьВременногоАрхива);
	Архив.ИзвлечьВсе(КаталогНазначения, РежимВосстановленияПутейФайловZIP.Восстанавливать);
	Архив.Закрыть();

	// BSLLS:MissingCodeTryCatchEx-off
	Попытка
		УдалитьФайлы(ПутьВременногоАрхива);
	Исключение
		// Временный архив будет удалён ОС при следующей очистке. Ошибку не пробрасываем.
	КонецПопытки;
	// BSLLS:MissingCodeTryCatchEx-on

КонецПроцедуры

// Распаковывает макет гпр_ПустаяБазаДанных (ZIP-архив с пустой файловой базой) в указанный каталог.
//
// Параметры:
//  КаталогНазначения - Строка - Путь к каталогу, в который распаковывается пустая база.
//
Процедура РаспаковатьПустуюБазу(КаталогНазначения) Экспорт // BSLLS:Typo-off

	ДлинаФрагментаУИД = 8;

	// BSLLS:Typo-off
	ДвоичныеДанные = ПолучитьОбщийМакет("гпр_ПустаяБазаДанных");
	// BSLLS:Typo-on

	ПутьВременногоАрхива = ОбъединитьПути(КаталогВременныхФайлов(), // BSLLS:TempFilesDir-off
		// BSLLS:Typo-off
		"цур_emptydb_" + Сред(Строка(Новый УникальныйИдентификатор()), 1, ДлинаФрагментаУИД) + ".zip");
		// BSLLS:Typo-on

	ДвоичныеДанные.Записать(ПутьВременногоАрхива);

	Архив = Новый ЧтениеZipФайла(ПутьВременногоАрхива);
	Архив.ИзвлечьВсе(КаталогНазначения, РежимВосстановленияПутейФайловZIP.Восстанавливать);
	Архив.Закрыть();

	// BSLLS:MissingCodeTryCatchEx-off
	Попытка
		УдалитьФайлы(ПутьВременногоАрхива);
	Исключение
		// Временный архив будет удалён ОС при следующей очистке. Ошибку не пробрасываем.
	КонецПопытки;
	// BSLLS:MissingCodeTryCatchEx-on

КонецПроцедуры

// Записывает текстовое содержимое в файл. Промежуточные каталоги создаются автоматически.
//
// Параметры:
//  ПолныйПуть - Строка   - Полный путь к файлу.
//  Содержимое - Строка   - Текст для записи.
//  Кодировка  - Строка   - Кодировка файла (по умолчанию "UTF-8").
//
Процедура ЗаписатьФайл(ПолныйПуть, Содержимое, Кодировка = "UTF-8") Экспорт

	КаталогФайла = "";

	РазделительПути = ПолучитьРазделительПутиСервера();
	ЧастиПути       = СтрРазделить(ПолныйПуть, РазделительПути, Ложь);

	Если ЧастиПути.Количество() > 1 Тогда
		ЧастиПути.Удалить(ЧастиПути.ВГраница());
		КаталогФайла = СтрСоединить(ЧастиПути, РазделительПути);
	КонецЕсли;

	Если ЗначениеЗаполнено(КаталогФайла) Тогда
		СоздатьКаталогиПоПути(КаталогФайла);
	КонецЕсли;

	ИспользоватьBOM = (ВРег(Кодировка) = "UTF-8");

	Запись = Новый ЗаписьТекста(ПолныйПуть, Кодировка, , , ИспользоватьBOM);
	Запись.Записать(Содержимое);
	Запись.Закрыть();

КонецПроцедуры

// Читает и возвращает текстовое содержимое файла.
//
// Параметры:
//  ПолныйПуть - Строка - Полный путь к файлу.
//
// Возвращаемое значение:
//  Строка - Содержимое файла.
//
Функция ПрочитатьФайл(ПолныйПуть) Экспорт

	Чтение = Новый ЧтениеТекста(ПолныйПуть);
	Содержимое = Чтение.Прочитать();
	Чтение.Закрыть();

	Возврат Содержимое;

КонецФункции

// Удаляет временный каталог со всем содержимым. Ошибки удаления игнорируются.
//
// Параметры:
//  Каталог - Строка - Путь к каталогу для удаления.
//
Процедура УдалитьВременныйКаталог(Каталог) Экспорт

	// BSLLS:MissingCodeTryCatchEx-off
	Попытка
		УдалитьФайлы(Каталог, "*");
		УдалитьФайлы(Каталог);
	Исключение
		// Каталог будет удалён ОС при следующей очистке. Ошибку не пробрасываем.
	КонецПопытки;
	// BSLLS:MissingCodeTryCatchEx-on

КонецПроцедуры

// Создаёт подкаталог внутри указанного каталога, если он ещё не существует.
//
// Параметры:
//  Каталог           - Строка - Путь к родительскому каталогу.
//  ИмяПодкаталога    - Строка - Имя создаваемого подкаталога.
//
// Возвращаемое значение:
//  Строка - Полный путь к подкаталогу.
//
Функция СоздатьПодкаталог(Каталог, ИмяПодкаталога) Экспорт

	ПолныйПуть = ОбъединитьПути(Каталог, ИмяПодкаталога);

	ФайлКаталога = Новый Файл(ПолныйПуть);
	Если Не ФайлКаталога.Существует() Тогда
		СоздатьКаталог(ПолныйПуть);
	КонецЕсли;

	Возврат ПолныйПуть;

КонецФункции

// Объединяет два сегмента пути через системный разделитель пути сервера.
//
// Параметры:
//  Путь1 - Строка - Первый сегмент пути.
//  Путь2 - Строка - Второй сегмент пути.
//
// Возвращаемое значение:
//  Строка - Объединённый путь.
//
Функция ОбъединитьПути(Путь1, Путь2) Экспорт

	РазделительПути = ПолучитьРазделительПутиСервера();

	Путь1Нормализованный = СтрЗаменить(Путь1, "/", РазделительПути);
	Путь1Нормализованный = СтрЗаменить(Путь1Нормализованный, "\", РазделительПути);

	Путь2Нормализованный = СтрЗаменить(Путь2, "/", РазделительПути);
	Путь2Нормализованный = СтрЗаменить(Путь2Нормализованный, "\", РазделительПути);

	Если Прав(Путь1Нормализованный, 1) = РазделительПути Тогда
		Путь1Нормализованный = Лев(Путь1Нормализованный, СтрДлина(Путь1Нормализованный) - 1);
	КонецЕсли;

	Если Лев(Путь2Нормализованный, 1) = РазделительПути Тогда
		ДлинаБезПервогоСимвола = СтрДлина(Путь2Нормализованный) - 1;
		Путь2Нормализованный = Прав(Путь2Нормализованный, ДлинаБезПервогоСимвола);
	КонецЕсли;

	Возврат Путь1Нормализованный + РазделительПути + Путь2Нормализованный;

КонецФункции

// Рекурсивно создаёт все промежуточные каталоги по указанному пути.
//
// Параметры:
//  ПолныйПуть - Строка - Путь к конечному каталогу (не к файлу).
//
Процедура СоздатьКаталогиПоПути(ПолныйПуть) Экспорт

	РазделительПути = ПолучитьРазделительПутиСервера();
	ЧастиПути        = СтрРазделить(ПолныйПуть, РазделительПути, Ложь);

	НакопленныйПуть = "";

	Если СтрНачинаетсяС(ПолныйПуть, РазделительПути) Тогда
		НакопленныйПуть = РазделительПути;
	КонецЕсли;

	Для Каждого Часть Из ЧастиПути Цикл

		Если НакопленныйПуть = "" Тогда
			НакопленныйПуть = Часть;
		ИначеЕсли НакопленныйПуть = РазделительПути Тогда
			НакопленныйПуть = НакопленныйПуть + Часть;
		Иначе
			НакопленныйПуть = НакопленныйПуть + РазделительПути + Часть;
		КонецЕсли;

		ФайлКаталога = Новый Файл(НакопленныйПуть);
		Если Не ФайлКаталога.Существует() Тогда
			СоздатьКаталог(НакопленныйПуть);
		КонецЕсли;

	КонецЦикла;

КонецПроцедуры

#КонецОбласти
