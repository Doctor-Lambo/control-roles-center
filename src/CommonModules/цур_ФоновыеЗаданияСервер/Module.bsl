// Фабрика фоновых заданий.
// Абстрагирует запуск и контроль фоновых заданий.
// Переключение между собственной реализацией и БСП (ДлительныеОперации) —
// через константу цур_ИспользоватьБСП в настройках генератора ролей.
//
// Процедура фонового задания должна иметь сигнатуру:
//   Процедура ИмяПроцедуры(Параметры, АдресРезультата) Экспорт
//   Параметры       - Структура - произвольные параметры
//   АдресРезультата - Строка    - адрес временного хранилища для результата

#Область ПрограммныйИнтерфейс

// Запускает процедуру в фоновом задании.
//
// Параметры:
//  ИмяПроцедуры      - Строка - полное имя серверной процедуры (например "Справочники.цур_Роли.МояПроцедура")
//  Параметры          - Структура - параметры для передачи в процедуру
//  УИДФормы           - УникальныйИдентификатор - идентификатор формы-владельца хранилища
//  НаименованиеЗадания - Строка - отображаемое наименование задания
//
// Возвращаемое значение:
//  Структура:
//   * ИдентификаторЗадания - УникальныйИдентификатор - УИД фонового задания
//   * АдресРезультата       - Строка - адрес временного хранилища
//
Функция ВыполнитьВФоне(ИмяПроцедуры, Параметры, УИДФормы, НаименованиеЗадания = "") Экспорт

	Если ИспользоватьБСП() Тогда
		Возврат ВыполнитьЧерезБСП(ИмяПроцедуры, Параметры, УИДФормы, НаименованиеЗадания);
	КонецЕсли;

	АдресРезультата = ПоместитьВоВременноеХранилище(Неопределено, УИДФормы);

	ПараметрыЗадания = Новый Массив;
	ПараметрыЗадания.Добавить(Параметры);
	ПараметрыЗадания.Добавить(АдресРезультата);

	Если ПустаяСтрока(НаименованиеЗадания) Тогда
		НаименованиеЗадания = НСтр("ru = 'Фоновое задание'");
	КонецЕсли;

	Задание = ФоновыеЗадания.Выполнить(ИмяПроцедуры, ПараметрыЗадания, , НаименованиеЗадания);

	Результат = Новый Структура;
	Результат.Вставить("ИдентификаторЗадания", Задание.УникальныйИдентификатор);
	Результат.Вставить("АдресРезультата",      АдресРезультата);

	Возврат Результат;

КонецФункции

// Возвращает состояние фонового задания.
//
// Параметры:
//  ИдентификаторЗадания - УникальныйИдентификатор - УИД задания
//
// Возвращаемое значение:
//  Строка - "Выполняется", "Завершено" или "Ошибка"
//
Функция ПолучитьСостояние(ИдентификаторЗадания) Экспорт

	Задание = ФоновыеЗадания.НайтиПоУникальномуИдентификатору(ИдентификаторЗадания);

	Если Задание = Неопределено Тогда
		Возврат "Ошибка";
	КонецЕсли;

	Если Задание.Состояние = СостояниеФоновогоЗадания.Активно Тогда
		Возврат "Выполняется";
	ИначеЕсли Задание.Состояние = СостояниеФоновогоЗадания.Завершено Тогда
		Возврат "Завершено";
	ИначеЕсли Задание.Состояние = СостояниеФоновогоЗадания.ЗавершеноАварийно Тогда
		Возврат "Ошибка";
	ИначеЕсли Задание.Состояние = СостояниеФоновогоЗадания.Отменено Тогда
		Возврат "Ошибка";
	Иначе
		Возврат "Выполняется";
	КонецЕсли;

КонецФункции

// Возвращает описание ошибки фонового задания.
//
// Параметры:
//  ИдентификаторЗадания - УникальныйИдентификатор - УИД задания
//
// Возвращаемое значение:
//  Строка - текст ошибки или пустая строка
//
Функция ПолучитьОписаниеОшибки(ИдентификаторЗадания) Экспорт

	Задание = ФоновыеЗадания.НайтиПоУникальномуИдентификатору(ИдентификаторЗадания);

	Если Задание = Неопределено Тогда
		Возврат НСтр("ru = 'Фоновое задание не найдено.'");
	КонецЕсли;

	Если Задание.ИнформацияОбОшибке <> Неопределено Тогда
		Возврат ПодробноеПредставлениеОшибки(Задание.ИнформацияОбОшибке);
	КонецЕсли;

	Возврат "";

КонецФункции

// Определяет, следует ли использовать модули БСП для работы с длительными операциями.
// Читает значение из глобальной константы цур_ИспользоватьБСП.
//
// Возвращаемое значение:
//  Булево
//
Функция ИспользоватьБСП() Экспорт
	Возврат Константы.цур_ИспользоватьБСП.Получить();
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ВыполнитьЧерезБСП(ИмяПроцедуры, Параметры, УИДФормы, НаименованиеЗадания)

	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(УИДФормы);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НаименованиеЗадания;

	РезультатБСП = ДлительныеОперации.ВыполнитьВФоне(ИмяПроцедуры, Параметры, ПараметрыВыполнения);

	Результат = Новый Структура;
	Результат.Вставить("ИдентификаторЗадания", РезультатБСП.ИдентификаторЗадания);
	Результат.Вставить("АдресРезультата",      РезультатБСП.АдресРезультата);

	Возврат Результат;

КонецФункции

#КонецОбласти
