#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Асинх Процедура Сгенерировать(Команда)

	МассивРолей = Новый Массив;

	Для Каждого СтрокаТаблицы Из СписокРолей Цикл
		МассивРолей.Добавить(СтрокаТаблицы.Роль);
	КонецЦикла;

	Если МассивРолей.Количество() = 0 Тогда
		Ждать ПредупреждениеАсинх(НСтр("ru = 'Добавьте роли для генерации.'"));
		Возврат;
	КонецЕсли;

	Элементы.ГруппаПрогресс.Видимость = Истина;
	Элементы.СгенерироватьКнопка.Доступность = Ложь;
	ТекстПрогресса = НСтр("ru = 'Генерация расширения...'");
	ТекстЛога = "";

	ЗапуститьГенерациюВФоне(МассивРолей);

	ПодключитьОбработчикОжидания("ПроверитьЗавершениеГенерации", 2, Ложь);

КонецПроцедуры

&НаКлиенте
Процедура ПроверитьЗавершениеГенерации()

	Результат = ПолучитьРезультатФоновогоЗаданияНаСервере();

	Если НЕ Результат.Завершено Тогда
		Возврат;
	КонецЕсли;

	ОтключитьОбработчикОжидания("ПроверитьЗавершениеГенерации");
	Элементы.ГруппаПрогресс.Видимость = Ложь;
	Элементы.СгенерироватьКнопка.Доступность = Истина;

	РезультатГенерации = Результат.Результат;

	Если РезультатГенерации = Неопределено Тогда

		ТекстПрогресса = НСтр("ru = 'Ошибка генерации.'");
		ТекстЛога = Результат.ОписаниеОшибки;
		Возврат;

	КонецЕсли;

	Если РезультатГенерации.Успешно Тогда

		ПутьКCFE = РезультатГенерации.ПутьКCFE;

		Если ТипЗнч(РезультатГенерации.Лог) = Тип("Массив") Тогда
			ТекстЛога = СтрСоединить(РезультатГенерации.Лог, Символ(10));
		Иначе
			ТекстЛога = "" + РезультатГенерации.Лог;
		КонецЕсли;

		ТекстПрогресса = НСтр("ru = 'Генерация завершена успешно.'");
		ПоказатьОповещениеПользователя(НСтр("ru = 'Генератор ролей'"), , НСтр("ru = 'Расширение успешно создано.'"));

	Иначе

		ТекстПрогресса = НСтр("ru = 'Ошибка генерации.'");
		ЧастиЛога = Новый Массив;

		Если ТипЗнч(РезультатГенерации.Лог) = Тип("Массив") Тогда
			Для Каждого СтрокаЛога Из РезультатГенерации.Лог Цикл
				ЧастиЛога.Добавить(СтрокаЛога);
			КонецЦикла;
		КонецЕсли;

		ЧастиЛога.Добавить("--- ОШИБКА ---");
		ЧастиЛога.Добавить(РезультатГенерации.ТекстОшибки);
		ТекстЛога = СтрСоединить(ЧастиЛога, Символ(10));

	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Асинх Процедура ЗаполнитьАктуальные(Команда)

	Если НЕ ЗначениеЗаполнено(ИнформационнаяБаза) Тогда
		Ждать ПредупреждениеАсинх(НСтр("ru = 'Выберите информационную базу.'"));
		Возврат;
	КонецЕсли;

	ЗаполнитьАктуальныеНаСервере();

КонецПроцедуры

&НаКлиенте
Асинх Процедура ДобавитьРоли(Команда)

	ПараметрыФормы = Новый Структура("РежимВыбора, МножественныйВыбор", Истина, Истина);

	ОповещениеОЗакрытии = Новый ОписаниеОповещения("ДобавитьРолиЗавершение", ЭтотОбъект);

	ОткрытьФорму(
		"Справочник.цур_Роли.ФормаВыбора",
		ПараметрыФормы,
		ЭтотОбъект,
		,,,
		ОповещениеОЗакрытии,
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);

КонецПроцедуры

&НаКлиенте
Процедура ДобавитьРолиЗавершение(Результат, ДополнительныеПараметры) Экспорт

	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Если ТипЗнч(Результат) = Тип("Массив") Тогда
		Для Каждого Ссылка Из Результат Цикл
			ДобавитьРольВТаблицуНаСервере(Ссылка);
		КонецЦикла;
	Иначе
		ДобавитьРольВТаблицуНаСервере(Результат);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Асинх Процедура УстановитьРасширение(Команда)

	Если Не ЗначениеЗаполнено(ПутьКCFE) Тогда
		Ждать ПредупреждениеАсинх(НСтр("ru = 'Сначала выполните генерацию.'"));
		Возврат;
	КонецЕсли;

	Ответ = Ждать ВопросАсинх(
		НСтр("ru = 'Установить расширение в текущую базу?'"),
		РежимДиалогаВопрос.ДаНет);

	Если Ответ = КодВозвратаДиалога.Да Тогда
		УстановитьРасширениеНаСервере(ПутьКCFE);
		ПоказатьОповещениеПользователя(НСтр("ru = 'Генератор ролей'"), , НСтр("ru = 'Расширение установлено. Перезапустите приложение.'"));
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Асинх Процедура СохранитьCFE(Команда)

	Если НЕ ЗначениеЗаполнено(ПутьКCFE) Тогда
		Ждать ПредупреждениеАсинх(НСтр("ru = 'Сначала выполните генерацию.'"));
		Возврат;
	КонецЕсли;

	АдресФайла = ПоместитьCFEВоВременноеХранилищеНаСервере(ПутьКCFE);

	ДиалогСохранения = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
	ДиалогСохранения.Фильтр = НСтр("ru = 'Файлы расширений (*.cfe)|*.cfe'");
	ДиалогСохранения.Расширение = "cfe";
	ДиалогСохранения.ПолноеИмяФайла = ИмяФайлаCFE();

	ОповещениеОЗакрытии = Новый ОписаниеОповещения("СохранитьCFEЗавершение", ЭтотОбъект,
		Новый Структура("АдресФайла", АдресФайла));
	ДиалогСохранения.Показать(ОповещениеОЗакрытии);

КонецПроцедуры

&НаКлиенте
Процедура СохранитьCFEЗавершение(ВыбранныеФайлы, ДополнительныеПараметры) Экспорт

	Если ВыбранныеФайлы = Неопределено Или ВыбранныеФайлы.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;

	ПутьСохранения = ВыбранныеФайлы[0];

	ПолучаемыеФайлы = Новый Массив;
	ПолучаемыеФайлы.Добавить(Новый ОписаниеПередаваемогоФайла(ПутьСохранения, ДополнительныеПараметры.АдресФайла));

	НачатьПолучениеФайлов(Новый ОписаниеОповещения("ПолучениеCFEЗавершение", ЭтотОбъект), ПолучаемыеФайлы, , Ложь);

КонецПроцедуры

&НаКлиенте
Процедура ПолучениеCFEЗавершение(ПолученныеФайлы, ДополнительныеПараметры) Экспорт

	Если ПолученныеФайлы <> Неопределено И ПолученныеФайлы.Количество() > 0 Тогда
		ПоказатьОповещениеПользователя(НСтр("ru = 'Генератор ролей'"), ,
			СтрШаблон(НСтр("ru = 'CFE сохранён: %1'"), ПолученныеФайлы[0].ПолноеИмя));
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Функция ИмяФайлаCFE()

	ЧастиПути = СтрРазделить(ПутьКCFE, "/\");
	Возврат ЧастиПути[ЧастиПути.ВГраница()];

КонецФункции

&НаКлиенте
Процедура ОткрытьФайлCFE(Команда)

	Если ЗначениеЗаполнено(ПутьКCFE) Тогда
		НачатьЗапускПриложения(Новый ОписаниеОповещения, ПутьКCFE);
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗапуститьГенерациюВФоне(МассивРолей)

	Генератор = Обработки.цур_ГенераторРолей.Создать();
	РезультатЗапуска = Генератор.СгенерироватьВФоне(МассивРолей, УникальныйИдентификатор);
	ИдентификаторЗадания = РезультатЗапуска.ИдентификаторЗадания;
	АдресХранилища       = РезультатЗапуска.АдресХранилища;

КонецПроцедуры

&НаСервереБезКонтекста
Функция ПоместитьCFEВоВременноеХранилищеНаСервере(ПутьКФайлу)

	ДвоичныеДанные = Новый ДвоичныеДанные(ПутьКФайлу);
	Возврат ПоместитьВоВременноеХранилище(ДвоичныеДанные);

КонецФункции

&НаСервере
Функция ПолучитьРезультатФоновогоЗаданияНаСервере()

	Генератор = Обработки.цур_ГенераторРолей.Создать();
	Возврат Генератор.ПолучитьРезультатФоновогоЗадания(ИдентификаторЗадания, АдресХранилища);

КонецФункции

&НаСервере
Процедура ДобавитьРольВТаблицуНаСервере(СсылкаРоли)

	Если Не ЗначениеЗаполнено(СсылкаРоли) Тогда
		Возврат;
	КонецЕсли;

	СуществующиеСтроки = СписокРолей.НайтиСтроки(Новый Структура("Роль", СсылкаРоли));

	Если СуществующиеСтроки.Количество() > 0 Тогда
		Возврат;
	КонецЕсли;

	НоваяСтрока = СписокРолей.Добавить();
	НоваяСтрока.Роль = СсылкаРоли;
	НоваяСтрока.Наименование = Строка(СсылкаРоли);

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьАктуальныеНаСервере()

	СписокРолей.Очистить();

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Роли.Ссылка КАК Ссылка,
	|	Роли.Наименование КАК Наименование
	|ИЗ
	|	Справочник.цур_Роли КАК Роли
	|ГДЕ
	|	НЕ Роли.ПометкаУдаления
	|	И НЕ Роли.ЭтоГруппа
	|	И Роли.Статус = ЗНАЧЕНИЕ(Перечисление.цур_СтатусыРоли.Актуальна)
	|	И Роли.Владелец = &ИнформационнаяБаза
	|УПОРЯДОЧИТЬ ПО
	|	Роли.Наименование";
	Запрос.УстановитьПараметр("ИнформационнаяБаза", ИнформационнаяБаза);

	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();

	Пока Выборка.Следующий() Цикл

		НоваяСтрока = СписокРолей.Добавить();
		НоваяСтрока.Роль         = Выборка.Ссылка;
		НоваяСтрока.Наименование = Выборка.Наименование;

	КонецЦикла;

КонецПроцедуры

&НаСервереБезКонтекста
Процедура УстановитьРасширениеНаСервере(Путь)

	цур_КонструкторРасширенияСервер.УстановитьРасширение(Путь);

КонецПроцедуры

#КонецОбласти
