#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Выполняет полный пайплайн генерации расширения: нормализация → построение XML →
// распаковка шаблона → запись файлов → сборка CFE → установка → очистка.
//
// Параметры:
//  МассивСсылокРолей - Массив - массив СправочникСсылка.цур_Роли
//  РежимСборки       - Строка - "УстановитьСразу" для немедленной установки расширения,
//                       иначе пустая строка (по умолчанию — без установки)
//
// Возвращаемое значение:
//  Структура - результат генерации:
//   * Успешно      - Булево  - Истина, если пайплайн завершён без ошибок
//   * ТекстОшибки  - Строка  - описание ошибки (пусто при успехе)
//   * ПутьКCFE     - Строка  - путь к собранному CFE-файлу (пусто при ошибке)
//   * Лог          - Массив  - строки лога выполненных шагов
//
Функция Сгенерировать(МассивСсылокРолей, РежимСборки = "") Экспорт

	Лог               = Новый Массив;
	КаталогРасширения = "";

	Попытка

		// --- Шаг 1: Подготовка пакета ролей ---
		ДобавитьЗапись(Лог, "Шаг 1: Подготовка пакета ролей...");
		ПакетРолей = цур_МодельРолейСервер.ПодготовитьПакетРолей(МассивСсылокРолей);

		Если ПакетРолей.Количество() = 0 Тогда
			Возврат РезультатОшибки("Не удалось подготовить ни одной роли. "
				+ "Проверьте наличие ролей и результаты валидации.", Лог);
		КонецЕсли;

		ДобавитьЗапись(Лог, СтрШаблон("  Подготовлено ролей: %1", ПакетРолей.Количество()));

		// --- Шаг 2: Параметры расширения ---
		ДобавитьЗапись(Лог, "Шаг 2: Формирование параметров расширения...");
		ПараметрыРасширения = цур_ПостроительКонфигурацииСервер.НовыеПараметрыРасширения();
		ЗаполнитьПараметрыРасширения(ПараметрыРасширения, ПакетРолей);
		НомерВерсии = цур_КонструкторРасширенияСервер.ПолучитьСледующийНомерВерсии();
		ПараметрыРасширения.Версия = "1.0.0." + Формат(НомерВерсии, "ЧГ=0");
		ДобавитьЗапись(Лог, СтрШаблон("  Имя расширения: %1", ПараметрыРасширения.ИмяРасширения));
		ДобавитьЗапись(Лог, СтрШаблон("  Версия расширения: %1", ПараметрыРасширения.Версия));

		// --- Шаг 3: Генерация XML ролей (Rights.xml + метаданные) ---
		ДобавитьЗапись(Лог, "Шаг 3: Генерация XML ролей...");
		//BSLLS:LatinAndCyrillicSymbolInWord-off
		СоответствиеXMLРолей = СформироватьXMLВсехРолей(ПакетРолей);
		//BSLLS:LatinAndCyrillicSymbolInWord-on
		ДобавитьЗапись(Лог, СтрШаблон("  Сформировано XML-файлов ролей: %1", СоответствиеXMLРолей.Количество()));

		// --- Подготовка каталога расширения (до шага 4, т.к. DOM пишет файлы напрямую) ---
		КаталогРасширения = цур_ФайловыеОперацииСервер.СоздатьВременныйКаталог("цур_расш"); //BSLLS:Typo-off
		КаталогИсходников = цур_ФайловыеОперацииСервер.СоздатьПодкаталог(
			КаталогРасширения, "ExtensionConfiguration");

		// --- Шаг 4: Генерация XML adopted-объектов (DOM → файлы) ---
		ДобавитьЗапись(Лог, "Шаг 4: Генерация XML adopted-объектов...");
		//BSLLS:LatinAndCyrillicSymbolInWord-off
		КоличествоОбъектов = цур_ПостроительXMLОбъектовСервер.СформироватьВсеОбъекты(
			ПакетРолей, КаталогИсходников);
		//BSLLS:LatinAndCyrillicSymbolInWord-on
		ДобавитьЗапись(Лог, СтрШаблон("  Записано XML объектов: %1", КоличествоОбъектов));

		// --- Шаг 5: Генерация Configuration.xml ---
		ДобавитьЗапись(Лог, "Шаг 5: Генерация Configuration.xml...");
		Попытка
			//BSLLS:LatinAndCyrillicSymbolInWord-off
			ТекстConfigXML = цур_ПостроительКонфигурацииСервер.СформироватьConfigurationXML(
				ПакетРолей, ПараметрыРасширения);
			//BSLLS:LatinAndCyrillicSymbolInWord-on
			ДобавитьЗапись(Лог, СтрШаблон("  Configuration.xml: %1 символов", СтрДлина(ТекстConfigXML)));
		Исключение
			ТекстConfigXML = "";
			ДобавитьЗапись(Лог, "  ОШИБКА Configuration.xml: "
				+ цур_ОбщегоНазначения.ОписаниеОшибкиПодробное(ИнформацияОбОшибке()));
		КонецПопытки;

		// --- Шаг 6: Запись Configuration.xml и ролей ---
		ДобавитьЗапись(Лог, "Шаг 6: Запись Configuration.xml и ролей...");

		//BSLLS:LatinAndCyrillicSymbolInWord-off
		ЗаписатьXMLФайлыРасширения(
			КаталогРасширения,
			ТекстConfigXML,
			СоответствиеXMLРолей);
		//BSLLS:LatinAndCyrillicSymbolInWord-on

		ДобавитьЗапись(Лог, "  Файлы расширения записаны.");

		// --- Шаг 7: Сборка CFE ---
		ДобавитьЗапись(Лог, "Шаг 7: Сборка CFE...");
		ПараметрыСборки = цур_КонструкторРасширенияСервер.НовыеПараметрыСборки();
		//BSLLS:LatinAndCyrillicSymbolInWord-off
		РезультатСборки = цур_КонструкторРасширенияСервер.СобратьCFE(КаталогРасширения, ПараметрыСборки);
		//BSLLS:LatinAndCyrillicSymbolInWord-on

		Если Не РезультатСборки.Успешно Тогда

			Если ЗначениеЗаполнено(КаталогРасширения) Тогда
				цур_ФайловыеОперацииСервер.УдалитьВременныйКаталог(КаталогРасширения);
			КонецЕсли;

			Возврат РезультатОшибки(
				СтрШаблон("Ошибка сборки CFE: %1", РезультатСборки.ТекстОшибки), Лог);
		КонецЕсли;

		//BSLLS:LatinAndCyrillicSymbolInWord-off
		ДобавитьЗапись(Лог, СтрШаблон("  CFE собран: %1", РезультатСборки.ПутьКCFE));
		//BSLLS:LatinAndCyrillicSymbolInWord-on

		ДобавитьЗапись(Лог, СтрШаблон("  Версия зафиксирована: %1", НомерВерсии));

		// --- Шаг 8: Установка расширения (опционально) ---
		Если РежимСборки = "УстановитьСразу" Тогда
			ДобавитьЗапись(Лог, "Шаг 8: Установка расширения...");
			//BSLLS:LatinAndCyrillicSymbolInWord-off
			цур_КонструкторРасширенияСервер.УстановитьРасширение(РезультатСборки.ПутьКCFE);
			//BSLLS:LatinAndCyrillicSymbolInWord-on
			ДобавитьЗапись(Лог, "  Расширение установлено.");
		КонецЕсли;

		// --- Шаг 9: Очистка ---
		ДобавитьЗапись(Лог, "Шаг 9: Очистка временных файлов...");
		цур_ФайловыеОперацииСервер.УдалитьВременныйКаталог(КаталогРасширения);
		КаталогРасширения = "";

		ДобавитьЗапись(Лог, "Генерация завершена успешно.");

		Результат = Новый Структура;
		Результат.Вставить("Успешно",     Истина);
		Результат.Вставить("ТекстОшибки", "");
		//BSLLS:LatinAndCyrillicSymbolInWord-off
		Результат.Вставить("ПутьКCFE",    РезультатСборки.ПутьКCFE);
		//BSLLS:LatinAndCyrillicSymbolInWord-on
		Результат.Вставить("Лог",         Лог);

		Возврат Результат;

	Исключение

		//BSLLS:DeprecatedMethods8317-off
		ТекстОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		//BSLLS:DeprecatedMethods8317-on
		ДобавитьЗапись(Лог, СтрШаблон("ОШИБКА: %1", ТекстОшибки));

		Если ЗначениеЗаполнено(КаталогРасширения) Тогда
			цур_ФайловыеОперацииСервер.УдалитьВременныйКаталог(КаталогРасширения);
		КонецЕсли;

		Возврат РезультатОшибки(ТекстОшибки, Лог);

	КонецПопытки;

КонецФункции

// Запускает генерацию расширения в фоновом задании.
// Параметры задания размещаются во временном хранилище формы.
//
// Параметры:
//  МассивСсылокРолей  - Массив              - массив СправочникСсылка.цур_Роли
//  ИдентификаторФормы - УникальныйИдентификатор - идентификатор формы-владельца хранилища
//
// Возвращаемое значение:
//  Структура - описание запущенного задания:
//   * ИдентификаторЗадания - УникальныйИдентификатор - идентификатор фонового задания
//   * АдресХранилища       - Строка - адрес временного хранилища для результата
//
Функция СгенерироватьВФоне(МассивСсылокРолей, ИдентификаторФормы) Экспорт

	АдресХранилища = ПоместитьВоВременноеХранилище(Неопределено, ИдентификаторФормы);

	ПараметрыЗадания = Новый Массив;
	ПараметрыЗадания.Добавить(МассивСсылокРолей);
	ПараметрыЗадания.Добавить(АдресХранилища);

	НаименованиеЗадания = НСтр("ru = 'Генератор ролей: генерация расширения'");

	ФоновоеЗадание = ФоновыеЗадания.Выполнить(
		"цур_ВызовСервера.ВыполнитьГенерациюФоновое", // Внимание: при переименовании модуля/метода — обновить эту строку
		ПараметрыЗадания,
		Неопределено,
		НаименованиеЗадания);

	Результат = Новый Структура;
	Результат.Вставить("ИдентификаторЗадания", Строка(ФоновоеЗадание.УникальныйИдентификатор));
	Результат.Вставить("АдресХранилища",       АдресХранилища);

	Возврат Результат;

КонецФункции

// Проверяет статус фонового задания и возвращает результат при его завершении.
//
// Параметры:
//  ИдентификаторЗадания - УникальныйИдентификатор - идентификатор фонового задания
//  АдресХранилища       - Строка - адрес временного хранилища результата
//
// Возвращаемое значение:
//  Структура - состояние задания:
//   * Завершено        - Булево  - Истина, если задание завершено (успешно или с ошибкой)
//   * Результат        - Структура - результат генерации (Неопределено, пока не завершено)
//   * ОписаниеОшибки   - Строка  - текст ошибки выполнения задания (пусто при успехе)
//
Функция ПолучитьРезультатФоновогоЗадания(ИдентификаторЗадания, АдресХранилища) Экспорт

	Результат = Новый Структура;
	Результат.Вставить("Завершено",      Ложь);
	Результат.Вставить("Результат",      Неопределено);
	Результат.Вставить("ОписаниеОшибки", "");

	ФоновоеЗадание = ФоновыеЗадания.НайтиПоУникальномуИдентификатору(
		Новый УникальныйИдентификатор(ИдентификаторЗадания));

	Если ФоновоеЗадание = Неопределено Тогда
		Результат.Завершено      = Истина;
		Результат.ОписаниеОшибки = НСтр("ru = 'Фоновое задание не найдено.'");
		Возврат Результат;
	КонецЕсли;

	Состояние = ФоновоеЗадание.Состояние;

	Если Состояние = СостояниеФоновогоЗадания.Активно Тогда
		Возврат Результат;
	КонецЕсли;

	Результат.Завершено = Истина;

	Если Состояние = СостояниеФоновогоЗадания.ЗавершеноАварийно Тогда

		ИнформацияОбОшибке = ФоновоеЗадание.ИнформацияОбОшибке;
		Если ИнформацияОбОшибке <> Неопределено Тогда
			//BSLLS:DeprecatedMethods8317-off
			Результат.ОписаниеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
			//BSLLS:DeprecatedMethods8317-on
		Иначе
			Результат.ОписаниеОшибки = НСтр("ru = 'Фоновое задание завершено аварийно.'");
		КонецЕсли;

	ИначеЕсли Состояние = СостояниеФоновогоЗадания.Отменено Тогда

		Результат.ОписаниеОшибки = НСтр("ru = 'Фоновое задание отменено.'");

	ИначеЕсли Состояние = СостояниеФоновогоЗадания.Завершено Тогда

		РезультатИзХранилища = ПолучитьИзВременногоХранилища(АдресХранилища);
		Результат.Результат  = РезультатИзХранилища;

	Иначе

		Результат.ОписаниеОшибки = СтрШаблон(НСтр("ru = 'Неизвестное состояние задания: %1'"), Состояние);

	КонецЕсли;

	Возврат Результат;

КонецФункции

// Точка входа фонового задания. Выполняет генерацию и сохраняет результат
// во временное хранилище по переданному адресу.
// Вызывается платформой через ФоновыеЗадания.Выполнить.
//
// Параметры:
//  МассивСсылокРолей - Массив - массив СправочникСсылка.цур_Роли
//  АдресХранилища    - Строка - адрес временного хранилища для размещения результата
//
Процедура ВыполнитьГенерациюФоновое(МассивСсылокРолей, АдресХранилища) Экспорт

	ОбъектОбработки   = Обработки.цур_ГенераторРолей.Создать();
	РезультатГенерации = ОбъектОбработки.Сгенерировать(МассивСсылокРолей);

	ПоместитьВоВременноеХранилище(РезультатГенерации, АдресХранилища);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Формирует соответствие XML-файлов всех ролей пакета.
// Каждая роль порождает два файла: Rights.xml и метаданные роли (ИмяРоли.xml).
//
// Параметры:
//  ПакетРолей - Массив - массив структур-моделей ролей
//
// Возвращаемое значение:
//  Соответствие - ключ: относительный путь в расширении (Строка), значение: XML-текст (Строка)
//
//BSLLS:LatinAndCyrillicSymbolInWord-off
Функция СформироватьXMLВсехРолей(ПакетРолей)

	СоответствиеXML = Новый Соответствие;

	Для Каждого МодельРоли Из ПакетРолей Цикл

		ТекстRights    = цур_ПостроительXMLРолейСервер.СформироватьRightsXML(МодельРоли);
		ТекстМетаданных = цур_ПостроительXMLРолейСервер.СформироватьМетаданныеРолиXML(МодельРоли);

		ПутьRights      = СтрШаблон("Roles/%1/Ext/Rights.xml", МодельРоли.Имя);
		ПутьМетаданных  = СтрШаблон("Roles/%1.xml",        МодельРоли.Имя);

		СоответствиеXML.Вставить(ПутьRights,     ТекстRights);
		СоответствиеXML.Вставить(ПутьМетаданных, ТекстМетаданных);

	КонецЦикла;

	Возврат СоответствиеXML;

КонецФункции
//BSLLS:LatinAndCyrillicSymbolInWord-on

// Записывает Configuration.xml и XML-файлы ролей в каталог расширения.
// Adopted-объекты записываются на шаге 4 через DOM напрямую.
//
// Параметры:
//  КаталогРасширения    - Строка       - путь к корню каталога расширения
//  ТекстConfigXML       - Строка       - текст Configuration.xml
//  СоответствиеXMLРолей - Соответствие - пути и тексты XML-файлов ролей
//
//BSLLS:LatinAndCyrillicSymbolInWord-off
Процедура ЗаписатьXMLФайлыРасширения(
		КаталогРасширения,
		ТекстConfigXML,
		СоответствиеXMLРолей)
//BSLLS:LatinAndCyrillicSymbolInWord-on

	РазделительПути   = ПолучитьРазделительПутиСервера();
	КаталогИсходников = цур_ФайловыеОперацииСервер.ОбъединитьПути(
		КаталогРасширения, "ExtensionConfiguration");
	ПутьConfiguration = цур_ФайловыеОперацииСервер.ОбъединитьПути(
		КаталогИсходников, "Configuration.xml");

	Если СтрДлина(ТекстConfigXML) > 0 Тогда

		ПолныйТекст = "<?xml version=""1.0"" encoding=""UTF-8""?>" + Символ(10) + ТекстConfigXML;
		ДвоичныеДанные = ПолучитьДвоичныеДанныеИзСтроки(ПолныйТекст, КодировкаТекста.UTF8, Истина);
		ДвоичныеДанные.Записать(ПутьConfiguration);

	КонецЕсли;

	//BSLLS:LatinAndCyrillicSymbolInWord-off
	Для Каждого ЭлементРоли Из СоответствиеXMLРолей Цикл

		ПутьФайла = цур_ФайловыеОперацииСервер.ОбъединитьПути(КаталогИсходников,
			СтрЗаменить(ЭлементРоли.Ключ, "/", РазделительПути));
		ЗаписатьXMLФайл(ПутьФайла, ЭлементРоли.Значение);

	КонецЦикла;
	//BSLLS:LatinAndCyrillicSymbolInWord-on

КонецПроцедуры

// Записывает XML-текст в файл через разбор в DOM и ЗаписьDOM → ЗаписьXML.ОткрытьФайл.
// Такой подход обеспечивает корректный формат файла для LoadConfigFromFiles.
//
// Параметры:
//  ПутьФайла - Строка - полный путь к файлу
//  ТекстXML  - Строка - XML-текст (с или без XML-декларации)
//
//BSLLS:LatinAndCyrillicSymbolInWord-off
Процедура ЗаписатьXMLФайл(ПутьФайла, ТекстXML)
//BSLLS:LatinAndCyrillicSymbolInWord-on

	Если НЕ СтрНачинаетсяС(ТекстXML, "<?xml") Тогда
		ТекстXML = "<?xml version=""1.0"" encoding=""UTF-8""?>" + Символ(10) + ТекстXML;
	КонецЕсли;

	ФайлОбъект = Новый Файл(ПутьФайла);
	цур_ФайловыеОперацииСервер.СоздатьКаталогиПоПути(ФайлОбъект.Путь);

	ЧтениеXML = Новый ЧтениеXML;
	ЧтениеXML.УстановитьСтроку(ТекстXML);

	ПостроительDOM = Новый ПостроительDOM;
	ДокументDOM = ПостроительDOM.Прочитать(ЧтениеXML);
	ЧтениеXML.Закрыть();

	ЗаписьXML = Новый ЗаписьXML;
	ЗаписьXML.ОткрытьФайл(ПутьФайла);

	СохранениеDOM = Новый ЗаписьDOM;
	СохранениеDOM.Записать(ДокументDOM, ЗаписьXML);

	ЗаписьXML.Закрыть();

КонецПроцедуры

// Заполняет параметры расширения на основе реквизитов объекта и пакета ролей.
// Имя расширения берётся из реквизита ИмяРасширения, а при его отсутствии
// формируется автоматически из имён ролей или временной метки.
//
// Параметры:
//  ПараметрыРасширения - Структура - конструктор из НовыеПараметрыРасширения()
//  ПакетРолей          - Массив    - массив структур-моделей ролей
//
Процедура ЗаполнитьПараметрыРасширения(ПараметрыРасширения, ПакетРолей)

	Если ЗначениеЗаполнено(ИмяРасширения) Тогда
		ПараметрыРасширения.ИмяРасширения = ИмяРасширения;
	Иначе
		ПараметрыРасширения.ИмяРасширения = "пр_цур_ПользовательскиеРолиРасширение";
	КонецЕсли;

	Если ПустаяСтрока(ПараметрыРасширения.Синоним) Тогда
		ПараметрыРасширения.Синоним = ПараметрыРасширения.ИмяРасширения;
	КонецЕсли;

КонецПроцедуры

// Формирует структуру результата с признаком ошибки.
//
// Параметры:
//  ТекстОшибки - Строка - описание ошибки
//  Лог         - Массив - накопленный лог шагов
//
// Возвращаемое значение:
//  Структура - результат с Успешно = Ложь
//
Функция РезультатОшибки(ТекстОшибки, Лог)

	Результат = Новый Структура;
	Результат.Вставить("Успешно",     Ложь);
	Результат.Вставить("ТекстОшибки", ТекстОшибки);
	//BSLLS:LatinAndCyrillicSymbolInWord-off
	Результат.Вставить("ПутьКCFE",    "");
	//BSLLS:LatinAndCyrillicSymbolInWord-on
	Результат.Вставить("Лог",         Лог);

	Возврат Результат;

КонецФункции

// Добавляет строку в массив лога с временной меткой текущего сеанса.
//
// Параметры:
//  Лог            - Массив - массив строк лога
//  СтрокаСообщения - Строка - добавляемое сообщение
//
Процедура ДобавитьЗапись(Лог, СтрокаСообщения)

	ВременнаяМетка = Формат(ТекущаяДатаСеанса(), "ДФ=HH:mm:ss");
	Лог.Добавить(СтрШаблон("[%1] %2", ВременнаяМетка, СтрокаСообщения));

КонецПроцедуры

#КонецОбласти

#КонецЕсли
