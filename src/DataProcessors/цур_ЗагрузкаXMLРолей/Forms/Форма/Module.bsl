&НаКлиенте
Процедура Загрузить(Команда)

	Если НЕ ЗначениеЗаполнено(ИнформационнаяБаза) Тогда
		ПоказатьОповещениеПользователя(НСтр("ru = 'Загрузка ролей'"), , НСтр("ru = 'Укажите информационную базу'"));
		Возврат;
	КонецЕсли;

	КаталогВыгрузки = ПолучитьКаталогВыгрузкиНаСервере();

	Если НЕ ЗначениеЗаполнено(КаталогВыгрузки) Тогда
		ПоказатьОповещениеПользователя(НСтр("ru = 'Загрузка ролей'"), ,
			НСтр("ru = 'Укажите каталог выгрузки в справочнике Информационные базы'"));
		Возврат;
	КонецЕсли;

	ТекстРезультата = НСтр("ru = 'Загрузка...'");

	РезультатЗагрузки = ЗагрузитьНаСервере(КаталогВыгрузки);

	Если РезультатЗагрузки.Успешно Тогда
		ТекстРезультата = СтрШаблон(НСтр("ru = 'Успешно загружено ролей: %1'"), РезультатЗагрузки.Количество);
		ПоказатьОповещениеПользователя(НСтр("ru = 'Загрузка ролей'"), , ТекстРезультата);
	Иначе
		ТекстРезультата = НСтр("ru = 'Ошибка при загрузке'");

		ОшибкиТекст = "";
		Для Каждого Ошибка Из РезультатЗагрузки.Ошибки Цикл
			ОшибкиТекст = ОшибкиТекст + Ошибка + Символы.ПС;
		КонецЦикла;

		Если ЗначениеЗаполнено(ОшибкиТекст) Тогда
			Сообщить(ОшибкиТекст);
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьИзБазы(Команда)

	Если НЕ ЗначениеЗаполнено(ИнформационнаяБаза) Тогда
		ПоказатьОповещениеПользователя(НСтр("ru = 'Загрузка ролей'"), , НСтр("ru = 'Укажите информационную базу'"));
		Возврат;
	КонецЕсли;

	ТекстРезультата = НСтр("ru = 'Загрузка ролей из базы...'");
	УстановитьДоступностьКоманд(Ложь);

	ЗапуститьЗагрузкуИзБазыВФоне();
	ПодключитьОбработчикОжидания("ПроверитьЗавершениеЗагрузки", 2, Ложь);

КонецПроцедуры

&НаКлиенте
Процедура ПроверитьЗавершениеЗагрузки()

	Результат = ПолучитьРезультатФоновогоЗаданияЗагрузки();

	Если НЕ Результат.Завершено Тогда
		Возврат;
	КонецЕсли;

	ОтключитьОбработчикОжидания("ПроверитьЗавершениеЗагрузки");
	УстановитьДоступностьКоманд(Истина);

	РезультатЗагрузки = Результат.Результат;

	Если РезультатЗагрузки = Неопределено Тогда
		ТекстРезультата = НСтр("ru = 'Ошибка загрузки.'");
		Сообщить(Результат.ОписаниеОшибки);
		Возврат;
	КонецЕсли;

	Если РезультатЗагрузки.Успешно Тогда
		ТекстРезультата = СтрШаблон(НСтр("ru = 'Успешно загружено ролей: %1'"), РезультатЗагрузки.Количество);
		ПоказатьОповещениеПользователя(НСтр("ru = 'Загрузка ролей'"), , ТекстРезультата);
	Иначе
		ТекстРезультата = НСтр("ru = 'Ошибка при загрузке из базы'");

		ОшибкиТекст = "";
		Для Каждого Ошибка Из РезультатЗагрузки.Ошибки Цикл
			ОшибкиТекст = ОшибкиТекст + Ошибка + Символы.ПС;
		КонецЦикла;

		Если ЗначениеЗаполнено(ОшибкиТекст) Тогда
			Сообщить(ОшибкиТекст);
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура УстановитьДоступностьКоманд(Доступность)

	Элементы.ЗагрузитьИзБазыКнопка.Доступность = Доступность;
	Элементы.ЗагрузитьКнопка.Доступность        = Доступность;

КонецПроцедуры

&НаКлиенте
Процедура ОбновитьМетаданные(Команда)

	Если НЕ ЗначениеЗаполнено(ИнформационнаяБаза) Тогда
		ПоказатьОповещениеПользователя(НСтр("ru = 'Метаданные'"), , НСтр("ru = 'Укажите информационную базу'"));
		Возврат;
	КонецЕсли;

	ОбновитьМетаданныеНаСервере();
	ПоказатьОповещениеПользователя(НСтр("ru = 'Метаданные'"), , НСтр("ru = 'Метаданные обновлены.'"));

КонецПроцедуры

&НаСервере
Процедура ОбновитьМетаданныеНаСервере()

	цур_ПровайдерМетаданныхСервер.ЗагрузитьМетаданныеИБ(ИнформационнаяБаза);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗапуститьЗагрузкуИзБазыВФоне()

	АдресХранилищаЗагрузки = ПоместитьВоВременноеХранилище(Неопределено, УникальныйИдентификатор);

	ПараметрыЗадания = Новый Массив;
	ПараметрыЗадания.Добавить(ИнформационнаяБаза);
	ПараметрыЗадания.Добавить(АдресХранилищаЗагрузки);

	ФоновоеЗадание = ФоновыеЗадания.Выполнить(
		"цур_ВызовСервера.ВыполнитьЗагрузкуРолейИзБазы", // Внимание: при переименовании модуля/метода — обновить эту строку
		ПараметрыЗадания,
		Неопределено,
		НСтр("ru = 'ЦУР: Загрузка ролей из базы'"));

	ИдентификаторЗаданияЗагрузки = Строка(ФоновоеЗадание.УникальныйИдентификатор);

КонецПроцедуры

&НаСервере
Функция ПолучитьРезультатФоновогоЗаданияЗагрузки()

	Результат = Новый Структура("Завершено, Результат, ОписаниеОшибки", Ложь, Неопределено, "");

	ФоновоеЗадание = ФоновыеЗадания.НайтиПоУникальномуИдентификатору(
		Новый УникальныйИдентификатор(ИдентификаторЗаданияЗагрузки));

	Если ФоновоеЗадание = Неопределено Тогда
		Результат.Завершено      = Истина;
		Результат.ОписаниеОшибки = НСтр("ru = 'Фоновое задание не найдено.'");
		Возврат Результат;
	КонецЕсли;

	Если ФоновоеЗадание.Состояние = СостояниеФоновогоЗадания.Активно Тогда
		Возврат Результат;
	КонецЕсли;

	Результат.Завершено = Истина;

	Если ФоновоеЗадание.Состояние = СостояниеФоновогоЗадания.ЗавершеноАварийно Тогда
		ИнформацияОбОшибке = ФоновоеЗадание.ИнформацияОбОшибке;
		Если ИнформацияОбОшибке <> Неопределено Тогда
			//BSLLS:DeprecatedMethods8317-off
			Результат.ОписаниеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
			//BSLLS:DeprecatedMethods8317-on
		Иначе
			Результат.ОписаниеОшибки = НСтр("ru = 'Фоновое задание завершено аварийно.'");
		КонецЕсли;
	ИначеЕсли ФоновоеЗадание.Состояние = СостояниеФоновогоЗадания.Завершено Тогда
		Результат.Результат = ПолучитьИзВременногоХранилища(АдресХранилищаЗагрузки);
	ИначеЕсли ФоновоеЗадание.Состояние = СостояниеФоновогоЗадания.Отменено Тогда
		Результат.ОписаниеОшибки = НСтр("ru = 'Загрузка отменена.'");
	КонецЕсли;

	Возврат Результат;

КонецФункции

&НаСервере
Функция ПолучитьКаталогВыгрузкиНаСервере()

	Возврат цур_ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
		ИнформационнаяБаза, "КаталогВыгрузкиКонфигурации");

КонецФункции

&НаСервере
Функция ЗагрузитьНаСервере(КаталогВыгрузки)

	ОбработкаОбъект = ДанныеФормыВЗначение(Объект, Тип("ОбработкаОбъект.цур_ЗагрузкаXMLРолей"));
	Возврат ОбработкаОбъект.ЗагрузитьИзКаталогаВыгрузки(КаталогВыгрузки, ИнформационнаяБаза);

КонецФункции

#КонецОбласти
